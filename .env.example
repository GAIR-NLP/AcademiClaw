# ==========================================================================
# AcademiClaw Evaluation Environment Configuration — EXAMPLE
# ==========================================================================
# Copy this file to `.env` inside each task directory you want to run and
# fill in your own credentials. NEVER commit a real `.env` to version control.
#
#   cp .env.example academiclaw/<task_id>/.env
#
# All fields are documented inline. `<placeholder>` style values MUST be
# replaced before running the harness.
# ==========================================================================


# --------------------------------------------------------------------------
# Experiment selection
# --------------------------------------------------------------------------
# Agent backend to evaluate: claude_code | openclaw | manual
AGENT_TYPE=openclaw

# Retry budget per subtask (>=1).
MAX_SUBTASK_ATTEMPTS=1

# Sandbox inactivity timeout in seconds before the harness aborts an attempt.
SANDBOX_TIMEOUT_SEC=1800


# --------------------------------------------------------------------------
# Claude Code agent (uses the Anthropic-compatible interface)
# --------------------------------------------------------------------------
CLAUDE_CODE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=<your_anthropic_or_proxy_key>
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_CODE_MAX_TURNS=300


# --------------------------------------------------------------------------
# OpenClaw agent (OpenAI-compatible chat completion endpoint)
# --------------------------------------------------------------------------
OPENCLAW_API_KEY=<your_openclaw_key>
OPENCLAW_BASE_URL=<your_openclaw_base_url>
OPENCLAW_MODEL=<model_identifier>
OPENCLAW_TIMEOUT_SECONDS=3600


# --------------------------------------------------------------------------
# Manual agent (for human-in-the-loop testing)
# --------------------------------------------------------------------------
MANUAL_MODEL_NAME=manual-agent


# --------------------------------------------------------------------------
# Judge models (used by rubric.py for LLM-as-Judge scoring)
# --------------------------------------------------------------------------
EVAL_TEXT_API_KEY=<your_judge_key>
EVAL_TEXT_API_BASE_URL=<your_judge_base_url>
EVAL_TEXT_MODEL=<strong_judge_model>

EVAL_VISION_API_KEY=<your_vision_judge_key>
EVAL_VISION_API_BASE_URL=<your_vision_judge_base_url>
EVAL_VISION_MODEL=<vision_capable_judge_model>


# --------------------------------------------------------------------------
# Task-specific keys (only needed for tasks that call external services)
# --------------------------------------------------------------------------
# Example: zh_piaofang_yuce_fenxi (box-office analysis) requires TMDB.
# TMDB_API_KEY=<your_tmdb_key>
