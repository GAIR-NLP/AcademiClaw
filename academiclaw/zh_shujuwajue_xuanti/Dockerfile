# 需要 PDF 解析能力（pypdf2 或 pdfplumber）。
# =============================================================================

# CPU 任务
FROM agencybench-sandbox


# =============================================================================
# 元数据
# =============================================================================

LABEL query="T12_zh_shujuwajue_xuanti"
LABEL task="数据挖掘课程项目选题与实施计划制定"


# =============================================================================
# 任务特定依赖
# =============================================================================

# 安装 PDF 解析库，供 Agent 读取课程文档
RUN pip3 install --no-cache-dir \
    pypdf2 \
    pdfplumber \
    pymupdf


# =============================================================================
# 工作目录
# =============================================================================

WORKDIR /agencybench


CMD []
