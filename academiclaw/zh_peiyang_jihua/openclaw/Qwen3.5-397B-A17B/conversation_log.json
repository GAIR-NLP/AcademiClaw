                    credits = float(parts[2])\\n                            hours = parts[1].strip()\\n                            all_courses.append({\\n                                'name': name,\\n                                'hours': hours,\\n                                'credits': credits,\\n                                'source': os.path.basename(f)\\n                            })\\n                        except ValueError:\\n                            continue\\n    \\n    return all_courses\\n\\n\\ndef categorize_course(course_name):\\n    \\\"\\\"\\\"根据课程名称分类\\\"\\\"\\\"\\n    # AI核心课程（需要较高匹配度）\\n    for kw, priority in AI_CORE_KEYWORDS[:12]:  # 前12个高优先级的算AI核心\\n        if kw in course_name:\\n            # 排除明显是其他领域的课程\\n            if any(exclude in course_name for exclude in ['医学', '生物', '化学', '材料', '能源', '食品', '农业', '环境']):\\n                continue\\n            return 'AI核心'\\n    \\n    # 数学基础\\n    for kw in MATH_KEYWORDS:\\n        if kw in course_name:\\n            return '数学基础'\\n    \\n    # 编程基础\\n    for kw in PROGRAMMING_KEYWORDS:\\n        if kw in course_name:\\n            return '编程基础'\\n    \\n    # 实践环节\\n    for kw in PRACTICE_KEYWORDS:\\n        if kw in course_name:\\n            return '实践环节'\\n    \\n    # 思政/通识\\n    for kw in GENERAL_KEYWORDS:\\n        if kw in course_name:\\n            return '思政通识'\\n    \\n    return '其他'\\n\\n\\ndef get_course_priority(course_name, category):\\n    \\\"\\\"\\\"获取课程优先级（用于排序选择）\\\"\\\"\\\"\\n    score = 0\\n    \\n    if category == 'AI核心':\\n        for kw, priority in AI_CORE_KEYWORDS:\\n            if kw in course_name:\\n                score += priority\\n                break\\n        # 纯AI课程加分\\n        if '人工智能' in course_name or '机器学习' in course_name or '深度学习' in course_name:\\n            score += 5\\n    \\n    elif category == '数学基础':\\n        if '高等数学' in course_name:\\n            score += 10\\n        elif '线性代数' in course_name:\\n            score += 9\\n     