urse)\\n    \\n    # 第6学期：AI进阶 - 大模型/强化学习（目标：18-22学分）\\n    for course in selected_courses['AI核心']:\\n        if ('大模型' in course['name'] or '强化学习' in course['name'] or '知识图谱' in course['name']) and get_semester_credits(6) < 20:\\n            add_course(6, course)\\n    \\n    # 补充AI核心课程到各学期\\n    for course in selected_courses['AI核心']:\\n        for sem in [3, 4, 5, 6]:\\n            if get_semester_credits(sem) < 20:\\n                add_course(sem, course)\\n            else:\\n                break\\n    \\n    # 第7学期：综合实践 + AI应用（目标：15-20学分）\\n    for course in selected_courses['实践环节']:\\n        if ('综合' in course['name'] or '实习' in course['name'] or '项目' in course['name']) and get_semester_credits(7) < 18:\\n            add_course(7, course)\\n    \\n    for course in selected_courses['AI核心']:\\n        if ('应用' in course['name'] or '系统' in course['name']) and get_semester_credits(7) < 18:\\n            add_course(7, course)\\n    \\n    # 第8学期：毕业设计/实习（目标：10-15学分）\\n    for course in selected_courses['实践环节']:\\n        if ('毕业' in course['name'] or '设计' in course['name']) and get_semester_credits(8) < 15:\\n            add_course(8, course)\\n    \\n    # 如果还有未分配的课程，尽量分配到合适的学期\\n    for category in ['AI核心', '数学基础', '编程基础', '实践环节', '思政通识']:\\n        for course in selected_courses[category]:\\n            if course['name'] not in used_courses:\\n                # 尝试分配到学分较少的学期\\n                for sem in range(1, 8):  # 第8学期只放毕业设计\\n                    if get_semester_credits(sem) < 22:\\n                        add_course(sem, course)\\n                        break\\n    \\n    return curriculum\\n\\n\\ndef calculate_credits(courses):\\n    \\\"\\\"\\\"计算学分总和\\\"\\\"\\\"\\n    return sum(c['credits'] for c in courses)\\n\\n\\ndef calculate_hours(courses):\\n    \\\"\\\"\\\"计算学时总和\\\"\\\"\\\"\\n    total = 0\\n    for c in courses:\\n        try:\\n            total += int(c['hours'])\\n        except ValueError:\\n            pass\\n    return total\\n\\n\\ndef generate_output(curriculum):\\n    \\\"\\\"\\\"生成输出文件（制表符分隔）\\\"\\\"\\\"\\n    lines = []\\n    lines.append(\\\"学期\\\\t课程名称\\\\t学时\\\\t学分\\\\t课程类别\\\")\\n    lines.append(\\\"\\\")\\n    \\n    category_map = {\\n        1: '第1学期', 2: '第2学期', 3: '第3学期', 4: '第4学期',\\n        5: '第5学期', 6: '第6学期', 7: '第7学期', 8: '第8学期'\\n    }\\n    \\n    total_credits = 0\\n    total_hours = 0\\n    \\n    for semester in range(1, 9):\\n        courses = curriculum[semester]\\n        if not courses:\\n            continue\\n        \\n        lines.append(f\\\"===== {category_map[semester]} =====\\\")\\n        semester_credits = 0\\n        semester_hours = 0\\n        \\n        for course in courses:\\n            category = course.get('category', categorize_course(course['name']))\\n            line = f\\\"{category_map[semester]}\\\\t{course['name']}\\\\t{course['hours']}\\\\t{course['credits']}\\\\t{category}\\\"\\n            lines.append(line)\\n            semester_credits += course['credits']\\n            try:\\n                semester_hours += int(course['hours'])\\n            except ValueError:\\n                pass\\n        \\n        lines.append(f\\\"学期小计\\\\t\\\\t\\\\t{semester_credits}\\\\t学时：{semester_hours}\\\")\\n        lines.append(\\\"\\\")\\n        \\n        total_credits += semester_credits\\n        total_hours += semester_hours\\n    \\n    lines.append(\\\"===== 总计 =====\\\")\\n    lines.append(f\\\"总学分：{total_credits}\\\\t总学时：{total_hours}\\\")\\n    \\n    return '\\\\n'.join(lines)\\n\\n\\ndef main():\\n    print(\\\"加载课程数据...\\\")\\n    all_courses = load_all_courses()\\n    print(f\\\"共加载 {len(all_courses)} 门课程\\\")\\n    \\n    print(\\\"分类课程...\\\")\\n    selected = select_courses_for_curriculum(all_courses)\\n    \\n    for cat, courses in selected.items():\\n        print(f\\\"  {cat}: {len(courses)} 门\\\")\\n    \\n    print(\\\"分配到学期...\\\")\\n    curriculum = distribute_to_semesters(selected)\\n    \\n    print(\\\"\\\\n学期分布:\\\")\