']) < 20:\\n            selected['AI核心'].append(course)\\n            ai_selected.add(course['name'])\\n    \\n    # 数学基础 - 选择6-8门核心数学课\\n    math_selected = set()\\n    for course in categorized['数学基础']:\\n        if course['name'] not in math_selected and len(selected['数学基础']) < 8:\\n            selected['数学基础'].append(course)\\n            math_selected.add(course['name'])\\n    \\n    # 编程基础 - 选择6-8门\\n    prog_selected = set()\\n    for course in categorized['编程基础']:\\n        if course['name'] not in prog_selected and len(selected['编程基础']) < 8:\\n            selected['编程基础'].append(course)\\n            prog_selected.add(course['name'])\\n    \\n    # 实践环节 - 选择10门\\n    prac_selected = set()\\n    for course in categorized['实践环节']:\\n        if course['name'] not in prac_selected and len(selected['实践环节']) < 10:\\n            selected['实践环节'].append(course)\\n            prac_selected.add(course['name'])\\n    \\n    # 思政通识 - 选择8门\\n    gen_selected = set()\\n    for course in categorized['思政通识']:\\n        if course['name'] not in gen_selected and len(selected['思政通识']) < 8:\\n            selected['思政通识'].append(course)\\n            gen_selected.add(course['name'])\\n    \\n    return selected\\n\\n\\ndef distribute_to_semesters(selected_courses):\\n    \\\"\\\"\\\"将课程分配到8个学期，考虑先修关系和学分平衡\\\"\\\"\\\"\\n    curriculum = {i: [] for i in range(1, 9)}\\n    used_courses = set()\\n    \\n    def add_course(semester, course):\\n        if course['name'] not in used_courses:\\n            curriculum[semester].append(course)\\n            used_courses.add(course['name'])\\n            return True\\n        return False\\n    \\n    def get_semester_credits(semester):\\n        return sum(c['credits'] for c in curriculum[semester])\\n    \\n    # 第1学期：数学基础 + 编程入门 + 思政通识（目标：20-25学分）\\n    # 高等数学、Python基础、英语、思政\\n    for course in selected_courses['数学基础']:\\n        if '高等数学' in course['name'] and get_semester_credits(1) < 22:\\n            add_course(1, course)\\n    \\n