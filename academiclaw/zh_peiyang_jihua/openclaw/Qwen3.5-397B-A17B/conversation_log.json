                  "arguments": "{\"content\": \"#!/usr/bin/env python3\\n# -*- coding: utf-8 -*-\\n\\\"\\\"\\\"\\n人工智能专业培养计划生成脚本（优化版）\\n生成符合约束的AI专业培养计划，确保：\\n1. 课程不重复\\n2. 学分分布合理（每学期15-25学分）\\n3. 先修关系合理\\n4. 覆盖AI核心、数学基础、编程基础、实践环节、思政通识\\n\\\"\\\"\\\"\\n\\nimport os\\nfrom collections import defaultdict\\n\\n# 数据文件路径\\nDATA_DIR = '/tmp/isolated_workspace_1091/context/original_data'\\nOUTPUT_FILE = '/tmp/isolated_workspace_1091/人工智能专业培养计划.txt'\\n\\n# AI核心关键词（按优先级排序）\\nAI_CORE_KEYWORDS = [\\n    ('机器学习', 10), ('深度学习', 10), ('人工智能', 10),\\n    ('神经网络', 9), ('大模型', 9), ('计算机视觉', 8),\\n    ('自然语言', 8), ('强化学习', 8), ('数据挖掘', 7),\\n    ('知识图谱', 7), ('智能系统', 7), ('模式识别', 7),\\n    ('图像识别', 6), ('图像', 5), ('视觉', 5),\\n    ('算法', 4), ('数据', 3), ('智能', 3)\\n]\\n\\n# 数学基础关键词\\nMATH_KEYWORDS = ['高等数学', '线性代数', '概率', '统计', '离散数学', '优化', '数值分析', '微积分']\\n\\n# 编程基础关键词\\nPROGRAMMING_KEYWORDS = ['Python', '编程', '数据结构', '算法', '软件工程', '数据库', '计算机系统', '导论']\\n\\n# 实践环节关键词\\nPRACTICE_KEYWORDS = ['实践', '实习', '实训', '实验', '项目', '综合', '设计', '创新']\\n\\n# 思政/通识关键词\\nGENERAL_KEYWORDS = ['思政', '通识', '文化', '历史', '哲学', '英语', '体育', '军事', '心理', '健康', '创业', '形势', '政策', '思想', '道德', '法治', '近现代', '马克思主义']\\n\\n\\ndef load_all_courses():\\n    \\\"\\\"\\\"加载所有课程数据\\\"\\\"\\\"\\n    files = [\\n        os.path.join(DATA_DIR, '2024-2025-3.txt'),\\n        os.path.join(DATA_DIR, '2025-2026-1.txt'),\\n        os.path.join(DATA_DIR, '2025-2026-2.txt')\\n    ]\\n    \\n    all_courses = []\\n    seen_names = set()\\n    \\n    for f in files:\\n        if not os.path.exists(f):\\n            continue\\n        with open(f, 'r', encoding='gbk') as file:\\n            lines = file.readlines()\\n            for line in lines[1:]:  # 跳过表头\\n                parts = line.strip().split('\\\\t')\\n                if len(parts) >= 3:\\n                    name = parts[0].strip()\\n                    if name and name not in seen_names:\\n                        seen_names.add(name)\\n                        try:\\n                            credits = float(parts[2])\\n                            hours = parts[1].strip()\\n                            all_courses.append({\\n                                'name': name,\\n                                'hours': hours,\\n                                'credits': credits,\\n                                'source': os.path.basename(f)\\n                            })\\n                        except ValueError:\\n                            continue\\n    \\n    return all_courses\\n\\n\\ndef categorize_course(course_name):\\n    \\\"\\\"\\\"根据课程名称分类\\\"\\\"\\\"\\n    # AI核心课程（需要较高匹配度）\\n    for kw, priority in AI_CORE_KEYWORDS[:12]:  # 前12个高优先级的算AI核心\\n        if kw in course_name:\\n            # 排除明显是其他领域的课程\\n            if any(exclude in course_name for exclude in ['医学', '生物', '化学', '材料', '能源', '食品', '农业', '环境']):\\n                continue\\n            return 'AI核心'\\n    \\n    # 数学基础\\n    for kw in MATH_KEYWORDS:\\n        if kw in course_name:\\n            return '数学基础'\\n    \\n    # 编程基础\\n    for kw in PROGRAMMING_KEYWORDS:\\n        if kw in course_name:\\n            return '编程基础'\\n    \\n    # 实践环节\\n    for kw in PRACTICE_KEYWORDS:\\n        if kw in course_name:\\n            return '实践环节'\\n    \\n    # 思政/通识\\n    for kw in GENERAL_KEYWORDS:\\n        if kw in course_name:\\n            return '思政通识'\\n    \\n    return '其他'\\n\\n\\ndef get_course_priority(course_name, category):\\n    \\\"\\\"\\\"获取课程优先级（用于排序选择）\\\"\\\"\\\"\\n    score = 0\\n    \\n    if category == 'AI核心':\\n        for kw, priority in AI_CORE_KEYWORDS:\\n            if kw in course_name:\\n                score += priority\\n                break\\n        # 纯AI课程加分\\n        if '人工智能' in course_name or '机器学习' in course_name or '深度学习' in course_name:\\n            score += 5\\n    \\n    elif category == '数学基础':\\n        if '高等数学' in course_name:\\n            score += 10\\n        elif '线性代数' in course_name:\\n            score += 9\\n        elif '概率' in course_name or '统计' in course_name:\\n            score += 8\\n        elif '离散' in course_name:\\n            score += 7\\n    \\n    elif category == '编程基础':\\n        if 'Python' in course_name:\\n            score += 10\\n        elif '数据结构' in course_name:\\n            score += 9\\n        elif '算法' in course_name:\\n            score += 8\\n        elif '导论' in course_name:\\n            score += 5\\n    \\n    elif category == '实践环节':\\n        if '毕业' in course_name or '综合' in course_name:\\n            score += 10\\n        elif '实习' in course_name:\\n            score += 8\\n        elif '实践' in course_name:\\n            score += 6\\n        elif '实验' in course_name:\\n            score += 4\\n    \\n    elif category == '思政通识':\\n        if '思政' in course_name or '思想' in course_name or '道德' in course_name or '法治' in course_name:\\n            score += 10\\n        elif '英语' in course_name:\\n            score += 8\\n        elif '体育' in course_name:\\n            score += 6\\n        elif '军事' in course_name:\\n            score += 5\\n    \\n    return score\\n\\n\\ndef select_courses_for_curriculum(all_courses):\\n    \\\"\\\"\\\"为培养计划选择课程\\\"\\\"\\\"\\n    categorized = defaultdict(list)\\n    \\n    for course in all_courses:\\n        category = categorize_course(course['name'])\\n        if category != '其他':\\n            course['category'] = category\\n            course['priority'] = get_course_priority(course['name'], category)\\n            categorized[category].append(course)\\n    \\n    # 对每个类别按优先级排序\\n    for cat in categorized:\\n        categorized[cat].sort(key=lambda x: -x['priority'])\\n    \\n    # 选择课程（确保不重复，按优先级选择）\\n    selected = {\\n        'AI核心': [],\\n        '数学基础': [],\\n        '编程基础': [],\\n        '实践环节': [],\\n        '思政通识': []\\n    }\\n    \\n    # AI核心课程 - 选择20门最重要的\\n    ai_selected = set()\\n    for course in categorized['AI核心']:\\n        if course['name'] not in ai_selected and len(selected['AI核心']) < 20:\\n            selected['AI核心'].append(course)\\n            ai_selected.add(course['name'])\\n    \\n    # 数学基础 - 选择6-8门核心数学课\\n    math_selected = set()\\n    for course in categorized['数学基础']:\\n        if course['name'] not in math_selected and len(selected['数学基础']) < 8:\\n            selected['数学基础'].append(course)\\n            math_selected.add(course['name'])\\n    \\n    # 编程基础 - 选择6-8门\\n    prog_selected = set()\\n    for course in categorized['编程基础']:\\n        if course['name'] not in prog_selected and len(selected['编程基础']) < 8:\\n            selected['编程基础'].append(course)\\n            prog_selected.add(course['name'])\\n    \\n    # 实践环节 - 选择10门\\n    prac_selected = set()\\n    for course in categorized['实践环节']:\\n        if course['name'] not in prac_selected and len(selected['实践环节']) < 10:\\n            selected['实践环节'].append(course)\\n            prac_selected.add(course['name'])\\n    \\n    # 思政通识 - 选择8门\\n    gen_selected = set()\\n    for course in categorized['思政通识']:\\n        if course['name'] not in gen_selected and len(selected['思政通识']) < 8:\\n            selected['思政通识'].append(course)\\n            gen_selected.add(course['name'])\\n    \\n    return selected\\n\\n\\ndef distribute_to_semesters(selected_courses):\\n    \\\"\\\"\\\"将课程分配到8个学期，考虑先修关系和学分平衡\\\"\\\"\\\"\\n    curriculum = {i: [] for i in range(1, 9)}\\n    used_courses = set()\\n    \\n    def add_course(semester, course):\\n        if course['name'] not in used_courses:\\n            curriculum[semester].append(course)\\n            used_courses.add(course['name'])\\n            return True\\n        return False\\n    \\n    def get_semester_credits(semester):\\n        return sum(c['credits'] for c in curriculum[semester])\\n    \\n    # 第1学期：数学基础 + 编程入门 + 思政通识（目标：20-25学分）\\n    # 高等数学、Python基础、英语、思政\\n    for course in selected_courses['数学基础']:\\n        if '高等数学' in course['name'] and get_semester_credits(1) < 22:\\n            add_course(1, course)\\n    \\n    for course in selected_courses['编程基础']:\\n        if ('Python' in course['name'] or '导论' in course['name']) and get_semester_credits(1) < 22:\\n            add_course(1, course)\\n    \\n    for course in selected_courses['思政通识']:\\n        if ('英语' in course['name'] or '体育' in course['name'] or '军事' in course['name']) and get_semester_credits(1) < 22:\\n            add_course(1, course)\\n    \\n    # 第2学期：数学继续 + 数据结构/算法 + 思政（目标：20-25学分）\\n    for course in selected_courses['数学基础']:\\n        if ('线性代数' in course['name'] or '概率' in course['name'] or '离散' in course['name']) and get_semester_credits(2) < 22:\\n            add_course(2, course)\\n    \\n    for course in selected_courses['编程基础']:\\n        if ('数据结构' in course['name'] or '算法' in course['name']) and get_semester_credits(2) < 22:\\n            add_course(2, course)\\n    \\n    for course in selected_courses['思政通识']:\\n        if get_semester_credits(2) < 22:\\n            add_course(2, course)\\n    \\n    # 第3学期：AI入门课程 + 基础实践（目标：18-22学分）\\n    for course in selected_courses['AI核心']:\\n        if ('人工智能' in course['name'] or '机器学习' in course['name']) and get_semester_credits(3) < 20:\\n            add_course(3, course)\\n    \\n    for course in selected_courses['实践环节']:\\n        if ('实验' in course['name'] or '实践' in course['name']) and get_semester_credits(3) < 20:\\n            add_course(3, course)\\n    \\n    # 第4学期：AI核心 - 深度学习（目标：18-22学分）\\n    for course in selected_courses['AI核心']:\\n        if '深度学习' in course['name'] and get_semester_credits(4) < 20:\\n            add_course(4, course)\\n    \\n    for course in selected_courses['AI核心']:\\n        if '神经网络' in course['name'] and get_semester_credits(4) < 20:\\n            add_course(4, course)\\n    \\n    # 第5学期：AI进阶 - 视觉/NLP（目标：18-22学分）\\n    for course in selected_courses['AI核心']:\\n        if ('视觉' in course['name'] or '图像' in course['name'] or '自然语言' in course['name']) and get_semester_credits(5) < 20:\\n            add_course(5, course)\\n    \\n    # 第6学期：AI进阶 - 大模型/强化学习（目标：18-22学分）\\n    for course in selected_courses['AI核心']:\\n        if ('大模型' in course['name'] or '强化学习' in course['name'] or '知识图谱' in course['name']) and get_semester_credits(6) < 20:\\n            add_course(6, course)\\n    \\n    # 补充AI核心课程到各学期\\n    for course in selected_courses['AI核心']:\\n        for sem in [3, 4, 5, 6]:\\n            if get_semester_credits(sem) < 20:\\n                add_course(sem, course)\\n            else:\\n                break\\n    \\n    # 第7学期：综合实践 + AI应用（目标：15-20学分）\\n    for course in selected_courses['实践环节']:\\n        if ('综合' in course['name'] or '实习' in course['name'] or '项目' in course['name']) and get_semester_credits(7) < 18:\\n            add_course(7, course)\\n    \\n    for course in selected_courses['AI核心']:\\n        if ('应用' in course['name'] or '系统' in course['name']) and get_semester_credits(7) < 18:\\n            add_course(7, course)\\n    \\n    # 第8学期：毕业设计/实习（目标：10-15学分）\\n    for course in selected_courses['实践环节']:\\n        if ('毕业' in course['name'] or '设计' in course['name']) and get_semester_credits(8) < 15:\\n            add_course(8, course)\\n    \\n    # 如果还有未分配的课程，尽量分配到合适的学期\\n    for category in ['AI核心', '数学基础', '编程基础', '实践环节', '思政通识']:\\n        for course in selected_courses[category]:\\n            if course['name'] not in used_courses:\\n                # 尝试分配到学分较少的学期\\n                for sem in range(1, 8):  # 第8学期只放毕业设计\\n                    if get_semester_credits(sem) < 22:\\n                        add_course(sem, course)\\n                        break\\n    \\n    return curriculum\\n\\n\\ndef calculate_credits(courses):\\n    \\\"\\\"\\\"计算学分总和\\\"\\\"\\\"\\n    return sum(c['credits'] for c in courses)\\n\\n\\ndef calculate_hours(courses):\\n    \\\"\\\"\\\"计算学时总和\\\"\\\"\\\"\\n    total = 0\\n    for c in courses:\\n        try:\\n            total += int(c['hours'])\\n        except ValueError:\\n            pass\\n    return total\\n\\n\\ndef generate_output(curriculum):\\n    \\\"\\\"\\\"生成输出文件（制表符分隔）\\\"\\\"\\\"\\n    lines = []\\n    lines.append(\\\"学期\\\\t课程名称\\\\t学时\\\\t学分\\\\t课程类别\\\")\\n    lines.append(\\\"\\\")\\n    \\n    category_map = {\\n        1: '第1学期', 2: '第2学期', 3: '第3学期', 4: '第4学期',\\n        5: '第5学期', 6: '第6学期', 7: '第7学期', 8: '第8学期'\\n    }\\n    \\n    total_credits = 0\\n    total_hours = 0\\n    \\n    for semester in range(1, 9):\\n        courses = curriculum[semester]\\n        if not courses:\\n            continue\\n        \\n        lines.append(f\\\"===== {category_map[semester]} =====\\\")\\n        semester_credits = 0\\n        semester_hours = 0\\n        \\n        for course in courses:\\n            category = course.get('category', categorize_course(course['name']))\\n            line = f\\\"{category_map[semester]}\\\\t{course['name']}\\\\t{course['hours']}\\\\t{course['credits']}\\\\t{category}\\\"\\n            lines.append(line)\\n            semester_credits += course['credits']\\n            try:\\n                semester_hours += int(course['hours'])\\n            except ValueError:\\n                pass\\n        \\n        lines.append(f\\\"学期小计\\\\t\\\\t\\\\t{semester_credits}\\\\t学时：{semester_hours}\\\")\\n        lines.append(\\\"\\\")\\n        \\n        total_credits += semester_credits\\n        total_hours += semester_hours\\n    \\n    lines.append(\\\"===== 总计 =====\\\")\\n    lines.append(f\\\"总学分：{total_credits}\\\\t总学时：{total_hours}\\\")\\n    \\n    return '\\\\n'.join(lines)\\n\\n\\ndef main():\\n    print(\\\"加载课程数据...\\\")\\n    all_courses = load_all_courses()\\n    print(f\\\"共加载 {len(all_courses)} 门课程\\\")\\n    \\n    print(\\\"分类课程...\\\")\\n    selected = select_courses_for_curriculum(all_courses)\\n    \\n    for cat, courses in selected.items():\\n        print(f\\\"  {cat}: {len(courses)} 门\\\")\\n    \\n    print(\\\"分配到学期...\\\")\\n    curriculum = distribute_to_semesters(selected)\\n    \\n    print(\\\"\\\\n学期分布:\\\")\\n    for sem in range(1, 9):\\n        credits = calculate_credits(curriculum[sem])\\n        hours = calculate_hours(curriculum[sem])\\n        print(f\\\"  第{sem}学期: {len(curriculum[sem])} 门课程, {credits} 学分, {hours} 学时\\\")\\n    \\n    total_credits = sum(calculate_credits(curriculum[s]) for s in range(1, 9))\\n    total_hours = sum(calculate_hours(curriculum[s]) for s in range(1, 9))\\n    print(f\\\"\\\\n总计: {total_credits} 学分, {total_hours} 学时\\\")\\n    \\n    print(\\\"\\\\n生成输出文件...\\\")\\n    output = generate_output(curriculum)\\n    \\n    with open(OUTPUT_FILE, 'w', encoding='utf-8') as f:\\n        f.write(output)\\n    \\n    print(f\\\"完成！输出文件：{OUTPUT_FILE}\\\")\\n\\n\\nif __name__ == '__main__':\\n    main()\", \"path\": \"/tmp/isolated_workspace_1091/generate_curriculum.py\"}"
