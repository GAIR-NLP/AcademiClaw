                "arguments": "{\"content\": \"#!/usr/bin/env python3\\n# -*- coding: utf-8 -*-\\n\\\"\\\"\\\"\\n人工智能专业培养计划生成脚本 v3\\n基于实际可用课程数据，生成合理的 8 学期 AI 专业培养计划。\\n输出：ai_curriculum.txt（制表符分隔）\\n\\\"\\\"\\\"\\n\\nimport os\\nfrom collections import defaultdict\\n\\nDATA_DIR = os.path.join(os.path.dirname(__file__), 'context', 'original_data')\\nSEMESTER_FILES = ['2024-2025-3.txt', '2025-2026-1.txt', '2025-2026-2.txt']\\n\\n# ─────────────────────────────────────────────────────────────\\n# 1.  课程池加载\\n# ─────────────────────────────────────────────────────────────\\n\\ndef load_all_courses():\\n    pool = {}\\n    for fname in SEMESTER_FILES:\\n        fpath = os.path.join(DATA_DIR, fname)\\n        with open(fpath, 'rb') as f:\\n            raw = f.read()\\n        text = raw.decode('gbk', errors='replace')\\n        for i, line in enumerate(text.strip().splitlines()):\\n            if i == 0:\\n                continue\\n            parts = line.strip().split('\\\\t')\\n            if len(parts) < 2:\\n                continue\\n            name = parts[0].strip()\\n            if not name:\\n                continue\\n            try:\\n                hours   = float(parts[1])\\n                credits = float(parts[2]) if len(parts) > 2 else round(hours / 16, 1)\\n            except ValueError:\\n                continue\\n            if name not in pool:\\n                pool[name] = {'name': name, 'hours': int(hours), 'credits': credits}\\n    return pool\\n\\n\\n# ─────────────────────────────────────────────────────────────\\n# 2.  8 学期培养计划（按课程名精确 / 模糊查找）\\n#     格式：(查找关键词, 学期编号, 学期标签, 课程类别)\\n# ─────────────────────────────────────────────────────────────\\n\\nCURRICULUM = [\\n    # ══ Semester 1 ── 大一第一学期 ══════════════════════════════\\n    ('思想道德与法治',              1, '大一第一学期', '思想政治课'),\\n    ('形势与政策',                  1, '大一第一学期', '思想政治课'),\\n    ('高等数学A1',                  1, '大一第一学期', '数学基础课'),\\n    ('线性代数',                    1, '大一第一学期', '数学基础课'),\\n    ('Python基础',                  1, '大一第一学期', '编程与CS基础课'),\\n    ('程序设计基础',                1, '大一第一学期', '编程与CS基础课'),\\n    ('英语听说（1）',               1, '大一第一学期', '外语课'),\\n    ('体育N（1）',                  1, '大一第一学期', '体育课'),\\n    ('军事理论',                    1, '大一第一学期', '军事理论'),\\n\\n    # ══ Semester 2 ── 大一第二学期 ══════════════════════════════\\n    ('马克思主义基本原理',          2, '大一第二学期', '思想政治课'),\\n    ('高等数学A2',                  2, '大一第二学期', '数学基础课'),\\n    ('概率论与数理统计',            2, '大一第二学期', '数学基础课'),\\n    ('离散数学',                    2, '大一第二学期', '数学基础课'),\\n    ('数据结构',                    2, '大一第二学期', '编程与CS基础课'),\\n    ('算法原理',                    2, '大一第二学期', '编程与CS基础课'),\\n    ('英语读写（3）',               2, '大一第二学期', '外语课'),\\n    ('体育N（2）',                  2, '大一第二学期', '体育课'),\\n\\n    # ══ Semester 3 ── 大二第一学期 ══════════════════════════════\\n    ('习近平新时代中国特色社会主义思想概论', 3, '大二第一学期', '思想政治课'),\\n    ('数学分析',                    3, '大二第一学期', '数学基础课'),\\n    ('数值分析',                    3, '大二第一学期', '数学基础课'),\\n    ('最优化方法',                  3, '大二第一学期', '数学基础课'),\\n    ('算法设计与分析',              3, '大二第一学期', '编程与CS基础课'),\\n    ('操作系统',                    3, '大二第一学期', '编程与CS基础课'),\\n    ('计算机网络',                  3, '大二第一学期', '编程与CS基础课'),\\n    ('大学英语（3）',               3, '大二第一学期', '外语课'),\\n    ('体育（3）',                   3, '大二第一学期', '体育课'),\\n\\n    # ══ Semester 4 ── 大二第二学期 ══════════════════════════════\\n    ('毛泽东思想和中国特色社会主义理论体系概论', 4, '大二第二学期', '思想政治课'),\\n    ('数据科学引论',                4, '大二第二学期', '数学基础课'),\\n    ('数据库技术',                  4, '大二第二学期', '编程与CS基础课'),\\n    ('人工智能导论',                4, '大二第二学期', 'AI核心课'),\\n    ('机器学习',                    4, '大二第二学期', 'AI核心课'),\\n    ('多元统计',                    4, '大二第二学期', '数据科学课'),\\n    ('大学英语（4）',               4, '大二第二学期', '外语课'),\\n    ('体育N（4）',                  4, '大二第二学期', '体育课'),\\n\\n    # ══ Semester 5 ── 大三第一学期 ══════════════════════════════\\n    ('神经网络与深度学习',          5, '大三第一学期', 'AI核心课'),\\n    ('深度学习',                    5, '大三第一学期', 'AI核心课'),\\n    ('自然语言处理',                5, '大三第一学期', 'AI核心课'),\\n    ('计算机视觉',                  5, '大三第一学期', 'AI核心课'),\\n    ('语言数据科学',                5, '大三第一学期', '数据科学课'),\\n    ('数据挖掘',                    5, '大三第一学期', '数据科学课'),\\n    ('GPU计算及深度学习',           5, '大三第一学期', '系统与工程课'),\\n    ('高阶通用学术英语',            5, '大三第一学期', '外语课'),\\n\\n    # ══ Semester 6 ── 大三第二学期 ══════════════════════════════\\n    ('强化学习',                    6, '大三第二学期', 'AI核心课'),\\n    ('模式识别',                    6, '大三第二学期', 'AI核心课'),\\n    ('知识图谱',                    6, '大三第二学期', 'AI核心课'),\\n    ('AIGC',                        6, '大三第二学期', 'AI核心课'),\\n    ('AI与数字传播',                6, '大三第二学期', 'AI核心课'),\\n    ('信息安全综合实践',            6, '大三第二学期', '系统与工程课'),\\n    ('密码学与信息安全',            6, '大三第二学期', '系统与工程课'),\\n    ('计算机伦理',                  6, '大三第二学期', '通识与素质课'),\\n\\n    # ══ Semester 7 ── 大四第一学期 ══════════════════════════════\\n    ('人工智能技术与前沿应用',      7, '大四第一学期', 'AI核心课'),\\n    ('大模型',                      7, '大四第一学期', 'AI核心课'),\\n    ('无人驾驶算法开发',            7, '大四第一学期', 'AI核心课'),\\n    ('人工智能基本原理',            7, '大四第一学期', 'AI核心课'),\\n    ('AI for Science',              7, '大四第一学期', 'AI核心课'),\\n    ('人工智能安全技术',            7, '大四第一学期', 'AI核心课'),\\n    ('职业生涯',                    7, '大四第一学期', '通识与素质课'),\\n\\n    # ══ Semester 8 ── 大四第二学期 ══════════════════════════════\\n    ('毕业设计（论文）（计算机）',  8, '大四第二学期', '实践与毕设'),\\n    ('毕业论文',                    8, '大四第二学期', '实践与毕设'),\\n    ('智能感知',                    8, '大四第二学期', 'AI核心课'),\\n    ('创新创业',                    8, '大四第二学期', '通识与素质课'),\\n    ('伦理学',                      8, '大四第二学期', '通识与素质课'),\\n]\\n\\n\\n# ─────────────────────────────────────────────────────────────\\n# 3.  查找函数\\n# ─────────────────────────────────────────────────────────────\\n\\ndef find_course(keyword, pool, used):\\n    \\\"\\\"\\\"\\n    按优先级在 pool 中查找 keyword 对应的课程。\\n    1. 精确匹配\\n    2. keyword ⊂ name（name 包含 keyword）→ 最短 name\\n    3. name ⊂ keyword（keyword 包含 name，name ≥ 3 字）→ 最长 name\\n    \\\"\\\"\\\"\\n    if keyword in pool and keyword not in used:\\n        return keyword\\n\\n    best = None\\n    best_len = 10**6\\n    for name in pool:\\n        if name in used:\\n            continue\\n        if keyword in name:\\n            if len(name) < best_len:\\n                best = name\\n                best_len = len(name)\\n    if best:\\n        return best\\n\\n    best = None\\n    best_len = 0\\n    for name in pool:\\n        if name in used:\\n            continue\\n        if name in keyword and len(name) >= 3:\\n            if len(name) > best_len:\\n                best = name\\n                best_len = len(name)\\n    return best\\n\\n\\n# ─────────────────────────────────────────────────────────────\\n# 4.  主流程\\n# ─────────────────────────────────────────────────────────────\\n\\ndef generate(pool):\\n    used  = set()\\n    rows  = []\\n\\n    for keyword, sem_id, sem_label, category in CURRICULUM:\\n        name = find_course(keyword, pool, used)\\n        if name is None:\\n            print(f'  [MISS] sem{sem_id} | {keyword}')\\n            # 记录占位行，方便校验\\n            rows.append({\\n                'semester_id':    sem_id,\\n                'semester_label': sem_label,\\n                'category':       category,\\n                'course_name':    f'[待定] {keyword}',\\n                'hours':          32,\\n                'credits':        2.0,\\n                'missing':        True,\\n            })\\n            continue\\n        used.add(name)\\n        c = pool[name]\\n        rows.append({\\n            'semester_id':    sem_id,\\n            'semester_label': sem_label,\\n            'category':       category,\\n            'course_name':    name,\\n            'hours':          c['hours'],\\n            'credits':        c['credits'],\\n            'missing':        False,\\n        })\\n\\n    return rows\\n\\n\\n# ─────────────────────────────────────────────────────────────\\n# 5.  输出\\n# ─────────────────────────────────────────────────────────────\\n\\ndef write_output(rows, out_path):\\n    header = ['学期编号', '学期名称', '课程类别', '课程名称', '学时', '学分']\\n    with open(out_path, 'w', encoding='utf-8') as f:\\n        f.write('\\\\t'.join(header) + '\\\\n')\\n        for r in rows:\\n            f.write('\\\\t'.join([\\n                str(r['semester_id']),\\n                r['semester_label'],\\n                r['category'],\\n                r['course_name'],\\n                str(r['hours']),\\n                str(r['credits']),\\n            ]) + '\\\\n')\\n    print(f'[INFO] 培养计划已写入：{out_path}')\\n\\n\\ndef print_summary(rows):\\n    by_sem = defaultdict(list)\\n    for r in rows:\\n        by_sem[r['semester_id']].append(r)\\n\\n    total_cr  = 0.0\\n    miss_count = 0\\n    print('\\\\n' + '='*68)\\n    print('  人工智能专业培养计划（8 学期）— 汇总')\\n    print('='*68)\\n\\n    for sem_id in sorted(by_sem):\\n        items  = by_sem[sem_id]\\n        label  = items[0]['semester_label']\\n        sc     = sum(x['credits'] for x in items)\\n        total_cr += sc\\n        miss   = sum(1 for x in items if x.get('missing'))\\n        miss_count += miss\\n        flag   = f'  ⚠ {miss} 门待定' if miss else ''\\n        print(f'\\\\n【Sem {sem_id}  {label}】  {len(items)} 门 / {sc:.1f} 学分{flag}')\\n        by_cat = defaultdict(list)\\n        for r in items:\\n            by_cat[r['category']].append(r)\\n        for cat, cs in sorted(by_cat.items()):\\n            print(f'  ▌ {cat}')\\n            for c in cs:\\n                mark = ' ⚠' if c.get('missing') else ''\\n                print(f'    {c[\\\"course_name\\\"]:<44} {c[\\\"hours\\\"]:>4}h  {c[\\\"credits\\\"]}分{mark}')\\n\\n    print(f'\\\\n{\\\"=\\\"*68}')\\n    print(f'  合计：{len(rows)} 门课程 / {total_cr:.1f} 学分'\\n          + (f'  （含 {miss_count} 门待定）' if miss_count else ''))\\n    print('='*68)\\n\\n\\n# ─────────────────────────────────────────────────────────────\\n# 6.  入口\\n# ─────────────────────────────────────────────────────────────\\n\\nif __name__ == '__main__':\\n    pool = load_all_courses()\\n    print(f'[INFO] 课程池：{len(pool)} 门课程')\\n\\n    rows = generate(pool)\\n\\n    out = os.path.join(os.path.dirname(__file__), 'ai_curriculum.txt')\\n    write_output(rows, out)\\n    print_summary(rows)\\n\", \"path\": \"/tmp/isolated_workspace_1091/generate_curriculum.py\"}"
