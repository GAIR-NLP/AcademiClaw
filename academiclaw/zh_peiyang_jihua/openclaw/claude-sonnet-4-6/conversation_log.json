    '编程与CS基础课'),\\n            # 外语\\n            ('大学英语（1）',               '外语课'),\\n            # 体育\\n            ('体育（1）',                   '体育课'),\\n            # 军事\\n            ('军事理论',                    '军事理论'),\\n        ],\\n    },\\n\\n    # ── 大一下（Sem 2）──────────────────────────────────────\\n    {\\n        'label': '大一第二学期',\\n        'targets': [\\n            # 思政\\n            ('中国近代史纲要',              '思想政治课'),\\n            # 数学\\n            ('高等数学A2',                  '数学基础课'),\\n            ('概率论与数理统计',            '数学基础课'),\\n            ('离散数学',                    '数学基础课'),\\n            # 编程\\n            ('数据结构',                    '编程与CS基础课'),\\n            ('C语言程序设计',               '编程与CS基础课'),\\n            # 外语\\n            ('大学英语（2）',               '外语课'),\\n            ('大学英语N（1）',              '外语课'),\\n            # 体育\\n            ('体育（2）',                   '体育课'),\\n        ],\\n    },\\n\\n    # ── 大二上（Sem 3）──────────────────────────────────────\\n    {\\n        'label': '大二第一学期',\\n        'targets': [\\n            # 思政\\n            ('马克思主义基本原理',          '思想政治课'),\\n            # 数学\\n            ('数学分析',                    '数学基础课'),\\n            ('数值分析',                    '数学基础课'),\\n            # 编程/CS\\n            ('算法设计与分析',              '编程与CS基础课'),\\n            ('数据库',                      '编程与CS基础课'),\\n            ('操作系统',                    '编程与CS基础课'),\\n            ('计算机网络',                  '编程与CS基础课'),\\n            # 外语\\n            ('大学英语（3）',               '外语课'),\\n            # 体育\\n            ('体育（3）',                   '体育课'),\\n        ],\\n    },\\n\\n    # ── 大二下（Sem 4）──────────────────────────────────────\\n    {\\n        'label': '大二第二学期',\\n        'targets': [\\n            # 思政\\n            ('毛泽东思想和中国特色社会主义理论体系概论', '思想政治课'),\\n            # 数学\\n            ('最优化方法',                  '数学基础课'),\\n            ('矩阵论',                      '数学基础课'),\\n            # AI 入门\\n            ('人工智能导论',                'AI核心课'),\\n            ('机器学习',                    'AI核心课'),\\n            # 数据科学\\n            ('数据科学',                    '数据科学课'),\\n            ('多元统计',                    '数据科学课'),\\n            # 外语\\n            ('大学英语（4）',               '外语课'),\\n            # 体育\\n            ('体育（4）',                   '体育课'),\\n        ],\\n    },\\n\\n    # ── 大三上（Sem 5）──────────────────────────────────────\\n    {\\n        'label': '大三第一学期',\\n        'targets': [\\n            # 思政\\n            ('习近平新时代中国特色社会主义思想概论', '思想政治课'),\\n            # AI 核心\\n            ('神经网络与深度学习',          'AI核心课'),\\n            ('深度学习',                    'AI核心课'),\\n            ('自然语言处理',                'AI核心课'),\\n            ('计算机视觉',                  'AI核心课'),\\n            # 数据科学\\n            ('数据挖掘',                    '数据科学课'),\\n            ('语言数据科学',                '数据科学课'),\\n            # 系统\\n            ('GPU计算及应用',               '系统与工程课'),\\n        ],\\n    },\\n\\n    # ── 大三下（Sem 6）──────────────────────────────────────\\n    {\\n        'label': '大三第二学期',\\n        'targets': [\\n            # AI 核心\\n            ('强化学习',                    'AI核心课'),\\n            ('模式识别',                    'AI核心课'),\\n            ('知识图谱',                    'AI核心课'),\\n            ('AIGC',                        'AI核心课'),\\n            ('AI与数字传播',                'AI核心课'),\\n            # 系统/工程\\n            ('嵌入式系统',                  '系统与工程课'),\\n            ('信息安全',                    '系统与工程课'),\\n            # 通识\\n            ('科技伦理',                    '通识与素质课'),\\n            ('创新创业',                    '通识与素质课'),\\n        ],\\n    },\\n\\n    # ── 大四上（Sem 7）──────────────────────────────────────\\n    {\\n        'label': '大四第一学期',\\n        'targets': [\\n            # AI 进阶\\n            ('人工智能技术与前沿应用',      'AI核心课'),\\n            ('大模型',                      'AI核心课'),\\n            ('无人驾驶算法',                'AI核心课'),\\n            ('人工智能基本原理',            'AI核心课'),\\n            ('AI for Science',              'AI核心课'),\\n            # 数据科学\\n            ('数据科学引论',                '数据科学课'),\\n            # 实践\\n            ('综合实验',                    '实践与毕设'),\\n        ],\\n    },\\n\\n    # ── 大四下（Sem 8）──────────────────────────────────────\\n    {\\n        'label': '大四第二学期',\\n        'targets': [\\n            # 实践\\n            ('专业实习',                    '实践与毕设'),\\n            ('毕业设计',                    '实践与毕设'),\\n            ('毕业论文',                    '实践与毕设'),\\n            # AI 前沿选修\\n            ('AI安全',                      'AI核心课'),\\n            ('智能感知',                    'AI核心课'),\\n        ],\\n    },\\n]\\n\\n# ─────────────────────────── 匹配逻辑 ───────────────────────────\\n\\ndef find_course(keyword, pool, used, cat_filter=None):\\n    \\\"\\\"\\\"\\n    按优先级查找课程：\\n    1. keyword 完全等于 name\\n    2. keyword in name（name包含关键词）\\n    3. name in keyword（关键词包含 name，name至少3字）\\n    如果 cat_filter 不为 None，强制匹配类别。\\n    \\\"\\\"\\\"\\n    def ok_cat(name):\\n        if cat_filter is None:\\n            return True\\n        return categorize(name) == cat_filter\\n\\n    # 精确\\n    if keyword in pool and keyword not in used and ok_cat(keyword):\\n        return keyword\\n    # 包含（keyword in name）\\n    best = None\\n    best_len = 9999\\n    for name in pool:\\n        if name in used:\\n            continue\\n        if keyword in name and ok_cat(name):\\n            if len(name) < best_len:\\n                best = name\\n                best_len = len(name)\\n    if best:\\n        return best\\n    # 包含（name in keyword，name≥3字）\\n    best = None\\n    best_len = 0\\n    for name in pool:\\n        if name in used:\\n            continue\\n        if name in keyword and len(name) >= 3 and ok_cat(name):\\n            if len(name) > best_len:\\n                best = name\\n                best_len = len(name)\\n    return best\\n\\n# ─────────────────────────── 主流程 ─────────────────────────────\\n\\ndef generate():\\n    pool = load_all_courses()\\n    print(f'[INFO] 课程池共 {len(pool)} 门')\\n\\n    used = set()\\n    all_rows = []\\n\\n    for sem_id, sem in enumerate(PLAN, start=1):\\n        label = sem['label']\\n        sem_rows = []\\n\\n        for keyword, category in sem['targets']:\\n            # 先按类别严格匹配，再放宽\\n            name = find_course(keyword, pool, used, cat_filter=category)\\n            if name is None:\\n                name = find_course(keyword, pool, used, cat_filter=None)\\n            if name is None:\\n                print(f'  [WARN] 未找到课程: {keyword}（{category}）')\\n                continue\\n            c = pool[name]\\n            used.add(name)\\n            sem_rows.append({\\n                'semester_id':    sem_id,\\n                'semester_label': label,\\n                'category':       category,\\n                'course_name':    name,\\n                'hours':          c['hours'],\\n                'credits':        c['credits'],\\n            })\\n\\n        sem_cr = sum(r['credits'] for r in sem_rows)\\n        print(f'[INFO] {label}：{len(sem_rows)} 门课 / {sem_cr:.1f} 学分')\\n        all_rows.extend(sem_rows)\\n\\n    return all_rows\\n\\n# ─────────────────────────── 输出 ───────────────────────────────\\n\\ndef write_output(rows, out_path):\\n    header = ['学期编号', '学期名称', '课程类别', '课程名称', '学时', '学分']\\n    with open(out_path, 'w', encoding='utf-8') as f:\\n        f.write('\\\\t'.join(header) + '\\\\n')\\n        for r in rows:\\n            line = '\\\\t'.join([\\n                str(r['semester_id']),\\n                r['semester_label'],\\n                r['category'],\\n                r['course_name'],\\n                str(r['hours']),\\n                str(r['credits']),\\n            ])\\n            f.write(line + '\\\\n')\\n    print(f'[INFO] 已写入：{out_path}')\\n\\ndef print_summary(rows):\\n    by_sem = defaultdict(list)\\n    for r in rows:\\n        by_sem[r['semester_id']].append(r)\\n\\n    total_cr = 0.0\\n    print('\\\\n' + '='*65)\\n    print('  人工智能专业培养计划（8学期）— 详细汇总')\\n    print('='*65)\\n\\n    for sem_id in sorted(by_sem):\\n        items = by_sem[sem_id]\\n        label = items[0]['semester_label']\\n        sc = sum(x['credits'] for x in items)\\n        total_cr += sc\\n        print(f'\\\\n【Sem {sem_id}  {label}】  {len(items)} 门 / {sc:.1f} 学分')\\n        by_cat = defaultdict(list)\\n        for r in items:\\n            by_cat[r['category']].append(r)\\n        for cat, cs in by_cat.items():\\n            print(f'  ▌ {cat}')\\n            for c in cs:\\n                print(f'    {c[\\\"course_name\\\"]:<42} {c[\\\"hours\\\"]:>4}h  {c[\\\"credits\\\"]}分')\\n\\n    print(f'\\\\n{\\\"=\\\"*65}')\\n    print(f'  合计：{len(rows)} 门课程 / {total_cr:.1f} 学分')\\n    print('='*65)\\n\\n# ─────────────────────────── 入口 ───────────────────────────────\\n\\nif __name__ == '__main__':\\n    rows = generate()\\n    out  = os.path.join(os.path.dirname(__file__), 'ai_curriculum.txt')\\n    write_output(rows, out)\\n    print_summary(rows)\\n\", \"path\": \"/tmp/isolated_workspace_1091/generate_curriculum.py\"}"
