                "arguments": "{\"content\": \"#!/usr/bin/env python3\\n# -*- coding: utf-8 -*-\\n\\\"\\\"\\\"\\nvalidate_curriculum.py\\n对 ai_curriculum.txt 进行 rubric 校验，输出详细报告。\\n\\n检查项：\\n1. 文件格式（制表符分隔、6 列）\\n2. 学期覆盖完整性（1-8 学期）\\n3. 每学期学分合理区间\\n4. 全程总学分\\n5. 思政课、体育课、外语课最低要求\\n6. AI 核心课程数量\\n7. 数学基础课数量\\n8. 编程/CS 基础课数量\\n9. 实践/毕设环节\\n10. 先修关系简要检查（数学 → AI 基础 → AI 进阶）\\n\\\"\\\"\\\"\\n\\nimport os\\nimport sys\\nfrom collections import defaultdict\\n\\nINPUT_FILE = os.path.join(os.path.dirname(__file__), 'ai_curriculum.txt')\\n\\n# ─────────────────────────────────────────────────────────────\\n# Rubric 参数\\n# ─────────────────────────────────────────────────────────────\\n\\nRUBRIC = {\\n    # (最小学期学分, 最大学期学分)\\n    'sem_credits_range':     (12, 32),\\n    # 全程总学分\\n    'total_credits_min':     140,\\n    'total_credits_max':     200,\\n    # 各类别最低课程数\\n    'min_courses': {\\n        '思想政治课':       4,\\n        '体育课':           3,\\n        '外语课':           3,\\n        'AI核心课':         8,\\n        '数学基础课':       5,\\n        '编程与CS基础课':   4,\\n        '实践与毕设':       1,\\n    },\\n    # 最低总课程数\\n    'total_courses_min': 45,\\n    # 先修关系: (先修课关键词列表, 后修课关键词列表, 说明)\\n    'prereqs': [\\n        (['高等数学', '数学分析'],\\n         ['概率论', '数值分析', '最优化'],\\n         '微积分 → 概率/数值/优化'),\\n        (['数据结构', '算法原理'],\\n         ['算法设计与分析'],\\n         '基础算法 → 进阶算法'),\\n        (['机器学习', '人工智能导论'],\\n         ['深度学习', '神经网络'],\\n         'AI基础 → 深度学习'),\\n        (['深度学习', '神经网络'],\\n         ['强化学习', '大模型', '无人驾驶'],\\n         '深度学习 → AI进阶'),\\n    ],\\n}\\n\\n# ─────────────────────────────────────────────────────────────\\n# 加载\\n# ─────────────────────────────────────────────────────────────\\n\\ndef load(path):\\n    rows = []\\n    with open(path, encoding='utf-8') as f:\\n        for i, line in enumerate(f):\\n            line = line.rstrip('\\\\n')\\n            if i == 0:   # header\\n                continue\\n            parts = line.split('\\\\t')\\n            if len(parts) != 6:\\n                print(f'  [FORMAT ERR] 第 {i+1} 行列数={len(parts)}: {line!r}')\\n                continue\\n            sem_id, sem_label, category, name, hours, credits = parts\\n            try:\\n                rows.append({\\n                    'semester_id':    int(sem_id),\\n                    'semester_label': sem_label,\\n                    'category':       category,\\n                    'course_name':    name,\\n                    'hours':          float(hours),\\n                    'credits':        float(credits),\\n                })\\n            except ValueError as e:\\n                print(f'  [PARSE ERR] 第 {i+1} 行: {e}')\\n    return rows\\n\\n\\n# ─────────────────────────────────────────────────────────────\\n# 校验逻辑\\n# ─────────────────────────────────────────────────────────────\\n\\nclass Checker:\\n    def __init__(self, rows):\\n        self.rows    = rows\\n        self.passed  = 0\\n        self.failed  = 0\\n        self.warns   = 0\\n        self.results = []\\n\\n    def check(self, name, ok, detail='', warn=False):\\n        status = '✅ PASS' if ok else ('⚠ WARN' if warn else '❌ FAIL')\\n        if ok:\\n            self.passed += 1\\n        elif warn:\\n            self.warns += 1\\n        else:\\n            self.failed += 1\\n        self.results.append(f'  {status}  {name}' + (f'\\\\n         → {detail}' if detail else ''))\\n\\n    def run(self):\\n        rows   = self.rows\\n        r      = RUBRIC\\n\\n        # ── 1. 文件格式 ─────────────────────────────────────\\n        self.check('文件格式（6列）', len(rows) > 0, f'共 {len(rows)} 行数据')\\n\\n        # ── 2. 学期覆盖 ─────────────────────────────────────\\n        sems = sorted(set(x['semester_id'] for x in rows))\\n        expected = list(range(1, 9))\\n        ok = sems == expected\\n        self.check('学期完整覆盖 1-8 学期', ok,\\n                   f'实际学期：{sems}' if not ok else f'覆盖 {sems}')\\n\\n        # ── 3. 每学期学分 ────────────────────────────────────\\n        by_sem = defaultdict(list)\\n        for x in rows:\\n            by_sem[x['semester_id']].append(x)\\n\\n        lo, hi = r['sem_credits_range']\\n        sem_ok = True\\n        sem_details = []\\n        for sid in range(1, 9):\\n            sc = sum(x['credits'] for x in by_sem[sid])\\n            ok_s = lo <= sc <= hi\\n            if not ok_s:\\n                sem_ok = False\\n            sem_details.append(f'Sem{sid}={sc:.1f}')\\n        self.check(f'每学期学分在 [{lo}, {hi}] 内', sem_ok,\\n                   '  '.join(sem_details))\\n\\n        # ── 4. 总学分 ────────────────────────────────────────\\n        total_cr = sum(x['credits'] for x in rows)\\n        ok = r['total_credits_min'] <= total_cr <= r['total_credits_max']\\n        self.check(f'总学分 [{r[\\\"total_credits_min\\\"]}, {r[\\\"total_credits_max\\\"]}]',\\n                   ok, f'实际 {total_cr:.1f} 学分')\\n\\n        # ── 5. 总课程数 ──────────────────────────────────────\\n        ok = len(rows) >= r['total_courses_min']\\n        self.check(f'总课程数 ≥ {r[\\\"total_courses_min\\\"]}',\\n                   ok, f'实际 {len(rows)} 门')\\n\\n        # ── 6. 各类别最低要求 ────────────────────────────────\\n        by_cat = defaultdict(list)\\n        for x in rows:\\n            by_cat[x['category']].append(x)\\n\\n        for cat, min_n in r['min_courses'].items():\\n            n  = len(by_cat.get(cat, []))\\n            ok = n >= min_n\\n            self.check(f'{cat} ≥ {min_n} 门', ok,\\n                       f'实际 {n} 门：' + '、'.join(x['course_name'] for x in by_cat.get(cat, [])[:5]))\\n\\n        # ── 7. 先修关系 ──────────────────────────────────────\\n        # 找每门课最早出现的学期\\n        earliest = {}\\n        for x in rows:\\n            n = x['course_name']\\n            if n not in earliest or x['semester_id'] < earliest[n]:\\n                earliest[n] = x['semester_id']\\n\\n        def sem_of_kw(kw):\\n            \\\"\\\"\\\"返回包含 kw 的课程最早出现学期，未找到则 None\\\"\\\"\\\"\\n            for name, sid in earliest.items():\\n                if kw in name:\\n                    return sid\\n            return None\\n\\n        for pre_kws, post_kws, desc in r['prereqs']:\\n            pre_sems  = [s for kw in pre_kws  if (s := sem_of_kw(kw)) is not None]\\n            post_sems = [s for kw in post_kws if (s := sem_of_kw(kw)) is not None]\\n            if not pre_sems or not post_sems:\\n                self.check(f'先修关系: {desc}', True,\\n                           '（未检测到相关课程，跳过）', warn=True)\\n                continue\\n            pre_max  = max(pre_sems)\\n            post_min = min(post_sems)\\n            ok = pre_max <= post_min\\n            self.check(f'先修关系: {desc}', ok,\\n                       f'先修最迟=Sem{pre_max}, 后修最早=Sem{post_min}')\\n\\n        # ── 打印 ─────────────────────────────────────────────\\n        print('\\\\n' + '─'*65)\\n        print('  培养计划 Rubric 校验报告')\\n        print('─'*65)\\n        for r_line in self.results:\\n            print(r_line)\\n        print('─'*65)\\n        print(f'  总计：{self.passed} 通过 / {self.warns} 警告 / {self.failed} 失败')\\n        print('─'*65)\\n\\n        return self.failed == 0\\n\\n\\n# ─────────────────────────────────────────────────────────────\\n# 入口\\n# ─────────────────────────────────────────────────────────────\\n\\nif __name__ == '__main__':\\n    if not os.path.exists(INPUT_FILE):\\n        print(f'[ERROR] 文件不存在：{INPUT_FILE}')\\n        sys.exit(1)\\n\\n    print(f'[INFO] 加载：{INPUT_FILE}')\\n    rows = load(INPUT_FILE)\\n    print(f'[INFO] 共 {len(rows)} 条课程记录')\\n\\n    checker = Checker(rows)\\n    ok = checker.run()\\n    sys.exit(0 if ok else 1)\\n\", \"path\": \"/tmp/isolated_workspace_1091/validate_curriculum.py\"}"
