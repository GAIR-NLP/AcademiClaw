", 48, 3, \\\"专业核心\\\", \\\"必修\\\"),\\n        course(\\\"自然语言处理\\\", 48, 3, \\\"专业核心\\\", \\\"必修\\\"),\\n        course(\\\"计算机视觉\\\", 32, 2, \\\"专业核心\\\", \\\"选修\\\"),\\n        course(\\\"强化学习\\\", 32, 2, \\\"专业核心\\\", \\\"选修\\\"),\\n        course(\\\"人工智能安全技术\\\", 32, 2, \\\"专业方向\\\", \\\"选修\\\"),\\n        course(\\\"计算机图形学\\\", 48, 3, \\\"专业方向\\\", \\\"选修\\\"),\\n        course(\\\"数据挖掘\\\", 32, 2, \\\"专业方向\\\", \\\"选修\\\"),\\n    ]\\n\\n    # ========== 第三学年 第二学期 ==========\\n    plan[\\\"第6学期（大三春）\\\"] = [\\n        course(\\\"人工智能基本原理与工程实践III（形式语言、自然语言、语音技术）\\\", 80, 5, \\\"专业核心\\\", \\\"必修\\\"),\\n        course(\\\"深度学习及应用\\\", 48, 3, \\\"专业核心\\\", \\\"选修\\\"),\\n        course(\\\"计算机视觉基础与应用\\\", 48, 3, \\\"专业方向\\\", \\\"选修\\\"),\\n        course(\\\"人工智能伦理\\\", 48, 3, \\\"专业方向\\\", \\\"必修\\\"),\\n        course(\\\"智能语音技术\\\", 48, 3, \\\"专业方向\\\", \\\"选修\\\"),\\n        course(\\\"人工智能算法\\\", 48, 3, \\\"专业核心\\\", \\\"选修\\\"),\\n        course(\\\"数据可视化与可视分析\\\", 48, 3, \\\"专业方向\\\", \\\"选修\\\"),\\n    ]\\n\\n    # ========== 第四学年 第一学期 ==========\\n    plan[\\\"第7学期（大四秋）\\\"] = [\\n        course(\\\"人工智能前沿讲座\\\", 32, 2, \\\"专业方向\\\", \\\"选修\\\"),\\n        course(\\\"人工智能进阶\\\", 64, 4, \\\"专业核心\\\", \\\"选修\\\"),\\n        course(\\\"模式识别导论\\\", 32, 2, \\\"专业方向\\\", \\\"选修\\\"),\\n        course(\\\"人工智能治理：技术、法律与政策\\\", 32, 2, \\\"专业方向\\\", \\\"选修\\\"),\\n        course(\\\"软件工程\\\", 48, 3, \\\"专业基础\\\", \\\"选修\\\"),\\n        course(\\\"计算机体系结构\\\", 48, 3, \\\"专业基础\\\", \\\"选修\\\"),\\n        course(\\\"专业实践1\\\", 32, 2, \\\"专业实践\\\", \\\"必修\\\"),\\n    ]\\n\\n    # ========== 第四学年 第二学期 ==========\\n    plan[\\\"第8学期（大四春）\\\"] = [\\n        course(\\\"毕业设计（论文）（计算机科学 ）（A类）\\\", 128, 8, \\\"毕业环节\\\", \\\"必修\\\"),\\n        course(\\\"专业实践2\\\", 32, 2, \\\"专业实践\\\", \\\"必修\\\"),\\n    ]\\n\\n    return plan\\n\\n\\n# ============================================================\\n# 3. 校验与统计\\n# ============================================================\\ndef validate_plan(plan):\\n    \\\"\\\"\\\"校验培养计划：学分分布、总学分等\\\"\\\"\\\"\\n    stats = {\\n        \\\"total_credits\\\": 0,\\n        \\\"total_hours\\\": 0,\\n        \\\"semester_credits\\\": {},\\n        \\\"category_credits\\\": {},\\n        \\\"nature_credits\\\": {\\\"必修\\\": 0, \\\"选修\\\": 0},\\n    }\\n\\n    for sem, courses in plan.items():\\n        sem_cr = 0\\n        sem_hr = 0\\n        for name, hours, credits, category, nature in courses:\\n            stats[\\\"total_credits\\\"] += credits\\n            stats[\\\"total_hours\\\"] += hours\\n            sem_cr += credits\\n            sem_hr += hours\\n            stats[\\\"category_credits\\\"][category] = stats[\\\"category_credits\\\"].get(category, 0) + credits\\n            stats[\\\"nature_credits\\\"][nature] += credits\\n        stats[\\\"semester_credits\\\"][sem] = (sem_cr, sem_hr)\\n\\n    return stats\\n\\n\\n# ============================================================\\n# 4. 输出\\n# ============================================================\\ndef export_plan(plan, stats, output_path=\\\"ai_training_plan.txt\\\"):\\n    \\\"\\\"\\\"导出制表符分隔的培养计划文件\\\"\\\"\\\"\\n    lines = []\\n\\n    # 标题\\n    lines.append(\\\"人工智能专业本科培养计划\\\")\\n    lines.append(\\\"=\\\" * 60)\\n    lines.append(\\\"\\\")\\n\\n    # 表头\\n    header = \\\"\\\\t\\\".join([\\\"学期\\\", \\\"课程名称\\\", \\\"学时\\\", \\\"学分\\\", \\\"课程类别\\\", \\\"课程性质\\\"])\\n    lines.append(header)\\n\\n    for sem, courses in plan.items():\\n        for name, hours, credits, category, nature in courses:\\n            row = \\\"\\\\t\\\".join([\\n                sem,\\n                name,\\n                str(int(hours)),\\n                str(credits),\\n                category,\\n                nature\\n            ])\\n            lines.append(row)\\n\\n    lines.append(\\\"\\\")\\n    lines.append(\\\"=\\\" * 60)\\n    lines.append(\\\"统计信息\\\")\\n    lines.append(\\\"=\\\" * 60)\\n    lines.append(\\\"\\\")\\n\\n    # 学期统计\\n    lines.append(\\\"学期\\\\t学分小计\\\\t学时小计\\\")\\n    for sem, (cr, hr) in stats[\\\"semester_credits\\\"].items():\\n        lines.append(f\\\"{sem}\\\\t{cr}\\\\t{hr}\\\")\\n\\n    lines.append(\\\"\\\")\\n    lines.append(f\\\"总学分\\\\t{stats['total_credits']}\\\")\\n    lines.append(f\\\"总学时\\\\t{stats['total_hours']}\\\")\\n\\n    lines.append(\\\"\\\")\\n    lines.append(\\\"课程类别\\\\t学分\\\")\\n    for cat, cr in sorted(stats[\\\"category_credits\\\"].items()):\\n        lines.append(f\\\"{cat}\\\\t{cr}\\\")\\n\\n    lines.append(\\\"\\\")\\n    lines.append(\\\"课程性质\\\\t学分\\\")\\n    for nat, cr in sorted(stats[\\\"nature_credits\\\"].items()):\\n        lines.append(f\\\"{nat}\\\\t{cr}\\\")\\n\\n    with open(output_path, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n        f.write(\\\"\\\\n\\\".join(lines) + \\\"\\\\n\\\")\\n\\n    return lines\\n\\n\\n# ============================================================\\n# 主函数\\n# ============================================================\\ndef main():\\n    print(\\\"=\\\" * 60)\\n    print(\\\"人工智能专业培养计划生成器\\\")\\n    print(\\\"=\\\" * 60)\\n\\n    # 1. 读取课程数据\\n    print(\\\"\\\\n[1] 读取课程数据...\\\")\\n    available = read_courses()\\n    print(f\\\"    共读取 {len(available)} 门唯一课程\\\")\\n\\n    # 2. 构建培养计划\\n    print(\\\"\\\\n[2] 构建培养计划...\\\")\\n    plan = build_curriculum(available)\\n    total_courses = sum(len(v) for v in plan.values())\\n    print(f\\\"    共安排 {total_courses} 门课程，分布在 {len(plan)} 个学期\\\")\\n\\n    # 3. 校验\\n    print(\\\"\\\\n[3] 校验计划...\\\")\\n    stats = validate_plan(plan)\\n\\n    print(f\\\"\\\\n    总学分: {stats['total_credits']}\\\")\\n    print(f\\\"    总学时: {stats['total_hours']}\\\")\\n    print(\\\"\\\\n    各学期学分分布:\\\")\\n    for sem, (cr, hr) in stats[\\\"semester_credits\\\"].items():\\n        print(f\\\"      {sem}: {cr} 学分 / {hr} 学时\\\")\\n\\n    print(\\\"\\\\n    按类别统计:\\\")\\n    for cat, cr in sorted(stats[\\\"category_credits\\\"].items()):\\n        print(f\\\"      {cat}: 