d(f\\\"{sem} 学分过多: {cr}\\\")\\n\\n    # 3. 课程类别覆盖\\n    categories = set(c[\\\"category\\\"] for c in courses)\\n    required_cats = {\\\"思政通识\\\", \\\"数学基础\\\", \\\"专业核心\\\", \\\"专业基础\\\"}\\n    missing = required_cats - categories\\n    if missing:\\n        errors.append(f\\\"缺少课程类别: {missing}\\\")\\n    else:\\n        print(f\\\"\\\\n✓ 课程类别完整: {sorted(categories)}\\\")\\n\\n    # 4. 思政课检查 (至少 4 门)\\n    politics = [c for c in courses if c[\\\"category\\\"] == \\\"思政通识\\\"]\\n    if len(politics) < 4:\\n        warnings.append(f\\\"思政课偏少: {len(politics)} 门\\\")\\n    else:\\n        print(f\\\"✓ 思政课: {len(politics)} 门\\\")\\n\\n    # 5. AI核心课检查\\n    ai_core = [c for c in courses if \\\"人工智能\\\" in c[\\\"name\\\"] or \\\"机器学习\\\" in c[\\\"name\\\"] \\n               or \\\"深度学习\\\" in c[\\\"name\\\"] or \\\"神经网络\\\" in c[\\\"name\\\"]]\\n    if len(ai_core) < 5:\\n        warnings.append(f\\\"AI核心课偏少: {len(ai_core)} 门\\\")\\n    else:\\n        print(f\\\"✓ AI核心课: {len(ai_core)} 门\\\")\\n        for c in ai_core:\\n            print(f\\\"    - {c['name']} ({c['credits']}学分)\\\")\\n\\n    # 6. 毕业环节\\n    grad = [c for c in courses if \\\"毕业\\\" in c[\\\"name\\\"]]\\n    if not grad:\\n        errors.append(\\\"缺少毕业设计/论文\\\")\\n    else:\\n        print(f\\\"✓ 毕业环节: {grad[0]['name']} ({grad[0]['credits']}学分)\\\")\\n\\n    # 7. 实践环节\\n    practice = [c for c in courses if c[\\\"category\\\"] in (\\\"专业实践\\\", \\\"毕业环节\\\")]\\n    prac_cr = sum(c[\\\"credits\\\"] for c in practice)\\n    print(f\\\"✓ 实践环节: {len(practice)} 门, {prac_cr} 学分\\\")\\n\\n    # 8. 必修/选修比例\\n    req_cr = sum(c[\\\"credits\\\"] for c in courses if c[\\\"nature\\\"] == \\\"必修\\\")\\n    elec_cr = sum(c[\\\"credits\\\"] for c in courses if c[\\\"nature\\\"] == \\\"选修\\\")\\n    ratio = req_cr / total_cr if total_cr > 0 else 0\\n    print(f\\\"✓ 必修/选修: {req_cr}/{elec_cr} (必修占比 {ratio:.1%})\\\")\\n\\n    # 9. 先修关系粗检 (简单逻辑检查)\\n    sem_order = {}\\n    for c in courses:\\n        sem_order[c[\\\"name\\\"]] = c[\\\"semester\\\"]\\n    \\n    prereq_checks = [\\n        (\\\"数据结构\\\", \\\"算法设计与分析\\\"),\\n        (\\\"离散数学\\\", \\\"算法设计与分析\\\"),\\n    ]\\n    for prereq, course_name in prereq_checks:\\n        if prereq in sem_order and course_name in sem_order:\\n            # Compare semester numbers\\n            pre_num = int(sem_order[prereq][1])\\n            cur_num = int(sem_order[course_name][1])\\n            if pre_num >= cur_num:\\n                warnings.append(f\\\"先修关系警告: {prereq}(学期{pre_num}) 应在 {course_name}(学期{cur_num}) 之前\\\")\\n\\n    print(\\\"\\\\n\\\" + \\\"=\\\" * 50)\\n    if errors:\\n        print(f\\\"❌ {len(errors)} 个错误:\\\")\\n        for e in errors:\\n            print(f\\\"   - {e}\\\")\\n    if warnings:\\n        print(f\\\"⚠ {len(warnings)} 个警告:\\\")\\n        for w in warnings:\\n            print(f\\\"   - {w}\\\")\\n    if not errors and not warnings:\\n        print(\\\"✅ 所有校验通过！\\\")\\n    elif not errors:\\n        print(\\\"✅ 无严重错误，仅有轻微警告\\\")\\n\\n    return len(errors) == 0\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    validate()\\n\", \"path\": \"/tmp/isolated_workspace_1091/validate_plan.py\"}"
