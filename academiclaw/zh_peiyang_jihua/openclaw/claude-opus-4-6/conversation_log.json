                  "arguments": "{\"path\": \"/tmp/isolated_workspace_1091/generate_plan.py\", \"content\": \"#!/usr/bin/env python3\\n\\\"\\\"\\\"\\n人工智能专业培养计划生成脚本\\n从上海交通大学课程数据中筛选并排程，生成4年8学期培养计划。\\n\\n参考：上海交通大学人工智能专业本科培养方案\\n输入：context/original_data/ 中的三个学期课程数据\\n输出：ai_training_plan.txt（制表符分隔）\\n\\\"\\\"\\\"\\n\\nimport os\\nfrom collections import OrderedDict\\n\\n# ============================================================\\n# 1. 读取所有课程数据\\n# ============================================================\\ndef read_courses(data_dir=\\\"context/original_data\\\"):\\n    \\\"\\\"\\\"读取所有课程文件，返回 {课程名: {学时, 学分, 学期列表}}\\\"\\\"\\\"\\n    courses = {}\\n    files = [\\n        (\\\"2024-2025-3.txt\\\", \\\"2024-2025暑期\\\"),\\n        (\\\"2025-2026-1.txt\\\", \\\"2025-2026第一学期\\\"),\\n        (\\\"2025-2026-2.txt\\\", \\\"2025-2026第二学期\\\"),\\n    ]\\n    for fname, sem_label in files:\\n        path = os.path.join(data_dir, fname)\\n        with open(path, \\\"rb\\\") as f:\\n            data = f.read()\\n        text = data.decode(\\\"gbk\\\", errors=\\\"replace\\\")\\n        for line in text.strip().split(\\\"\\\\n\\\")[1:]:  # skip header\\n            parts = line.strip().split(\\\"\\\\t\\\")\\n            if len(parts) >= 3:\\n                name = parts[0].strip()\\n                hours = parts[1].strip()\\n                credits = parts[2].strip()\\n                if name:\\n                    try:\\n                        cr = float(credits)\\n                        hr = int(hours)\\n                    except ValueError:\\n                        continue\\n                    if name not in courses:\\n                        courses[name] = {\\n                            \\\"hours\\\": hr,\\n                            \\\"credits\\\": cr,\\n                            \\\"semesters_available\\\": []\\n                        }\\n                    courses[name][\\\"semesters_available\\\"].append(sem_label)\\n    return courses\\n\\n# ============================================================\\n# 2. 定义培养计划课程体系\\n# ============================================================\\n# 基于上海交通大学人工智能专业典型培养方案设计\\n# 课程分类：\\n#   必修-思政通识、必修-数学基础、必修-物理基础、\\n#   必修-专业核心、必修-实践环节、\\n#   选修-专业方向、选修-通识\\n\\ndef build_curriculum(available_courses):\\n    \\\"\\\"\\\"\\n    构建4年8学期课程计划。\\n    每门课程格式: (课程名, 学时, 学分, 课程类别, 课程性质)\\n    \\\"\\\"\\\"\\n\\n    # ---- 辅助函数：查找可用课程 ----\\n    def find(name):\\n        \\\"\\\"\\\"在可用课程库中查找，返回 (name, hours, credits) 或 None\\\"\\\"\\\"\\n        if name in available_courses:\\n            c = available_courses[name]\\n            return (name, c[\\\"hours\\\"], c[\\\"credits\\\"])\\n        # 模糊匹配\\n        for k, v in available_courses.items():\\n            if name in k or k in name:\\n                return (k, v[\\\"hours\\\"], v[\\\"credits\\\"])\\n        return None\\n\\n    def course(name, hours, credits, category, nature):\\n        \\\"\\\"\\\"创建课程记录，优先从课程库获取学时学分\\\"\\\"\\\"\\n        found = find(name)\\n        if found:\\n            return (found[0], found[1], found[2], category, nature)\\n        return (name, hours, credits, category, nature)\\n\\n    plan = OrderedDict()\\n\\n    # ========== 第一学年 第一学期 ==========\\n    plan[\\\"第1学期（大一秋）\\\"] = [\\n        course(\\\"思想道德与法治\\\", 48, 3, \\\"思政通识\\\", \\\"必修\\\"),\\n        course(\\\"高等数学I\\\", 96, 6, \\\"数学基础\\\", \\\"必修\\\"),\\n        course(\\\"线性代数\\\", 48, 3, \\\"数学基础\\\", \\\"必修\\\"),\\n        course(\\\"程序设计思想与方法（C++）\\\", 80, 4, \\\"专业基础\\\", \\\"必修\\\"),\\n        course(\\\"大学英语（3）\\\", 48, 3, \\\"通识教育\\\", \\\"必修\\\"),\\n        course(\\\"大学物理(A类）（1）\\\", 64, 4, \\\"物理基础\\\", \\\"必修\\\"),\\n        course(\\\"体育（3）\\\", 32, 1, \\\"通识教育\\\", \\\"必修\\\"),\\n    ]\\n\\n    # ========== 第一学年 第二学期 ==========\\n    plan[\\\"第2学期（大一春）\\\"] = [\\n        course(\\\"中国近现代史纲要\\\", 48, 3, \\\"思政通识\\\", \\\"必修\\\"),\\n        course(\\\"高等数学II\\\", 64, 4, \\\"数学基础\\\", \\\"必修\\\"),\\n        course(\\\"概率统计\\\", 48, 3, \