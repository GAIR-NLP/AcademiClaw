\\n    ]),\\n    ('第8学期', []),\\n]\\n\\n\\nPREREQ = {\\n    '高等数学（N）II': ['高等数学（N）I'],\\n    '概率统计': ['高等数学（N）I'],\\n    '程序设计与数据结构Ⅱ': ['程序设计基础（荣誉）'],\\n    'Python程序设计': ['程序设计基础（荣誉）'],\\n    '数据结构': ['程序设计基础（荣誉）'],\\n    '算法设计与分析': ['数据结构'],\\n    '数据库原理': ['程序设计基础（荣誉）'],\\n    '人工智能导论': ['高等数学（N）I', '程序设计基础（荣誉）'],\\n    '机器学习': ['概率统计', '线性代数与双重线性代数Ⅰ', '人工智能导论'],\\n    '数据挖掘': ['数据库原理', '概率统计'],\\n    '神经网络与深度学习': ['机器学习'],\\n    '计算机视觉': ['机器学习'],\\n    '数字图像处理': ['人工智能导论'],\\n    '数字信号与图像处理': ['数字图像处理'],\\n    '移动机器人自主定位导航算法实践': ['机器学习'],\\n    '无人驾驶算法开发': ['机器学习', '计算机视觉'],\\n    '人工智能海洋学': ['机器学习'],\\n    '脑机接口理论与实训': ['机器学习'],\\n    '实验室实践（1）': ['人工智能导论'],\\n    '工程实践': ['操作系统', '计算机网络', '软件工程'],\\n    '编程综合实践': ['数据结构', '算法设计与分析'],\\n    '本科生科研项目': ['机器学习'],\\n    '创新创业实践': ['软件工程'],\\n}\\n\\n\\ndef choose_course(name: str, catalog: Dict[str, List[Course]]) -> Course:\\n    candidates = catalog.get(name)\\n    if not candidates:\\n        raise KeyError(f'课程不存在: {name}')\\n    # 优先较新学期；若同名多条，取学分更高者\\n    candidates = sorted(candidates, key=lambda c: (c.source_term, c.credits, c.hours))\\n    return candidates[-1]\\n\\n\\n\\ndef build_plan(catalog: Dict[str, List[Course]]) -> List[dict]:\\n    rows: List[dict] = []\\n    for semester_no, (semester_name, names) in enumerate(SEMESTER_PLAN, start=1):\\n        for order, name in enumerate(names, start=1):\\n            c = choose_course(name, catalog)\\n            rows.append({\\n                'semester_no': semester_no,\\n                'semester': semester_name,\\n                'order': order,\\n                'course_name': c.name,\\n                'hours': f'{c.hours:g}',\\n                'credits': f'{c.credits:g}',\\n                'category': COURSE_CATEGORY.get(c.name, '其他'),\\n                'source_term': c.source_term,\\n            })\\n    return rows\\n\\n\\n\\ndef validate(rows: List[dict]) -> dict:\\n    issues = []\\n    sem_credits: Dict[int, float] = defaultdict(float)\\n    taken_sem: Dict[str, int] = {}\\n    cat_credits: Dict[str, float] = defaultdict(float)\\n    total_credits = 0.0\\n\\n    for row in rows:\\n        sem = row['semester_no']\\n        credits = float(row['credits'])\\n        sem_credits[sem] += credits\\n        total_credits += credits\\n        taken_sem[row['course_name']] = sem\\n        cat_credits[row['category']] += credits\\n\\n    for row in rows:\\n        course = row['course_name']\\n        sem = row['semester_no']\\n        for pre in PREREQ.get(course, []):\\n            if pre not in taken_sem:\\n                issues.append(f'{course} 缺少先修课 {pre}')\\n            elif taken_sem[pre] >= sem:\\n                issues.append(f'{course} 与先修课 {pre} 排程冲突')\\n\\n    # 每学期学分尽量落在 8~25；最后一学期可为空\\n    for sem in range(1, 9):\\n        credits = sem_credits.get(sem, 0.0)\\n        if sem < 8 and not (8 <= credits <= 25):\\n            issues.append(f'第{sem}学期学分 {credits:g} 不在建议区间 8~25')\\n        if sem == 8 and credits > 10:\\n            issues.append(f'第8学期学分 {credits:g} 偏高')\\n\\n    required_categories = ['思政', '通识', '数学基础', '编程基础', '专业核心', 'AI核心', '实践']\\n    for cat in required_categories:\\n        if cat_credits.get(cat, 0) <= 0:\\n            issues.append(f'缺少类别: {cat}')\\n\\n    return {\\n        'total_credits': total_credits,\\n        'semester_credits': {f'第{k}学期': v for k, v in sorted(sem_credits.items())},\\n        'category_credits': dict(sorted(cat_credits.items())),\\n        'issues': issues,\\n        'ok': not issues,\\n    }\\n\\n\\n\\ndef write_plan(rows: List[dict]) -> None:\\n    header = ['学期', '学期序号', '课程序号', '课程名称', '学时', '学分', '课程类别', '数据来源学期']\\n    with OUTPUT_PLAN.open('w', encoding='utf-8', newline='') as f:\\n        f.write('\\\\t'.join(header) + '\\\\n')\\n        for row in rows:\\n            f.write('\\\\t'.join([\\n                row['semester'],\\n                str(row['semester_no']),\\n                str(row['order']),\\n                row['course_name'],\\n                row['hours'],\\n                row['credits'],\\n                row['category'],\\n                row['source_term'],\\n            ]) + '\\\\n')\\n\\n\\n\\ndef write_summary(result: dict, rows: List[dict]) -> None:\\n    lines = [\\n        '# 人工智能专业培养计划说明',\\n        '',\\n        '- 输出文件：`ai_training_plan.txt`（制表符分隔）',\\n        '- 生成脚本：`generate_ai_plan.py`',\\n        '- 校验脚本：`validate_ai_plan.py`',\\n        '',\\n        '## 方案思路',\\n        '',\\n        '1. 从给定三份原始课程表中抽取 AI 专业相关课程。',\\n        '2. 按“思政/通识、数学基础、编程基础、专业核心、AI核心、AI应用、实践”分层组织。',\\n        '3. 依据常见先修关系安排到 8 个学期，保证核心 AI 课程逐步递进。',\\n        '4. 对每学期学分、类别覆盖和先修关系进行校验。',\\n        '',\\n        '## 学分统计',\\n        '',\\n    ]\\n    for sem, credits in result['semester_credits'].items():\\n        lines.append(f'- {sem}: {credits:g} 学分')\\n    lines += ['', f'- 总学分: {result[\\\"total_credits\\\"]:g}', '', '## 类别学分统计', '']\\n    for cat, credits in result['category_credits'].items():\\n        lines.append(f'- {cat}: {credits:g} 学分')\\n    lines += ['', '## 校验结果', '']\\n    if result['ok']:\\n        lines.append('- 校验通过：未发现先修冲突，且各核心类别均已覆盖。')\\n    else:\\n        lines.append('- 校验未通过：')\\n        lines.extend([f'  - {x}' for x in result['issues']])\\n    OUTPUT_SUMMARY.write_text('\\\\n'.join(lines), encoding='utf-8')\\n\\n\\n\\ndef main() -> None:\\n    catalog = load_courses()\\n    rows = build_plan(catalog)\\n    result = validate(rows)\\n    write_plan(rows)\\n    write_summary(result, rows)\\n    print(json.dumps(result, ensure_ascii=False, indent=2))\\n\\n\\nif __name__ == '__main__':\\n    main()\\n\"}"
