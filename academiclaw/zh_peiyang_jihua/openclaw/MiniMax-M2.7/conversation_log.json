rds = ['python', 'java', 'c语言', 'c++', '程序设计',\\n                           '数据结构', '算法设计', '软件工程', '数据库原理',\\n                           '操作系统', '计算机网络', '编译原理', '分布式系统',\\n                           '面向对象', '云计算', '边缘计算', '软件工程',\\n                           '编程', '程序设计']\\n    \\n    # Practice/Practical courses\\n    practice_keywords = ['实验', '实践', '实习', '实训', '课程设计', '毕业设计',\\n                         '毕业论文', '项目实践', '创新创业', '科研训练', '工程实践']\\n    \\n    # Ideological/General education\\n    ideology_keywords = ['思政', '政治', '军事理论', '国防教育', '体育', \\n                        '大学语文', '心理健康', '就业指导', '职业生涯', '形势与政策',\\n                        '英语', '大学英语', '体育与健康']\\n    \\n    # Check each category\\n    for kw in ai_keywords:\\n        if kw in name:\\n            return 'AI核心课'\\n    \\n    for kw in math_keywords:\\n        if kw in name:\\n            return '数学基础'\\n    \\n    for kw in programming_keywords:\\n        if kw in name:\\n            return '编程基础'\\n    \\n    for kw in practice_keywords:\\n        if kw in name:\\n            return '实践环节'\\n    \\n    for kw in ideology_keywords:\\n        if kw in name:\\n            return '思政/通识'\\n    \\n    return None\\n\\ndef is_valid_course(course):\\n    \\\"\\\"\\\"Check if a course is valid for inclusion\\\"\\\"\\\"\\n    name = course['name']\\n    credits = course['credits']\\n    hours = course['hours']\\n    \\n    # Must have reasonable credits and hours\\n    if credits < 1 or credits > 8:\\n        return False\\n    \\n    if hours < 16:\\n        return False\\n    \\n    # Skip obviously non-relevant courses\\n    skip_patterns = ['游泳', '足球', '篮球', '排球', '羽毛球', '乒乓球', '武术', \\n                     '健美操', '拉丁舞', '跆拳道', '高尔夫', '网球', '体操',\\n                     '营养学', '食品科学', '护理学', '药学', '医学', '农学',\\n                     '生物学', '化学', '物理', '力学', '机械', '电气', '电子',\\n                     '会计', '金融', '经济', '管理', '营销', '物流', '旅游',\\n                     '建筑', '土木', '材料', '环境', '能源', '交通']\\n    \\n    for pattern in skip_patterns:\\n        if pattern in name:\\n            return False\\n    \\n    return True\\n\\ndef is_ai_related(name):\\n    \\\"\\\"\\\"Check if a course name is AI-related\\\"\\\"\\\"\\n    name_lower = name.lower()\\n    ai_keywords = ['人工智能', '机器学习', '深度学习', '神经网络', '计算机视觉',\\n                  '自然语言', '数据挖掘', '模式识别', '知识图谱', '强化学习',\\n                  '语音', 'AI', 'artificial', 'machine learning', 'deep learning',\\n                  'neural', 'cv', 'nlp', 'speech', 'kg', 'rl', '数据科学',\\n                  '智能系统', '智能计算', '人工智能技术', '人工智能算法',\\n                  '人工智能', '智能', 'AIGC', '大语言模型', 'LLM', 'GPT']\\n    \\n    for kw in ai_keywords:\\n        if kw.lower() in name_lower:\\n            return True\\n    return False\\n\\ndef select_courses_by_category(courses, category, min_credits=2):\\n    \\\"\\\"\\\"Select courses for a specific category\\\"\\\"\\\"\\n    selected = []\\n    for course in courses:\\n        if identify_course_category(course['name']) == category and course['credits'] >= min_credits:\\n            if is_valid_course(course):\\n                selected.append(course)\\n    return selected\\n\\ndef generate_training_plan_v3(courses):\\n    \\\"\\\"\\\"Generate training plan v3 - improved version\\\"\\\"\\\"\\n    \\n    # Get unique courses\\n    unique_courses = get_unique_courses(courses)\\n    \\n    # Categorize\\n    ai_core = select_courses_by_category(unique_courses, 'AI核心课', min_credits=2)\\n    math_base = select_courses_by_category(unique_courses, '数学基础', min_credits=2)\\n    prog_base = select_courses_by_category(unique_courses, '编程基础', min_credits=2)\\n    practice = select_courses_by_category(unique_courses, '实践环节', min_credits=1)\\n    ideology = select_courses_by_category(unique_courses, '思政/通识', min_credits=1)\\n    \\n    # Filter AI courses to only truly AI-related ones\\n    ai_core = [c for c in ai_core if is_ai_related(c['name'])]\\n    \\n    # Sort by credits descending\\n    ai_core.sort(key=lambda x: -x['credits'])\\n    math_base.sort(key=lambda x: -x['credits'])\\n    prog_base.sort(key=lambda x: -x['credits'])\\n    practice.sort(key=lambda x: -x['credits'])\\n    ideology.sort(key=lambda x: -x['credits'])\\n    \\n    # Define semester structure\\n    semesters = {k: [] for k in range(1, 9)}\\n    semester_credits = {k: 0 for k in range(1, 9)}\\n    max_credits = 26\\n    used_courses = set()\\n    \\n    def can_add(course):\\n        \\\"\\\"\\\"Check if course can be added to a semester\\\"\\\"\\\"\\n        return semester_credits[current_sem] + course['credits'] <= max_credits\\n    \\n    def add_course(course, sem):\\n        \\\"\\\"\\\"Add a course to a semester\\\"\\\"\\\"\\n        semesters[sem].append(course)\\n        semester_credits[sem] += course['credits']\\n        used_courses.add(course['name'])\\n    \\n    # === Build the training plan ===\\n    \\n    # Priority order for semesters\\n    # Semester 1: Programming + Math foundation\\n    current_sem = 1\\n    \\n    # Add Python courses\\n    for course in prog_base:\\n        if 'python' in course['name'].lower() and course['name'] not in used_courses:\\n            if can_add(course):\\n                add_course(course, 1)\\n    \\n    # Add basic math\\n    for course in math_base:\\n        if ('高等数学' in course['name'] or '线性代数' in course['name']) and course['name'] not in used_courses:\\n            if can_add(course):\\n                add_course(course, 1)\\n    \\n    # Add PE\\n    for course in ideology:\\n        if '体育' in course['name'] and course['credits'] <= 2 and course['name'] not in used_courses:\\n            if can_add(course):\\n                add_course(course, 1)\\n                break\\n    \\n    # Add English\\n    for course in ideology:\\n        if ('英语' in course['name'] or '大学英语' in course['name']) and course['name'] not in used_courses:\\n            if can_add(course):\\n                add_course(course, 1)\\n                break\\n    \\n    # Semester 2: Data structures + algorithms + more math\\n    current_sem = 2\\n    \\n    for course in prog_base:\\n        if ('数据结构' in course['name'] or '算法' in course['name'].lower()) and course['name'] not in used_courses:\\n            if can_add(course):\\n                add_course(course, 2)\\n    \\n    for course in math_base:\\n        if ('概率论' in course['name'] or '离散数学' in course['name']) and course['name'] not in used_courses:\\n            if can_add(course):\\n                add_course(course, 2)\\n    \\n    # Semester 3-6: AI core courses\\n    ai_course_priority = ['机器学习', '深度学习', '神经网络', '计算机视觉', \\n                         '自然语言处理', '数据挖掘', '模式识别', '知识图谱',\\n                         '强化学习', '人工智能', 'AI']\\n    \\n    sem分配 = {3: [], 4: [], 5: [], 6: []}\\n    \\n    for course in ai_core:\\n        if course['name'] in used_courses:\\n            continue\\n        \\n        # Find best semester based on course content\\n        name = course['name']\\n        \\n        if any(kw in name for kw in ['机器学习', 'machine learning']):\\n            target_sem = 3\\n        elif any(kw in name for kw in ['深度学习', 'deep learning', '神经网络']):\\n            target_sem = 4\\n        elif any(kw in name for kw in ['计算机视觉', 'cv']):\\n            target_sem = 5\\n        elif any(kw in name for kw in ['自然语言', 'nlp']):\\n            target_sem = 6\\n        else:\\n            target_sem = 3\\n        \\n        if can_add(course):\\n            add_course(course, target_sem)\\n    \\n    # Fill remaining slots with remaining courses\\n    for sem in range(1, 9):\\n        current_sem = sem\\n        \\n        # Fill with remaining AI courses\\n        for course in ai_core:\\n            if course['name'] not in used_courses and can_add(course):\\n                add_course(course, sem)\\n        \\n        # Fill with remaining math\\n        for course in math_base:\\n            if course['name'] not in used_courses and can_add(course):\\