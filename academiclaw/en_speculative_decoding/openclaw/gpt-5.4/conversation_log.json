)\\n            for k, v in zip(self.keys, self.values)\\n        ]\\n\\n    def append_from_model_cache(self, new_cache: Sequence[Tuple[torch.Tensor, torch.Tensor]], appended_tokens: int):\\n        new_total = new_cache[0][0].size(2)\\n        old_total = new_total - appended_tokens\\n        for i, (new_k, new_v) in enumerate(new_cache):\\n            append_k = new_k[:, :, old_total:new_total, :]\\n            append_v = new_v[:, :, old_total:new_total, :]\\n            if self.keys[i].size(2) < self.length + appended_tokens:\\n                self.keys[i] = torch.cat([self.keys[i][:, :, : self.length, :], append_k], dim=2)\\n                self.values[i] = torch.cat([self.values[i][:, :, : self.length, :], append_v], dim=2)\\n            else:\\n                self.keys[i][:, :, self.length : self.length + appended_tokens, :] = append_k\\n                self.values[i][:, :, self.length : self.length + appended_tokens, :] = append_v\\n        self.length += appended_tokens\\n\\n    def rollback(self, new_length: int):\\n        if new_length < 0 or new_length > self.length:\\n            raise ValueError(f\\\"invalid rollback length {new_length}, current={self.length}\\\")\\n        self.length = new_length\\n\\n\\nclass ModelRunner:\\n    def __init__(self, model: GPTLite, name: str):\\n        self.model = model\\n        self.name = name\\n        self.forward_calls = 0\\n\\n    def prefill(self, idx: torch.Tensor):\\n        self.forward_calls += 1\\n        logits, cache = self.model(idx)\\n        return logits, KVCacheView.from_model_cache(cache)\\n\\n    def decode(self, idx: torch.Tensor, cache: KVCacheView):\\n        self.forward_calls += 1\\n        logits, new_cache = self.model(idx, cache.as_model_cache())\\n        out = cache.clone()\\n        out.append_from_model_cache(new_cache, idx.size(1))\\n        return logits, out\\n\\n\\nclass SeededSampler:\\n    def __init__(self, seed: int, device: torch.device, bank_size: int = 200000):\\n        self.device = device\\n        gen = torch.Generator(device=\\\"cpu\\\")\\n        gen.manual_seed(seed)\\n        self.bank = torch.rand(bank_size, generator=gen, dtype=torch.float64)\\n        self.pos = 0\\n\\n    def uniform(self) -> float:\\n        if self.pos >= len(self.bank):\\n            raise RuntimeError(\\\"random bank exhausted\\\")\\n        out = float(self.bank[self.pos].item())\\n        self.pos += 1\\n        return out\\n\\n    def probs_from_logits(self, logits: torch.Tensor, temperature: float) -> torch.Tensor:\\n        if temperature <= 0:\\n            probs = torch.zeros_like(logits, dtype=torch.float32)\\n            probs.scatter_(-1, torch.argmax(logits, dim=-1, keepdim=True), 1.0)\\n            return probs\\n        return F.softmax(logits / max(temperature, 1e-6), dim=-1)\\n\\n    def sample_from_probs(self, probs: torch.Tensor, u: Optional[float] = None) -> torch.Tensor:\\n        if u is None:\\n            u = self.uniform()\\n        cdf = torch.cumsum(probs[0].to(torch.float64), dim=-1)\\n        token = torch.searchsorted(cdf, torch.tensor(u, dtype=torch.float64, device=probs.device), right=False)\\n        token = torch.clamp(token, max=probs.size(-1) - 1)\\n        return token.view(1, 1).to(torch.long)\\n\\n    def sample_from_logits(self, logits: torch.Tensor, temperature: float, u: Optional[float] = None):\\n        probs = self.probs_from_logits(logits, temperature)\\n        return self.sample_from_probs(probs, u=u), probs\\n\\n\\n\\ndef get_default_device() -> str:\\n    return \\\"cuda\\\" if torch.cuda.is_available() else \\\"cpu\\\"\\n\\n\\ndef load_target_model(device: str):\\n    config = GPTConfig(n_layer=4, n_embd=64, vocab_size=1000)\\n    model = GPTLite(config, simulate_latency=True)\\n    model.load_state_dict(torch.load(TARGET_MODEL_PATH, map_location=device))\\n    model.to(device)\\n    model.eval()\\n    return model\\n\\n\\ndef load_draft_model(device: str):\\n    config = GPTConfig(n_layer=1, n_embd=64, vocab_size=1000)\\n    model = GPTLite(config, simulate_latency=False)\\n    model.load_state_dict(torch.load(DRAFT_MODEL_PATH, map_location=device))\\n    model.to(device)\\n    model.eval()\\n    return model\\n\\n\\ndef make_prompt(batch_size: int = 1, prompt_len: int = 10, vocab_size: int = 1000, seed: int = 1234, device: str = \\\"cpu\\\"):\\n    gen = torch.Generator(device=\\\"cpu\\\")\\n    gen.manual_seed(seed)\\n    prompt = torch.randint(0, vocab_size, (batch_size, prompt_len), generator=gen)\\n    return prompt.to(device)\\n\\n\\n\\ndef _sync_if_needed(device: torch.device):\\n    if torch.cuda.is_available() and device.type == \\\"cuda\\\":\\n        torch.cuda.synchronize()\\n\\n\\n@torch.no_grad()\\ndef autoregressive_sampling(model: GPTLite, prompt: torch.Tensor, max_new_tokens: int = 50, temperature: float = 0.0, seed: int = 0):\\n    runner = ModelRunner(model, \\\"baseline\\\")\\n    sampler = SeededSampler(seed, prompt.device)\\n    idx = prompt.clone()\\n    _, cache = runner.prefill(idx)\\n    logits, cache = runner.decode(idx[:, -1:], cache)\\n    step_logits = logits[:, -1, :]\\n\\n    _sync_if_needed(prompt.device)\\n    start = time.time()\\n    for _ in range(max_new_tokens):\\n        next_token, _ = sampler.sample_from_logits(step_logits, temperature)\\n        idx = torch.cat([idx, next_token], dim=1)\\n        logits, cache = runner.decode(next_token, cache)\\n        step_logits = logits[:, -1, :]\\n    _sync_if_needed(prompt.device)\\n    elapsed = time.time() - start\\n    stats = GenerationStats(\\n        model_name=\\\"baseline\\\",\\n        generated_tokens=max_new_tokens,\\n        wall_time=elapsed,\\n        tokens_per_second=max_new_tokens / max(elapsed, 1e-9),\\n        temperature=temperature,\\n        target_forward_calls=runner.forward_calls,\\n    )\\n    return idx, stats\\n\\n\\n@torch.no_grad()\\ndef speculative_sampling(\\n    target_model: GPTLite,\\n    draft_model: GPTLite,\\n    prompt: torch.Tensor,\\n    max_new_tokens: int = 50,\\n    gamma: int = 4,\\n    temperature: float = 0.0,\\n    seed: int = 0,\\n):\\n    target_runner = ModelRunner(target_model, \\\"target\\\")\\n    draft_runner = ModelRunner(draft_model, \\\"draft\\\")\\n    sampler = SeededSampler(seed, prompt.device)\\n\\n    idx = prompt.clone()\\n    _, target_cache = target_runner.prefill(idx)\\n    _, draft_cache = draft_runner.prefill(idx)\\n    target_logits, target_cache = target_runner.decode(idx[:, -1:], target_cache)\\n    draft_logits, draft_cache = draft_runner.decode(idx[:, -1:], draft_cache)\\n    target_step_logits = target_logits[:, -1, :]\\n    draft_step_logits = draft_logits[:, -1, :]\\n\\n    generated = 0\\n    accepted = 0\\n    proposed = 0\\n\\n    _sync_if_needed(prompt.device)\\n    start = time.time()\\n\\n    while generated < max_new_tokens:\\n        if gamma <= 1:\\n            next_token, _ = sampler.sample_from_logits(target_step_logits, temperature)\\n            idx = torch.cat([idx, next_token], dim=1)\\n            generated += 1\\n            target_logits, target_cache = target_runner.decode(next_token, target_cache)\\n            draft_logits, draft_cache = draft_runner.decode(next_token, draft_cache)\\n            target_step_logits = target_logits[:, -1, :]\\n            draft_step_logits = draft_logits[:, -1, :]\\n            continue\\n\\n        steps = min(gamma, max_new_tokens - generated)\\n        base_draft_len = draft_cache.length\\n        work_draft_cache = draft_cache.clone()\\n        running_draft_logits = draft_step_logits\\n\\n        proposal_tokens: List[torch.Tensor] = []\\n        draft_probs: List[torch.Tensor] = []\\n        proposal_uniforms: List[float] = []\\n        accept_uniforms: List[float] = []\\n\\n        for _ in range(steps):\\n            u_propose = sampler.uniform()\\n            token, probs = sampler.sample_from_logits(running_draft_logits, temperature, u=u_propose)\\n            proposal_tokens.append(token)\\n            draft_probs.append(probs)\\n            proposal_uniforms.append(u_propose)\\n            accept_uniforms.append(sampler.uniform())\\n            draft_logits_next, work_draft_cache = draft_runner.decode(token, work_draft_cache)\\n            running_draft_logits = draft_logits_next[:, -1, :]\\n\\n        proposal = torch.cat(proposal_tokens, dim=1)\\n        proposed += proposal.size(1)\\n\\n        verify_logits, verified_target_cache = target_runner.decode(proposal, target_cache.clone())\\n        verify_probs = [sampler.probs_from_logits(verify_logits[:, i, :], temperature) for i in range(proposal.size(1))]\\n\\n        reject_at = None\\n        correction_token = None\\n        correction_probs = None\\n        accepted_prefix = 0\\n\\n        for i, token in enumerate(proposal_tokens):\\n            token_id = int(token.item())\\n            p_d = float(draft_probs[i][0, token_id].item())\\n            p_t = float(verify_probs[i][0, token_id].item())\\n            if temperature <= 0:\\n                accept_prob = 1.0 if token_id == int(torch.argmax(verify_probs[i], dim=-1).item()) else 0.0\\n            else:\\n                accept_prob = 1.0 if p_d <= p_t else max(0.0, min(1.0, p_t / max(p_d, 1e-12)))\\n            if accept_uniforms[i] <= accept_prob:\\n                accepted_prefix += 1\\n                accepted += 1\\n                continue\\n            reject_at = i\\n            diff = torch.clamp(verify_probs[i] - draft_probs[i], min=0.0)\\n            norm = diff.sum(dim=-1, keepdim=True)\\n            if float(norm.item()) <= 0:\\n                diff = verify_probs[i]\\n                norm = diff.sum(dim=-1, keepdim=True)\\n            correction_probs = diff / norm\\n            correction_token = sampler.sample_from_probs(correction_probs)\\n            break\\n\\n        if reject_at is None:\\n            idx = torch.cat([idx, proposal], dim=1)\\n            generated += proposal.size(1)\\n            target_cache = verified_target_cache\\n            draft_cache = work_draft_cache\\n            draft_step_logits = running_draft_logits\\n            target_step_logits = verify_logits[:, -1, :]\\n\\n            if generated < max_new_tokens:\\n                bonus_token, _ = sampler.sample_from_logits(target_step_logits, temperature)\\n                idx = torch.cat([idx, bonus_token], dim=1)\\n                generated += 1\\n                target_logits, target_cache = target_runner.decode(bonus_token, target_cache)\\n                draft_logits, draft_cache = draft_runner.decode(bonus_token, draft_cache)\\n                target_step_logits = target_logits[:, -1, :]\\n                draft_step_logits = draft_logits[:, -1, :]\\n        else:\\n            if accepted_prefix > 0:\\n                idx = torch.cat([idx, proposal[:, :accepted_prefix]], dim=1)\\n                generated += accepted_prefix\\n            idx = torch.cat([idx, correction_token], dim=1)\\n            generated += 1\\n\\n            target_cache = verified_target_cache\\n            target_cache.rollback(target_cache.length - (proposal.size(1) - accepted_prefix))\\n            draft_cache.rollback(base_draft_len + accepted_prefix)\\n\\n            target_step_logits = verify_logits[:, reject_at, :]\\n            target_logits, target_cache = target_runner.decode(correction_token, target_cache)\\n            target_step_logits = target_logits[:, -1, :]\\n\\n            draft_logits, draft_cache = draft_runner.decode(correction_token, draft_cache)\\n            draft_step_logits = draft_logits[:, -1, :]\\n\\n    _sync_if_needed(prompt.device)\\n    elapsed = time.time() - start\\n    stats = GenerationStats(\\n        model_name=\\\"speculative\\\",\\n        generated_tokens=max_new_tokens,\\n        wall_time=elapsed,\\n        tokens_per_second=max_new_tokens / max(elapsed, 1e-9),\\n        temperature=temperature,\\n        gamma=gamma,\\n        accepted_tokens=accepted,\\n        proposed_tokens=proposed,\\n        acceptance_rate=accepted / max(proposed, 1),\\n        target_forward_calls=target_runner.forward_calls,\\n        draft_forward_calls=draft_runner.forward_calls,\\n    )\\n    return idx[:, : prompt.size(1) + max_new_tokens], stats\\n\\n\\n\\ndef run_distribution_check(device: Optional[str] = None, seed: int = 2025, max_new_tokens: int = 32, gamma: int = 4, temperature: float = 0.8):\\n    device = device or get_default_device()\\n    prompt = make_prompt(device=device, seed=seed)\\n    target = load_target_model(device)\\n    draft = load_draft_model(device)\\n    baseline_out, baseline_stats = autoregressive_sampling(target, prompt, max_new_tokens=max_new_tokens, temperature=temperature, seed=seed)\\n    spec_out, spec_stats = speculative_sampling(target, draft, prompt, max_new_tokens=max_new_tokens, gamma=gamma, temperature=temperature, seed=seed)\\n    return {\\n        \\\"match\\\": torch.equal(baseline_out, spec_out),\\n        \\\"baseline_output\\\": baseline_out,\\n        \\\"spec_output\\\": spec_out,\\n        \\\"baseline_stats\\\": baseline_stats,\\n        \\\"spec_stats\\\": spec_stats,\\n    }\\n\\n\\n\\ndef benchmark(device: Optional[str] = None, seed: int = 2025, prompt_len: int = 10, max_new_tokens: int = 40, gamma: int = 4, temperatures: Sequence[float] = (0.0, 0.4, 0.8, 1.2)):\\n    device = device or get_default_device()\\n    target = load_target_model(device)\\n    draft = load_draft_model(device)\\n    prompt = make_prompt(prompt_len=prompt_len, device=device, seed=seed)\\n    rows = []\\n    for temp in temperatures:\\n        base_out, base_stats = autoregressive_sampling(target, prompt, max_new_tokens=max_new_tokens, temperature=float(temp), seed=seed)\\n        spec_out, spec_stats = speculative_sampling(target, draft, prompt, max_new_tokens=max_new_tokens, gamma=gamma, temperature=float(temp), seed=seed)\\n        rows.append(\\n            {\\n                \\\"temperature\\\": float(temp),\\n                \\\"match\\\": torch.equal(base_out, spec_out),\\n                \\\"baseline\\\": base_stats,\\n                \\\"speculative\\\": spec_stats,\\n                \\\"speedup\\\": spec_stats.tokens_per_second / max(base_stats.tokens_per_second, 1e-9),\\n            }\\n        )\\n    return rows\\n\\n\\n\\ndef stats_to_dict(stats: GenerationStats):\\n    return {\\n        \\\"model_name\\\": stats.model_name,\\n        \\\"generated_tokens\\\": stats.generated_tokens,\\n        \\\"wall_time\\\": round(stats.wall_time, 6),\\n        \\\"tokens_per_second\\\": round(stats.tokens_per_second, 4),\\n        \\\"temperature\\\": stats.temperature,\\n        \\\"gamma\\\": stats.gamma,\\n        \\\"accepted_tokens\\\": stats.accepted_tokens,\\n        \\\"proposed_tokens\\\": stats.proposed_tokens,\\n        \\\"acceptance_rate\\\": round(stats.acceptance_rate, 4),\\n        \\\"target_forward_calls\\\": stats.target_forward_calls,\\n        \\\"draft_forward_calls\\\": stats.draft_forward_calls,\\n    }\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    device = get_default_device()\\n    seed = 2025\\n    gamma = 4\\n    max_new_tokens = 40\\n    temperatures = [0.0, 0.4, 0.8, 1.2]\\n\\n    print(f\\\"Running on device={device}\\\")\\n    check = run_distribution_check(device=device, seed=seed, max_new_tokens=32, gamma=gamma, temperature=0.8)\\n    print(f\\\"Distribution check @ temperature=0.8 gamma={gamma}: match={check['match']}\\\")\\n    print(\\\"Baseline:\\\", stats_to_dict(check[\\\"baseline_stats\\\"]))\\n    print(\\\"Speculative:\\\", stats_to_dict(check[\\\"spec_stats\\\"]))\\n    print(\\\"\\\\nBenchmark summary:\\\")\\n    for row in benchmark(device=device, seed=seed, max_new_tokens=max_new_tokens, gamma=gamma, temperatures=temperatures):\\n        print(\\n            {\\n                \\\"temperature\\\": row[\\\"temperature\\\"],\\n                \\\"match\\\": row[\\\"match\\\"],\\n                \\\"baseline_tps\\\": round(row[\\\"baseline\\\"].tokens_per_