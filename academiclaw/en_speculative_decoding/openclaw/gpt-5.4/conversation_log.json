                  "arguments": "{\"path\":\"/tmp/isolated_workspace_1091/inference.py\",\"content\":\"import math\\nimport os\\nimport random\\nimport sys\\nimport time\\nfrom dataclasses import dataclass\\nfrom typing import List, Optional, Sequence, Tuple\\n\\nimport torch\\nimport torch.nn.functional as F\\n\\nsys.path.append(os.path.join(os.path.dirname(__file__), \\\"context\\\", \\\"original_proj\\\"))\\nfrom gpt_lite import GPTConfig, GPTLite  # noqa: E402\\n\\n\\nMODELS_DIR = os.path.join(os.path.dirname(__file__), \\\"context\\\", \\\"models\\\")\\nTARGET_MODEL_PATH = os.path.join(MODELS_DIR, \\\"target_model.pt\\\")\\nDRAFT_MODEL_PATH = os.path.join(MODELS_DIR, \\\"draft_model.pt\\\")\\n\\n\\n@dataclass\\nclass GenerationStats:\\n    model_name: str\\n    generated_tokens: int\\n    wall_time: float\\n    tokens_per_second: float\\n    temperature: float\\n    gamma: int = 1\\n    accepted_tokens: int = 0\\n    proposed_tokens: int = 0\\n    acceptance_rate: float = 0.0\\n    target_forward_calls: int = 0\\n    draft_forward_calls: int = 0\\n\\n\\nclass KVCacheView:\\n    \\\"\\\"\\\"\\n    Lightweight cache wrapper with a logical length pointer.\\n\\n    Physical tensors are only grown on append; rollback only adjusts `length`.\\n    This avoids repeated `torch.cat`-driven reallocation in the speculative path.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, layers: Sequence[Tuple[torch.Tensor, torch.Tensor]]):\\n        self.keys: List[torch.Tensor] = [kv[0].clone() for kv in layers]\\n        self.values: List[torch.Tensor] = [kv[1].clone() for kv in layers]\\n        self.length = layers[0][0].size(2) if layers else 0\\n\\n    @classmethod\\n    def from_model_cache(cls, past_key_values: Optional[Sequence[Tuple[torch.Tensor, torch.Tensor]]]):\\n        if past_key_values is None:\\n            return None\\n        return cls(past_key_values)\\n\\n    def as_model_cache(self) -> List[Tuple[torch.Tensor, torch.Tensor]]:\\n        return [\\n            (k[:, :, : self.length, :], v[:, :, : self.length, :])\\n            for k, v in zip(self.keys, self.values)\\n        ]\\n\\n    def append_from_model_cache(self, new_cache: Sequence[Tuple[torch.Tensor, torch.Tensor]], appended_tokens: int):\\n        new_total_len = new_cache[0][0].size(2)\\n        prev_len = new_total_len - appended_tokens\\n        for i, (new_k, new_v) in enumerate(new_cache):\\n            append_k = new_k[:, :, prev_len:new_total_len, :]\\n            append_v = new_v[:, :, prev_len:new_total_len, :]\\n            if self.keys[i].size(2) < self.length + appended_tokens:\\n                self.keys[i] = torch.cat([self.keys[i][:, :, : self.length, :], append_k], dim=2)\\n                self.values[i] = torch.cat([self.values[i][:, :, : self.length, :], append_v], dim=2)\\n            else:\\n                self.keys[i][:, :, self.length : self.length + appended_tokens, :] = append_k\\n                self.values[i][:, :, self.length : self.length + appended_tokens, :] = append_v\\n        self.length += appended_tokens\\n\\n    def rollback(self, new_length: int):\\n        if new_length < 0 or new_length > self.length:\\n            raise ValueError(f\\\"invalid rollback length: {new_length} from current={self.length}\\\")\\n        self.length = new_length\\n\\n    def clone(self):\\n        out = object.__new__(KVCacheView)\\n        out.keys = [k.clone() for k in self.keys]\\n        out.values = [v.clone() for v in self.values]\\n        out.length = self.length\\n        return out\\n\\n\\nclass ModelRunner:\\n    def __init__(self, model: GPTLite, name: str):\\n        self.model = model\\n        self.name = name\\n        self.forward_calls = 0\\n\\n    @property\\n    def device(self):\\n        return next(self.model.parameters()).device\\n\\n    def reset_stats(self):\\n        self.forward_calls = 0\\n\\n    @torch.no_grad()\\n    def prefill(self, idx: torch.Tensor) -> Tuple[torch.Tensor, KVCacheView]:\\n        self.forward_calls += 1\\n        logits, past = self.model(idx)\\n        return logits, KVCacheView.from_model_cache(past)\\n\\n    @torch.no_grad()\\n    def decode(self, idx: torch.Tensor, cache: KVCacheView) -> Tuple[torch.Tensor, KVCacheView]:\\n        self.forward_calls += 1\\n        logits, new_cache = self.model(idx, cache.as_model_cache())\\n        out_cache = cache.clone()\\n        out_cache.append_from_model_cache(new_cache, idx.size(1))\\n        return logits, out_cache\\n\\n\\nclass SeedController:\\n    \\\"\\\"\\\"\\n    Deterministic token source.\\n\\n    We pre-sample a bank of uniforms so baseline and speculative decoding can\\n    consume the same randomness in the same logical order.\\n    \\\"\\\"\\\"\\n\\n    def __init__(self, seed: int, device: torch.device, bank_size: int = 200000):\\n        gen = torch.Generator(device=\\\"cpu\\\")\\n        gen.manual_seed(seed)\\n        self.bank = torch.rand(bank_size, generator=gen, dtype=torch.float64)\\n        self.pos = 0\\n        self.device = device\\n\\n    def uniform(self) -> float:\\n        if self.pos >= len(self.bank):\\n            raise RuntimeError(\\\"random bank exhausted\\\")\\n        val = float(self.bank[self.pos].item())\\n        self.pos += 1\\n        return val\\n\\n\\nclass SamplingTape:\\n    def __init__(self, seed_controller: SeedController):\\n        self.rng = seed_controller\\n\\n    def _safe_temperature(self, temperature: float) -> float:\\n        return max(float(temperature), 1e-6)\\n\\n    def probs_from_logits(self, logits: torch.Tensor, temperature: float) -> torch.Tensor:\\n        if temperature <= 0:\\n            probs = torch.zeros_like(logits, dtype=torch.float32)\\n            probs.scatter_(-1, torch.argmax(logits, dim=-1, keepdim=True), 1.0)\\n            return probs\\n        return F.softmax(logits / self._safe_temperature(temperature), dim=-1)\\n\\n    def sample_from_probs(self, probs: torch.Tensor, u: Optional[float] = None) -> torch.Tensor:\\n        if probs.dim() != 2 or probs.size(0) != 1:\\n            raise ValueError(\\\"expected probs shape [1, vocab]\\\")\\n        if u is None:\\n            u = self.rng.uniform()\\n        cdf = torch.cumsum(probs[0].to(torch.float64), dim=-1)\\n        target = torch.tensor(u, dtype=torch.float64, device=probs.device)\\n        token = torch.searchsorted(cdf, target, right=False)\\n        token = torch.clamp(token, max=probs.size(-1) - 1)\\n        return token.view(1, 1).to(torch.long)\\n\\n    def sample_from_logits(self, logits: torch.Tensor, temperature: float, u: Optional[float] = None) -> Tuple[torch.Tensor, torch.Tensor]:\\n        probs = self.probs_from_logits(logits, temperature)\\n        token = self.sample_from_probs(probs, u=u)\\n        return token, probs\\n\\n    def corrected_distribution(self, target_probs: torch.Tensor, draft_probs: torch.Tensor) -> torch.Tensor:\\n        diff = torch.clamp(target_probs - draft_probs, min=0.0)\\n        norm = diff.sum(dim=-1, keepdim=True)\\n        fallback = norm <= 0\\n        if fallback.any():\\n            diff = torch.where(fallback, target_probs, diff)\\n            norm = diff.sum(dim=-1, keepdim=True)\\n        return diff / norm\\n\\n\\n\\ndef get_default_device() -> str:\\n    return \\\"cuda\\\" if torch.cuda.is_available() else \\\"cpu\\\"\\n\\n\\ndef load_target_model(device: str) -> GPTLite:\\n    config = GPTConfig(n_layer=4, n_embd=64, vocab_size=1000)\\n    model = GPTLite(config, simulate_latency=True)\\n    if not os.path.exists(TARGET_MODEL_PATH):\\n        raise FileNotFoundError(f\\\"Target model weights not found: {TARGET_MODEL_PATH}\\\")\\n    model.load_state_dict(torch.load(TARGET_MODEL_PATH, map_location=device))\\n    model.to(device)\\n    model.eval()\\n    return model\\n\\n\\ndef load_draft_model(device: str) -> GPTLite:\\n    config = GPTConfig(n_layer=1, n_embd=64, vocab_size=1000)\\n    model = GPTLite(config, simulate_latency=False)\\n    if not os.path.exists(DRAFT_MODEL_PATH):\\n        raise FileNotFoundError(f\\\"Draft model weights not found: {DRAFT_MODEL_PATH}\\\")\\n    model.load_state_dict(torch.load(DRAFT_MODEL_PATH, map_location=device))\\n    model.to(device)\\n    model.eval()\\n    return model\\n\\n\\ndef make_prompt(batch_size: int = 1, prompt_len: int = 10, vocab_size: int = 1000, seed: int = 1234, device: str = \\\"cpu\\\"):\\n    gen = torch.Generator(device=\\\"cpu\\\")\\n    gen.manual_seed(seed)\\n    prompt = torch.randint(0, vocab_size, (batch_size, prompt_len), generator=gen)\\n    return prompt.to(device)\\n\\n\\ndef autoregressive_sampling(model: GPTLite, prompt: torch.Tensor, max_new_tokens: int = 50, temperature: float = 0.0, seed: int = 0):\\n    runner = ModelRunner(model, \\\"baseline\\\")\\n    tape = SamplingTape(SeedController(seed, prompt.device))\\n    idx = prompt.clone()\\n    logits, cache = runner.prefill(idx)\\n\\n    start = time.time()\\n    generated = 0\\n    for step in range(max_new_tokens):\\n        if step == 0:\\n            step_logits = logits[:, -1, :]\\n        else:\\n            step_logits, cache = runner.decode(idx[:, -1:], cache)\\n            step_logits = step_logits[:, -1, :]\\n        next_token, _ = tape.sample_from_logits(step_logits, temperature)\\n        idx = torch.cat((idx, next_token), dim=1)\\n        generated += 1\\n    if torch.cuda.is_available() and prompt.device.type == \\\"cuda\\\":\\n        torch.cuda.synchronize()\\n    elapsed = time.time() - start\\n    stats = GenerationStats(\\n        model_name=\\\"baseline\\\",\\n        generated_tokens=generated,\\n        wall_time=elapsed,\\n        tokens_per_second=generated / max(elapsed, 1e-9),\\n        temperature=temperature,\\n        gamma=1,\\n        target_forward_calls=runner.forward_calls,\\n        draft_forward_calls=0,\\n    )\\n    return idx, stats\\n\\n\\n@torch.no_grad()\\ndef speculative_sampling(\\n    target_model: GPTLite,\\n    draft_model: GPTLite,\\n    prompt: torch.Tensor,\\n    max_new_tokens: int = 50,\\n    gamma: int = 4,\\n    temperature: float = 0.0,\\n    seed: int = 0,\\n):\\n    target_runner = ModelRunner(target_model, \\\"target\\\")\\n    draft_runner = ModelRunner(draft_model, \\\"draft\\\")\\n    tape = SamplingTape(SeedController(seed, prompt.device))\\n\\n    idx = prompt.clone()\\n    _, target_cache = target_runner.prefill(idx)\\n    _, draft_cache = draft_runner.prefill(idx)\\n\\n    generated = 0\\n    accepted = 0\\n    proposed = 0\\n\\n    if torch.cuda.is_available() and prompt.device.type == \\\"cuda\\\":\\n        torch.cuda.synchronize()\\n    start = time.time()\\n\\n    while generated < max_new_tokens:\\n        steps = min(gamma, max_new_tokens - generated)\\n\\n        base_draft_len = draft_cache.length\\n        draft_tokens = []\\n        draft_probs_per_step = []\\n        draft_context = idx\\n        work_draft_cache = draft_cache.clone()\\n\\n        for step in range(steps):\\n            if step == 0:\\n                draft_logits, work_draft_cache = draft_runner.decode(draft_context[:, -1:], work_draft_cache)\\n            else:\\n                draft_logits, work_draft_cache = draft_runner.decode(draft_tokens[-1], work_draft_cache)\\n            draft_last_logits = draft_logits[:, -1, :]\\n            sampled_token, draft_probs = tape.sample_from_logits(draft_last_logits, temperature)\\n            draft_tokens.append(sampled_token)\\n            draft_probs_per_step.append(draft_probs)\\n\\n        proposal = torch.cat(draft_tokens, dim=1)\\n        proposed += proposal.size(1)\\n\\n        target_logits, verified_target_cache = target_runner.decode(proposal, target_cache.clone())\\n        target_probs_per_step = [\\n            tape.probs_from_logits(target_logits[:, i, :], temperature) for i in range(proposal.size(1))\\n        ]\\n\\n        reject_at = None\\n        replacement_token = None\\n\\n        for i in range(proposal.size(1)):\\n            token_id = int(proposal[0, i].item())\\n            draft_prob = float(draft_probs_per_step[i][0, token_id].item())\\n            target_prob = float(target_probs_per_step[i][0, token_id].item())\\n            if temperature <= 0:\\n                accept_prob = 1.0 if token_id == int(torch.argmax(target_probs_per_step[i], dim=-1).item()) else 0.0\\n            else:\\n                accept_prob = 1.0 if draft_prob <= target_prob else max(0.0, min(1.0, target_prob / max(draft_prob, 1e-12)))\\n            u_accept = tape.rng.uniform()\\n            if u_accept <= accept_prob:\\n                accepted += 1\\n                continue\\n            reject_at = i\\n            corrected = tape.corrected_distribution(target_probs_per_step[i], draft_probs_per_step[i])\\n            replacement_token = tape.sample_from_probs(corrected)\\n            break\\n\\n        if reject_at is None:\\n            idx = torch.cat([idx, proposal], dim=1)\\n            generated += proposal.size(1)\\n            target_cache = verified_target_cache\\n            draft_cache = work_draft_cache\\n\\n            if generated < max_new_tokens:\\n                final_logits, target_cache = target_runner.decode(proposal[:, -1:], target_cache)\\n                last_target_probs = tape.probs_from_logits(final_logits[:, -1, :], temperature)\\n                bonus_token = tape.sample_from_probs(last_target_probs)\\n                idx = torch.cat([idx, bonus_token], dim=1)\\n                generated += 1\\n\\n                draft_cache.rollback(base_draft_len)\\n                replay_tokens = torch.cat([proposal, bonus_token], dim=1)\\n                replay_logits, draft_cache = draft_runner.decode(replay_tokens, draft_cache)\\n                _ = replay_logits\\n        else:\\n            accepted_prefix = proposal[:, :reject_at]\\n            if accepted_prefix.numel() > 0:\\n                idx = torch.cat([idx, accepted_prefix], dim=1)\\n                generated += accepted_prefix.size(1)\\n            idx = torch.cat([idx, replacement_token], dim=1)\\n            generated += 1\\n\\n            keep_target_len = target_cache.length + reject_at + 1\\n            target_cache = verified_target_cache\\n            target_cache.rollback(keep_target_len)\\n\\n            draft_cache.rollback(base_draft_len)\\n            replay_tokens = torch.cat([accepted_prefix, replacement_token], dim=1)\\n            if replay_tokens.numel() > 0:\\n                replay_logits, draft_cache = draft_runner.decode(replay_tokens, draft_cache)\\n                _ = replay_logits\\n\\n    if torch.cuda.is_available() and prompt.device.type == \\\"cuda\\\":\\n        torch.cuda.synchronize()\\n    elapsed = time.time() - start\\n    stats = GenerationStats(\\n        model_name=\\\"speculative\\\",\\n        generated_tokens=max_new_tokens,\\n        wall_time=elapsed,\\n        tokens_per_second=max_new_tokens / max(elapsed, 1e-9),\\n        temperature=temperature,\\n        gamma=gamma,\\n        accepted_tokens=accepted,\\n        proposed_tokens=proposed,\\n        acceptance_rate=accepted / max(proposed, 1),\\n        target_forward_calls=target_runner.forward_calls,\\n        draft_forward_calls=draft_runner.forward_calls,\\n    )\\n    return idx[:, : prompt.size(1) + max_new_tokens], stats\\n\\n\\n\\ndef run_distribution_check(device: str = None, seed: int = 2025, max_new_tokens: int = 32, gamma: int = 4, temperature: float = 0.8):\\n    device = device or get_default_device()\\n    prompt = make_prompt(device=device, seed=seed)\\n    target = load_target_model(device)\\n    draft = load_draft_model(device)\\n    baseline_out, baseline_stats = autoregressive_sampling(target, prompt, max_new_tokens=max_new_tokens, temperature=temperature, seed=seed)\\n    spec_out, spec_stats = speculative_sampling(target, draft, prompt, max_new_tokens=max_new_tokens, gamma=gamma, temperature=temperature, seed=seed)\\n    return {\\n        \\\"match\\\": torch.equal(baseline_out, spec_out),\\n        \\\"baseline_output\\\": baseline_out,\\n        \\\"spec_output\\\": spec_out,\\n        \\\"baseline_stats\\\": baseline_stats,\\n        \\\"spec_stats\\\": spec_stats,\\n    }\\n\\n\\n\\ndef benchmark(device: str = None, seed: int = 2025, prompt_len: int = 10, max_new_tokens: int = 40, gamma: int = 4, temperatures: Sequence[float] = (0.0, 0.4, 0.8, 1.2)):\\n    device = device or get_default_device()\\n    target = load_target_model(device)\\n    draft = load_draft_model(device)\\n    prompt = make_prompt(prompt_len=prompt_len, device=device, seed=seed)\\n    results = []\\n    for temp in temperatures:\\n        baseline_out, baseline_stats = autoregressive_sampling(target, prompt, max_new_tokens=max_new_tokens, temperature=float(temp), seed=seed)\\n        spec_out, spec_stats = speculative_sampling(target, draft, prompt, max_new_tokens=max_new_tokens, gamma=gamma, temperature=float(temp), seed=seed)\\n        results.append(\\n            {\\n                \\\"temperature\\\": float(temp),\\n                \\\"match\\\": torch.equal(baseline_out, spec_out),\\n                \\\"baseline\\\": baseline_stats,\\n                \\\"speculative\\\": spec_stats,\\n                \\\"speedup\\\": spec_stats.tokens_per_second / max(baseline_stats.tokens_per_second, 1e-9),\\n            }\\n        )\\n    return results\\n\\n\\n\\ndef stats_to_dict(stats: GenerationStats):\\n    return {\\n        \\\"model_name\\\": stats.model_name,\\n        \\\"generated_tokens\\\": stats.generated_tokens,\\n        \\\"wall_time\\\": stats.wall_time,\\n        \\\"tokens_per_second\\\": stats.tokens_per_second,\\n        \\\"temperature\\\": stats.temperature,\\n        \\\"gamma\\\": stats.gamma,\\n        \\\"accepted_tokens\\\": stats.accepted_tokens,\\n        \\\"proposed_tokens\\\": stats.proposed_tokens,\\n        \\\"acceptance_rate\\\": stats.acceptance_rate,\\n        \\\"target_forward_calls\\\": stats.target_forward_calls,\\n        \\\"draft_forward_calls\\\": stats.draft_forward_calls,\\n    }\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    device = get_default_device()\\n    seed = 2025\\n    gamma = 4\\n    max_new_tokens = 40\\n    temperatures = [0.0, 0.4, 0.8, 1.2]\\n\\n    print(f\\\"Running on device={device}\\\")\\n    check = run_distribution_check(device=device, seed=seed, max_new_tokens=32, gamma=gamma, temperature=0.8)\\n    print(f\\\"Distribution check @ temperature=0.8, gamma={gamma}: match={check['match']}\\\")\\n    print(\\\"Baseline stats:\\\", stats_to_dict(check[\\\"baseline_stats\\\"]))\\n    print(\\\"Speculative stats:\\\", stats_to_dict(check[\\\"spec_stats\\\"]))\\n\\n    bench = benchmark(device=device, seed=seed, max_new_tokens=max_new_tokens, gamma=gamma, temperatures=temperatures)\\n    print(\\\"\\\\nBenchmark summary:\\\")\\n    for row in bench:\\n        print(\\n            {\\n                \\\"temperature\\\": row[\\\"temperature\\\"],\\n                \\\"match\\\": row[\\\"match\\\"],\\n                \\\"baseline_tps\\\": row[\\\"baseline\\\"].tokens_per_second,\\n                \\\"speculative_tps\\\": row[\\\"speculative\\\"].tokens_per_second,\\n                \\\"speedup\\\": row[\\\"speedup\\\"],\\n                \\\"acceptance_rate\\\": row[\\\"speculative\\\"].acceptance_rate,\\n            }\\n        )\\n\"}"
