                "name": "write",
                "arguments": "{\"path\": \"sift.py\", \"content\": \"#!/usr/bin/env python3\\n# -*- coding: utf-8 -*-\\n\\\"\\\"\\\"\\nComplete SIFT Implementation:\\n1) DoG keypoint detection (Gaussian pyramid + DoG + 3x3x3 extrema + contrast + edge suppression)\\n2) Orientation assignment (36-bin, Gaussian-weighted)\\n3) 128-D descriptor (4x4 cells x 8 bins, tri-linear interpolation, normalize -> clamp -> renormalize)\\n\\nOnly use: numpy, cv2\\n\\\"\\\"\\\"\\n\\nfrom typing import List, Tuple\\nimport numpy as np\\nimport cv2 as cv\\n\\nKeypoint = Tuple[float, float, float]                 # (x, y, sigma)\\nOrientedKeypoint = Tuple[float, float, float, float]  # (x, y, sigma, theta)\\n\\n# ----------------------------\\n# Utilities\\n# ----------------------------\\ndef to_gray_float01(image: np.ndarray) -> np.ndarray:\\n    \\\"\\\"\\\"Convert to grayscale float32 in [0,1].\\\"\\\"\\\"\\n    if image.ndim == 3:\\n        image = cv.cvtColor(image, cv.COLOR_BGR2GRAY)\\n    img = image.astype(np.float32)\\n    if img.max() > 1.0:\\n        img /= 255.0\\n    return img\\n\\ndef gaussian_blur(img: np.ndarray, sigma: float) -> np.ndarray:\\n    \\\"\\\"\\\"OpenCV Gaussian blur with sigma; ksize=(0,0) lets cv choose size.\\\"\\\"\\\"\\n    return cv.GaussianBlur(img, ksize=(0, 0), sigmaX=sigma, sigmaY=sigma, borderType=cv.BORDER_REPLICATE)\\n\\ndef gradient(img: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:\\n    \\\"\\\"\\\"Return (mag, ori in [0, 2pi)) using Sobel.\\\"\\\"\\\"\\n    gx = cv.Sobel(img, cv.CV_32F, 1, 0, ksize=1)\\n    gy = cv.Sobel(img, cv.CV_32F, 0, 1, ksize=1)\\n    mag = np.hypot(gx, gy)\\n    ori = np.mod(np.arctan2(gy, gx), 2.0 * np.pi)\\n    return mag, ori\\n\\n# ----------------------------\\n# 0) Build Gaussian pyramid & DoG\\n# ----------------------------\\ndef build_gaussian_pyramid(\\n    image: np.ndarray,\\n    sigma_base: float = 1.6,\\n    num_octaves: int = 4,\\n    num_scales: int = 3\\n) -> Tuple[List[List[np.ndarray]], List[List[float]]]:\\n    \\\"\\\"\\\"\\n    Build Gaussian pyramid for SIFT.\\n    \\n    Returns:\\n      gauss_pyr: list over octaves, each is list of Gaussian images (length s+3)\\n      sigmas:    list over octaves, each is list of absolute sigmas\\n    \\\"\\\"\\\"\\n    s = num_scales\\n    k = 2.0 ** (1.0 / s)  # Scale factor between consecutive levels\\n    \\n    gauss_pyr = []\\n    sigmas = []\\n    \\n    # Start with the base image\\n    current_image = image.copy()\\n    \\n    for octave in range(num_octaves):\\n        octave_gauss = []\\n        octave_sigmas = []\\n        \\n        # Compute sigma for first image in this octave\\n        if octave == 0:\\n            sigma = sigma_base\\n        else:\\n            sigma = sigma_base\\n        \\n        # Generate s+3 Gaussian images for this octave\\n        for i in range(s + 3):\\n            if i == 0 and octave == 0:\\n                # First image in first octave: blur the input\\n                blurred = gaussian_blur(current_image, sigma)\\n            elif i == 0:\\n                # First image in subsequent octaves: downsample previous octave's image\\n                # Then apply base sigma blur\\n                current_image = cv.pyrDown(current_image)\\n                blurred = gaussian_blur(current_image, sigma)\\n            else:\\n                # Subsequent images: increase sigma\\n                sigma = sigma * k\\n                blurred = gaussian_blur(current_image, sigma)\\n            \\n            octave_gauss.append(blurred)\\n            octave_sigmas.append(sigma)\\n        \\n        gauss_pyr.append(octave_gauss)\\n        sigmas.append(octave_sigmas)\\n        \\n        # Update current_image for next octave (use the last blurred image before downsampling)\\n        current_image = octave_gauss[-3]  # Use the image before the last two\\n    \\n    return gauss_pyr, sigmas\\n\\ndef build_dog_pyramid(gauss_pyr: List[List[np.ndarray]]) -> List[List[np.ndarray]]:\\n    \\\"\\\"\\\"\\n    Build DoG pyramid by subtracting adjacent Gaussian images.\\n    \\n    Returns:\\n      dog_pyr: list over octaves, each is list of DoG images (length s+2)\\n    \\\"\\\"\\\"\\n    dog_pyr = []\\n    \\n    for octave in range(len(gauss_pyr)):\\n        octave_dog = []\\n        gauss_octave = gauss_pyr[octave]\\n        \\n        # Subtract adjacent Gaussian images\\n        for i in range(len(gauss_octave) - 1):\\n            dog = gauss_octave[i + 1] - gauss_octave[i]\\n            octave_dog.append(dog)\\n        \\n        dog_pyr.append(octave_dog)\\n    \\n    return dog_pyr\\n\\n# ----------------------------\\n# 1) DoG keypoint detection\\n# ----------------------------\\ndef is_extremum(dog_pyr: List[List[np.ndarray]], octave: int, scale: int, y: int, x: int) -> bool:\\n    \\\"\\\"\\\"Check if pixel is a 3x3x3 extremum in DoG pyramid.\\\"\\\"\\\"\\n    dog = dog_pyr[octave][scale]\\n    h, w = dog.shape\\n    center_val = dog[y, x]\\n    \\n    # Check if maximum or minimum\\n    is_max = True\\n    is_min = True\\n    \\n    # Check all 26 neighbors (9 in each of 3 scales, minus center)\\n    for ds in [-1, 0, 1]:\\n        for dy in [-1, 0, 1]:\\n            for dx in [-1, 0, 1]:\\n                if ds == 0 and dy == 0 and dx == 0:\\n                    continue\\n                \\n                ns = scale + ds\\n                ny, nx = y + dy, x + dx\\n                \\n                if ns < 0 or ns >= len(dog_pyr[octave]):\\n                    return False\\n                if ny < 0 or ny >= h or nx < 0 or nx >= w:\\n                    return False\\n                \\n                neighbor_val = dog_pyr[octave][ns][ny, nx]\\n                \\n                if neighbor_val > center_val:\\n                    is_max = False\\n                if neighbor_val < center_val:\\n                    is_min = False\\n    \\n    return is_max or is_min\\n\\ndef compute_hessian_ratio(dog: np.ndarray, y: int, x: int) -> Tuple[float, float, float]:\\n    \\\"\\\"\\\"\\n    Compute Hessian matrix and edge response ratio.\\n    \\n    Returns: (trace^2/det, det, trace)\\n    \\\"\\\"\\\"\\n    # Compute second derivatives using finite differences\\n    dxx = dog[y, x+1] + dog[y, x-1] - 2 * dog[y, x]\\n    dyy = dog[y+1, x] + dog[y-1, x] - 2 * dog[y, x]\\n    dxy = (dog[y+1, x+1] - dog[y+1, x-1] - dog[y-1, x+1] + dog[y-1, x-1]) / 4.0\\n    \\n    trace = dxx + dyy\\n    det = dxx * dyy - dxy * dxy\\n    \\n    if det <= 0:\\n        return float('inf'), det, trace\\n    \\n    ratio = (trace * trace) / det\\n    return ratio, det, trace\\n\\ndef detect_dog_keypoints(\\n    image: np.ndarray,\\n    sigma: float = 1.6,\\n    num_octaves: int = 4,\\n    num_scales: int = 3,\\n    contrast_thresh: float = 0.03,\\n    edge_r: float = 10.0\\n) -> List[Keypoint]:\\n    \\\"\\\"\\\"\\n    Detect keypoints using DoG pyramid.\\n    \\n    Returns list of (x, y, sigma)\\n    \\\"\\\"\\\"\\n    # Build pyramids\\n    gauss_pyr, sigmas = build_gaussian_pyramid(image, sigma, num_octaves, num_scales)\\n    dog_pyr = build_dog_pyramid(gauss_pyr)\\n    \\n    s = num_scales\\n    keypoints = []\\n    \\n    edge_thresh = (edge_r + 1) ** 2 / edge_r  # Typically 12.1 for r=10\\n    \\n    for octave in range(len(dog_pyr)):\\n        dog_octave = dog_pyr[octave]\\n        \\n        # Skip first and last scale (need neighbors in scale dimension)\\n        for scale in range(1, len(dog_octave) - 1):\\n            dog = dog_octave[scale]\\n            h, w = dog.shape\\n            \\n            # Skip border pixels\\n            for y in range(1, h - 1):\\n                for x in range(1, w - 1):\\n                    # Check if extremum\\n                    if not is_extremum(dog_pyr, octave, scale, y, x):\\n                        continue\\n                    \\n                    # Contrast threshold\\n                    dog_val = abs(dog[y, x])\\n                    if dog_val < contrast_thresh:\\n                        continue\\n                    \\n                    # Edge suppression\\n                    ratio, det, trace = compute_hessian_ratio(dog, y, x)\\n                    if ratio > edge_thresh:\\n                        continue\\n                    \\n                    # Compute scale-space coordinates\\n                    # Account for octave downsampling\\n                    scale_factor = 2.0 ** octave\\n                    kp_x = x * scale_factor\\n                    kp_y = y * scale_factor\\n                    \\n                    # Get sigma for this scale\\n                    kp_sigma = sigmas[octave][scale + 1] * scale_factor\\n                    \\n                    keypoints.append((kp_x, kp_y, kp_sigma))\\n    \\n    return keypoints\\n\\n# ----------------------------\\n# 2) Orientation assignment\\n# ----------------------------\\ndef compute_keypoint_orientation(\\n    image: np.ndarray,\\n    keypoints: List[Keypoint],\\n    sigma_ori_mul: float = 1.5,\\n    num_bins: int = 36\\n) -> List[OrientedKeypoint]:\\n    \\\"\\\"\\\"\\n    Assign orientations to keypoints.\\n    \\n    Returns list of (x, y, sigma, theta in radians)\\n    \\\"\\\"\\\"\\n    oriented_keypoints = []\\n    bin_width = 2.0 * np.pi / num_bins\\n    \\n    # Pre-compute gradients for the entire image\\n    mag, ori = gradient(image)\\n    \\n    for (x, y, sigma) in keypoints:\\n        x, y = int(round(x)), int(round(y))\\n        \\n        # Window radius\\n        radius = int(round(3 * sigma))\\n        sigma_ori = sigma_ori_mul * sigma\\n        \\n        # Create orientation histogram\\n        hist = np.zeros(num_bins)\\n        \\n        # Accumulate weighted gradient orientations\\n        for dy in range(-radius, radius + 1):\\n            for dx in range(-radius, radius + 1):\\n                px, py = x + dx, y + dy\\n                \\n                # Check bounds\\n                if py < 0 or py >= mag.shape[0] or px < 0 or px >= mag.shape[1]:\\n                    continue\\n                \\n                # Gaussian weight\\n                dist_sq = dx * dx + dy * dy\\n                weight = np.exp(-dist_sq / (2 * sigma_ori * sigma_ori))\\n                \\n                # Get gradient info\\n                grad_mag = mag[py, px]\\n                grad_ori = ori[py, px]\\n                \\n                # Find bin\\n                bin_idx = int(grad_ori / bin_width) % num_bins\\n                \\n                # Accumulate\\n                hist[bin_idx] += weight * grad_mag\\n        \\n        # Smooth histogram (simple circular smoothing)\\n        for _ in range(6):  # 6 passes of smoothing\\n            prev = hist[-1]\\n            for i in range(num_bins):\\n                next_val = hist[(i + 1) % num_bins]\\n                hist[i] = (prev + hist[i] * 2 + next_val) / 4.0\\n                prev = next_val if i < num_bins - 1 else hist[0]\\n        \\n        # Find peaks\\n        max_val = hist.max()\\n        peak_thresh = 0.8 * max_val\\n        \\n        # Find all peaks above threshold\\n        for i in range(num_bins):\\n            prev = hist[(i - 1) % num_bins]\\n            curr = hist[i]\\n            next_val = hist[(i + 1) % num_bins]\\n            \\n            if curr > prev and curr > next_val and curr >= peak_thresh:\\n                # Parabolic interpolation for sub-bin accuracy\\n                delta = 0.5 * (prev - next_val) / (prev - 2 * curr + next_val) if (prev - 2 * curr + next_val) != 0 else 0\\n                theta = (i + delta) * bin_width\\n                \\n                oriented_keypoints.append((x, y, sigma, theta))\\n        \\n        # Ensure at least one orientation\\n        if len(oriented_keypoints) == 0 or oriented_keypoints[-1][0] != x:\\n            max_bin = hist.argmax()\\n            theta = max_bin * bin_width\\n            oriented_keypoints.append((x, y, sigma, theta))\\n    \\n    return oriented_keypoints\\n\\n# ----------------------------\\n# 3) 128-D SIFT descriptor\\n# ----------------------------\\ndef compute_sift_descriptor(\\n    image: np.ndarray,\\n    oriented_keypoints: List[OrientedKeypoint],\\n    grid_size: int = 4,\\n    bin_per_cell: int = 8\\n) -> np.ndarray:\\n    \\\"\\\"\\\"\\n    Compute 128-D SIFT descriptors.\\n    \\n    Returns: (N, 128) float32 array\\n    \\\"\\\"\\\"\\n    descriptors = []\\n    \\n    # Pre-compute gradients\\n    mag, ori = gradient(image)\\n    h, w = image.shape\\n    \\n    # Descriptor parameters\\n    desc_width = grid_size * 4  # 16 pixels\\n    bin_width = 2.0 * np.pi / bin_per_cell\\n    \\n    for (x, y, sigma, theta) in oriented_keypoints:\\n        # Scale factor for sampling\\n        scale = sigma\\n        \\n        # Create descriptor histogram (4x4x8 = 128 bins)\\n        desc_hist = np.zeros((grid_size, grid_size, bin_per_cell))\\n        \\n        # Sample region around keypoint\\n        # Rotate coordinates by -theta to achieve rotation invariance\\n        cos_t = np.cos(-theta)\\n        sin_t = np.sin(-theta)\\n        \\n        # Gaussian weight for descriptor window\\n        desc_sigma = grid_size * 2  # 8 pixels\\n        weight_factor = -0.5 / (desc_sigma * desc_sigma)\\n        \\n        for py in range(-desc_width // 2, desc_width // 2):\\n            for px in range(-desc_width // 2, desc_width // 2):\\n                # Rotate sample point\\n                rx = px * cos_t - py * sin_t\\n                ry = px * sin_t + py * cos_t\\n                \\n                # Image coordinates\\n                ix = int(round(x + rx * scale))\\n                iy = int(round(y + ry * scale))\\n                \\n                # Check bounds\\n                if iy < 0 or iy >= h or ix < 0 or ix >= w:\\n                    continue\\n                \\n                # Get gradient at sample point\\n                grad_mag = mag[iy, ix]\\n                grad_ori = ori[iy, ix]\\n                \\n                # Rotate gradient orientation by -theta\\n                grad_ori_rot = (grad_ori - theta) % (2 * np.pi)\\n                \\n                # Gaussian weight\\n                dist_sq = px * px + py * py\\n                weight = np.exp(dist_sq * weight_factor)\\n                \\n                # Orientation bin (with interpolation)\\n                bin_pos = grad_ori_rot / bin_width\\n                bin_idx = int(bin_pos) % bin_per_cell\\n                bin_frac = bin_pos - int(bin_pos)\\n                \\n                # Cell coordinates (with interpolation)\\n                # Map from [-8, 8] to [0, 4] cell indices\\n                cell_x = (px + desc_width // 2) / 4.0\\n                cell_y = (py + desc_width // 2) / 4.0\\n                \\n                cx = int(cell_x)\\n                cy = int(cell_y)\\n                cx_frac = cell_x - cx\\n                cy_frac = cell_y - cy\\n                \\n                # Tri-linear interpolation\\n                contrib = grad_mag * weight\\n                \\n                # Distribute to neighboring cells and bins\\n                for dx in [0, 1]:\\n                    for dy in [0, 1]:\\n                        nx, ny = cx + dx, cy + dy\\n                        if nx >= grid_size or ny >= grid_size:\\n                            continue\\n                        \\n                        cell_weight = (1 - dx * cx_frac - (1 - dx) * (1 - cx_frac)) * \\\\\\n                                     (1 - dy * cy_frac - (1 - dy) * (1 - cy_frac))\\n                        \\n                        # Distribute to orientation bins\\n                        for db in [0, 1]:\\n                            nb = (bin_idx + db) % bin_per_cell\\n                            bin_weight = 1 - db * bin_frac - (1 - db) * (1 - bin_frac)\\n                            \\n                            desc_hist[ny, nx, nb] += contrib * cell_weight * bin_weight\\n        \\n        # Flatten and normalize\\n        desc_vec = desc_hist.flatten()\\n        \\n        # L2 normalize\\n        norm = np.linalg.norm(desc_vec)\\n        if norm > 0:\\n            desc_vec /= norm\\n        \\n        # Clamp to 0.2 and renormalize\\n        desc_vec = np.clip(desc_vec, 0, 0.2)\\n        norm = np.linalg.norm(desc_vec)\\n        if norm > 0:\\n            desc_vec /= norm\\n        \\n        descriptors.append(desc_vec)\\n    \\n    return np.array(descriptors, dtype=np.float32)\\n\\ndef main():\\n    import argparse\\n    ap = argparse.ArgumentParser()\\n    ap.add_argument(\\\"--image\\\", type=str, required=True)\\n    args = ap.parse_args()\\n\\n    img0 = cv.imread(args.image, cv.IMREAD_GRAYSCALE)\\n    assert img0 is not None, \\\"Failed to load image\\\"\\n    img = to_gray_float01(img0)\\n\\n    print(\\\"Building Gaussian pyramid and detecting keypoints...\\\")\\n    kps = detect_dog_keypoints(img)\\n    print(f\\\"Detected {len(kps)} keypoints\\\")\\n\\n    print(\\\"Computing orientations...\\\")\\n    okps = compute_keypoint_orientation(img, kps)\\n    print(f\\\"Generated {len(okps)} oriented keypoints\\\")\\n\\n    print(\\\"Computing descriptors...\\\")\\n    desc = compute_sift_descriptor(img, okps)\\n    print(f\\\"Descriptor shape: {desc.shape}\\\")\\n\\n    # Visualization\\n    vis = cv.cvtColor((img * 255).astype(np.uint8), cv.COLOR_GRAY2BGR)\\n    for (x, y, s, th) in okps[:300]:  # Draw at most 300\\n        p = (int(round(x)), int(round(y)))\\n        # Scale orientation line by sigma for visibility\\n        line_len = max(5, int(s))\\n        q = (int(round(x + line_len * np.cos(th))), int(round(y + line_len * np.sin(th))))\\n        cv.circle(vis, p, max(1, int(s/2)), (0, 255, 0), -1)\\n        cv.line(vis, p, q, (0, 0, 255), 1)\\n    \\n    cv.imwrite(\\\"sift_keypoints_vis.png\\\", vis)\\n    print(\\\"Saved: sift_keypoints_vis.png\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\"}"
