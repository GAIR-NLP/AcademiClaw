# =============================================================================
# Query 3 专属 Dockerfile - 中国车牌识别系统
# 
# 任务需求：Python环境 + OpenCV + OCR + GUI库
# =============================================================================

# 使用 sandbox 基础镜像
FROM agencybench-sandbox

# =============================================================================
# 元数据
# =============================================================================

LABEL query="T10_zh_chepai_shibie"
LABEL task="中国车牌识别系统"

# =============================================================================
# 任务特定依赖
# =============================================================================

# 切换到 pypi 官方源（阿里云源经常超时）
RUN pip3 config set global.index-url https://pypi.org/simple/ && pip3 config set global.timeout 300

# 安装图像处理和 OCR 相关依赖
RUN pip install --no-cache-dir \
    opencv-python-headless \
    Pillow \
    numpy \
    paddlepaddle \
    paddleocr \
    easyocr \
    hyperlpr3

# 安装 GUI 库（用于代码检查，实际运行需要显示环境）
RUN apt-get update && apt-get install -y python3-tk && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir \
    PyQt5==5.15.10 \
    gradio==4.7.1

# 说明：此 Dockerfile 配置了 OCR 和图像处理环境
# 由于 Docker 环境通常没有显示器，GUI 程序可能无法完全测试
# 评估主要基于代码审查和可选的识别结果文件

# 注意：PaddleOCR 首次使用会自动下载模型文件
# 如果需要离线环境，请提前下载模型并挂载到容器中

# =============================================================================
# 工作目录
# =============================================================================

WORKDIR /agencybench

# =============================================================================
# 命令
# =============================================================================

CMD []
