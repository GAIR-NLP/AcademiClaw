igned char)(255 * clamp(0, 1, framebuffer[i].y));  \n        color[2] = (unsigned char)(255 * clamp(0, 1, framebuffer[i].z));  \n        fwrite(color, 1, 3, fp);  \n    }  \n    fclose(fp);      \n}  \n",
