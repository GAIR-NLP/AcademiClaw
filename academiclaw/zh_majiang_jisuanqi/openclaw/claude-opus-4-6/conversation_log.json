i/noten.\\n     *\\n     * Also need to consider: if dealer (North) is tenpai, the game continues (連荘).\\n     */\\n    static void calculateDrawBranches(StringBuilder sb) {\\n        sb.append(\\\"【听牌分支一览】\\\\n\\\");\\n\\n        // All 16 combinations\\n        for (int mask = 0; mask < 16; mask++) {\\n            boolean[] tenpai = new boolean[4];\\n            int tenpaiCount = 0;\\n            for (int i = 0; i < 4; i++) {\\n                tenpai[i] = ((mask >> i) & 1) == 1;\\n                if (tenpai[i]) tenpaiCount++;\\n            }\\n\\n            // Compute scores after tenpai payment\\n            int[] finalScores = currentScores.clone();\\n            if (tenpaiCount > 0 && tenpaiCount < 4) {\\n                int notenCount = 4 - tenpaiCount;\\n                // Each noten pays 3000/notenCount, each tenpai receives 3000/tenpaiCount\\n                // But standard: total 3000 from noten side, distributed to tenpai side\\n                int tenpaiReceive = 3000 / tenpaiCount;\\n                int notenPay = 3000 / notenCount;\\n                for (int i = 0; i < 4; i++) {\\n                    if (tenpai[i]) {\\n                        finalScores[i] += tenpaiReceive;\\n                    } else {\\n                        finalScores[i] -= notenPay;\\n                    }\\n                }\\n            }\\n            // All tenpai or all noten: no payment change\\n\\n            // Kyotaku stays on the table for draws, but if it's the very end (game over),\\n            // kyotaku goes to 1st place\\n            // The game ends if dealer is noten (in a last-dealer scenario where dealer=North).\\n            // If dealer is tenpai, game continues (連荘)\\n\\n            boolean dealerTenpai = tenpai[dealerIdx];\\n            boolean gameEnds = !dealerTenpai; // North dealer noten -> game ends\\n\\n            // Build description of this tenpai pattern\\n            String patternDesc = buildTenpaiDesc(tenpai, tenpaiCount);\\n\\n          