                  "name": "write",
                  "arguments": "{\"file_path\": \"/tmp/isolated_workspace_1091/MahjongPromoCalculator.java\", \"content\": \"import java.util.*;\\nimport java.io.*;\\n\\n/**\\n * 立直麻将晋级条件计算器\\n * Riichi Mahjong Promotion Condition Calculator\\n *\\n * Supports: M-League, A規 (JPML), WRC, 最高位戦 (Saikouisen)\\n */\\npublic class MahjongPromoCalculator {\\n\\n    // ============================================================\\n    // Data classes\\n    // ============================================================\\n\\n    static class Player {\\n        String name;\\n        double prePt;      // total pt before this hanchan\\n        int currentScore;  // current score in this hanchan (e.g. 48200)\\n        int seatWind;      // 0=East, 1=South, 2=West, 3=North\\n    }\\n\\n    static class RuleSet {\\n        String name;\\n        int startScore;     // 持ち点 (e.g. 25000)\\n        int returnScore;    // 返し点 (e.g. 30000)\\n        // uma[0..3] = 1位,2位,3位,4位 in 1000pt units (will be converted to pt)\\n        double[] uma;       // e.g. {+50, +10, -10, -30} for M-League\\n\\n        RuleSet(String name, int startScore, int returnScore, double[] uma) {\\n            this.name = name;\\n            this.startScore = startScore;\\n            this.returnScore = returnScore;\\n            this.uma = uma;\\n        }\\n    }\\n\\n    // ============================================================\\n    // Constants\\n    // ============================================================\\n\\n    static final Map<String, RuleSet> RULES = new LinkedHashMap<>();\\n    static {\\n        // M-League: 25000持ち/30000返し, 順位点 +50/+10/-10/-30 (千点=1p)\\n        RULES.put(\\\"M-LEAGUE\\\", new RuleSet(\\\"M-League\\\", 25000, 30000, new double[]{50, 10, -10, -30}));\\n        RULES.put(\\\"M-league\\\", new RuleSet(\\\"M-League\\\", 25000, 30000, new double[]{50, 10, -10, -30}));\\n\\n        // A規 (日本プロ麻雀連盟): 25000持ち/30000返し, 順位点 +12/+4/-4/-12\\n        RULES.put(\\\"A規\\\", new RuleSet(\\\"A規\\\", 25000, 30000, new double[]{12, 4, -4, -12}));\\n        RULES.put(\\\"A-RULE\\\", new RuleSet(\\\"A規\\\", 25000, 30000, new double[]{12, 4, -4, -12}));\\n\\n        // WRC: 25000持ち/30000返し, 順位点 +15/+5/-5/-15\\n        RULES.put(\\\"WRC\\\", new RuleSet(\\\"WRC\\\", 25000, 30000, new double[]{15, 5, -5, -15}));\\n\\n        // 最高位戦: 30000持ち/30000返し, 順位点 +10/+10/-10/-30 (ウマ 10000-30000)\\n        // Actually: 1位+30, 2位+10, 3位-10, 4位-30 (30000持ち30000返し, so oka=0)\\n        RULES.put(\\\"最高位戦\\\", new RuleSet(\\\"最高位戦\\\", 30000, 30000, new double[]{30, 10, -10, -30}));\\n        RULES.put(\\\"SAIKOUISEN\\\", new RuleSet(\\\"最高位戦\\\", 30000, 30000, new double[]{30, 10, -10, -30}));\\n    }\\n\\n    // Standard valid mahjong scores (子 Ron values)\\n    // We enumerate all possible point values for child ron / child tsumo / dealer ron / dealer tsumo\\n    // For the purpose of checking thresholds, we use standard point ladder\\n\\n    // Child ron scores\\n    static final int[] CHILD_RON = {\\n        1000, 1300, 1600, 2000, 2300, 2600, 2900, 3200, 3400, 3900,\\n        4500, 4800, 5200, 5800, 6400, 6800, 7100, 7700,\\n        8000,   // mangan\\n        12000,  // haneman\\n        16000,  // baiman\\n        24000,  // sanbaiman\\n        32000,  // yakuman\\n        64000,  // double yakuman\\n        96000   // triple yakuman\\n    };\\n\\n    // Child tsumo scores: {from_child, from_dealer}\\n    static final int[][] CHILD_TSUMO = {\\n        {300, 500}, {400, 700}, {400, 800}, {500, 1000},\\n        {600, 1200}, {700, 1300}, {700, 1300}, {800, 1600},\\n        {800, 1500}, {1000, 2000},\\n        {1200, 2300}, {1200, 2300}, {1300, 2600}, {1500, 2900},\\n        {1600, 3200}, {1600, 3200}, {1800, 3600}, {2000, 3900},\\n        {2000, 4000},   // mangan\\n        {3000, 6000},   // haneman\\n        {4000, 8000},   // baiman\\n        {6000, 12000},  // sanbaiman\\n        {8000, 16000},  // yakuman\\n        {16000, 32000}, // double yakuman\\n        {24000, 48000}  // triple yakuman\\n    };\\n\\n    // Dealer ron scores\\n    static final int[] DEALER_RON = {\\n        1500, 2000, 2400, 2900, 3400, 3900, 4400, 4800, 4800, 5800,\\n        6800, 7700, 7700, 8700, 9600, 9600, 10600, 11600,\\n        12000,  // mangan\\n        18000,  // haneman\\n        24000,  // baiman\\n        36000,  // sanbaiman\\n        48000,  // yakuman\\n        96000,  // double yakuman\\n        144000  // triple yakuman\\n    };\\n\\n    // Dealer tsumo scores: {from_each}\\n    static final int[] DEALER_TSUMO = {\\n        500, 700, 800, 1000, 1200, 1300, 1500, 1600, 1600, 2000,\\n        2300, 2600, 2600, 2900, 3200, 3200, 3600, 3900,\\n        4000,   // mangan\\n        6000,   // haneman\\n        8000,   // baiman\\n        12000,  // sanbaiman\\n        16000,  // yakuman\\n        32000,  // double yakuman\\n        48000   // triple yakuman\\n    };\\n\\n    // Standard child ron scores with labels for display\\n    static final String[] CHILD_RON_LABELS = {\\n        \\\"1000\\\", \\\"1300\\\", \\\"1600\\\", \\\"2000\\\", \\\"2300\\\", \\\"2600\\\", \\\"2900\\\", \\\"3200\\\", \\\"3400\\\", \\\"3900\\\",\\n        \\\"4500\\\", \\\"4800\\\", \\\"5200\\\", \\\"5800\\\", \\\"6400\\\", \\\"6800\\\", \\\"7100\\\", \\\"7700\\\",\\n        \\\"8000(満貫)\\\", \\\"12000(跳満)\\\", \\\"16000(倍満)\\\", \\\"24000(三倍満)\\\",\\n        \\\"32000(役満)\\\", \\\"64000(2倍役満)\\\", \\\"96000(3倍役満)\\\"\\n    };\\n\\n    // Names for score display\\n    static String childTsumoLabel(int idx) {\\n        return CHILD_TSUMO[idx][0] + \\\"・\\\" + CHILD_TSUMO[idx][1];\\n    }\\n\\n    static String dealerTsumoLabel(int idx) {\\n        return DEALER_TSUMO[idx] + \\\"all\\\";\\n    }\\n\\n    // Quick lookup: special score names\\n    static String scoreNameRon(int score, boolean isDealer) {\\n        if (isDealer) {\\n            if (score == 12000) return \\\"満貫\\\";\\n            if (score == 18000) return \\\"跳満\\\";\\n            if (score == 24000) return \\\"倍満\\\";\\n            if (score == 36000) return \\\"三倍満\\\";\\n            if (score == 48000) return \\\"役満\\\";\\n            if (score == 96000) return \\\"2倍役満\\\";\\n            if (score == 144000) return \\\"3倍役満\\\";\\n        } else {\\n            if (score == 8000) return \\\"満貫\\\";\\n            if (score == 12000) return \\\"跳満\\\";\\n            if (score == 16000) return \\\"倍満\\\";\\n            if (score == 24000) return \\\"三倍満\\\";\\n            if (score == 32000) return \\\"役満\\\";\\n            if (score == 64000) return \\\"2倍役満\\\";\\n            if (score == 96000) return \\\"3倍役満\\\";\\n        }\\n        return String.valueOf(score);\\n    }\\n\\n    static String scoreNameTsumo(int[] childTsumo) {\\n        return childTsumo[0] + \\\"・\\\" + childTsumo[1];\\n    }\\n\\n    static String scoreNameDealerTsumo(int dealerTsumo) {\\n        return dealerTsumo + \\\"all\\\";\\n    }\\n\\n    // ============================================================\\n    // Core Calculation\\n    // ============================================================\\n\\n    /**\\n     * Given final scores of 4 players, honba, kyotaku, and the ruleset,\\n     * compute the final pt (total pt) for each player.\\n     */\\n    static double[] computeFinalPt(int[] finalScores, RuleSet rule, int dealerSeat,\\n                                    double[] prePt, int kyotaku) {\\n        // First: determine ranking (1-based)\\n        // Ties broken by seat order from dealer: dealer > dealer's shimo > ...\\n        Integer[] indices = {0, 1, 2, 3};\\n        final int[] fs = finalScores;\\n        final int ds = dealerSeat;\\n        Arrays.sort(indices, (a, b) -> {\\n            if (fs[a] != fs[b]) return fs[b] - fs[a]; // higher score = better rank\\n            // same score: closer to east in this round is better\\n            // seat wind order from East(0) -> South(1) -> West(2) -> North(3)\\n            // but actually for tie-breaking, closer to 起家 (east=0) is better\\n            int seatA = a; // seat index\\n            int seatB = b;\\n            return seatA - seatB; // lower seat index = closer to East = better\\n        });\\n\\n        int[] rank = new int[4]; // 0-indexed rank (0 = 1st place)\\n        for (int i = 0; i < 4; i++) {\\n            rank[indices[i]] = i;\\n        }\\n\\n        double[] resultPt = new double[4];\\n        for (int i = 0; i < 4; i++) {\\n            double scorePt = (finalScores[i] - rule.returnScore) / 1000.0;\\n            double umaPt = rule.uma[rank[i]];\\n            resultPt[i] = prePt[i] + scorePt + umaPt;\\n        }\\n\\n        // Kyotaku (供托/リーチ棒 on table): goes to 1st place\\n        resultPt[indices[0]] += kyotaku; // kyotaku is in 1000-pt units already\\n\\n        return resultPt;\\n    }\\n\\n    /**\\n     * Determine rank ordering. Returns sorted indices (0-indexed), best first.\\n     * Ties broken by seat proximity to East (seat 0).\\n     */\\n    static Integer[] getRanking(int[] scores) {\\n        Integer[] indices = {0, 1, 2, 3};\\n        Arrays.sort(indices, (a, b) -> {\\n            if (scores[a] != scores[b]) return scores[b] - scores[a];\\n            return a - b;\\n        });\\n        return indices;\\n    }\\n\\n    /**\\n     * Check if player at index pi qualifies (is in top 'promoCount' positions)\\n     * given the final scores and rule.\\n     */\\n    static boolean qualifies(int pi, int[] finalScores, RuleSet rule,\\n                              double[] prePt, int kyotaku, int promoCount) {\\n        double[] finalPt = computeFinalPt(finalScores, rule, 0, prePt, kyotaku);\\n        // Rank by finalPt\\n        Integer[] indices = {0, 1, 2, 3};\\n        Arrays.sort(indices, (a, b) -> {\\n            if (finalPt[a] != finalPt[b]) return Double.compare(finalPt[b], finalPt[a]);\\n            return a - b;\\n        });\\n        for (int i = 0; i < promoCount; i++) {\\n            if (indices[i] == pi) return true;\\n        }\\n        return false;\\n    }\\n\\n    // ============================================================\\n    // Main Logic\\n    // ============================================================\\n\\n    static int[] currentScores;\\n    static Player[] players;\\n    static RuleSet rule;\\n    static int promoCount;\\n    static int honba;      // 本場数\\n    static int kyotaku;    // 供托数 (in 1000-pt units)\\n    static int dealerIdx;  // index of current dealer in players array\\n\\n    public static void main(String[] args) throws Exception {\\n        Scanner sc;\\n        if (args.length > 0) {\\n            sc = new Scanner(new File(args[0]), \\\"UTF-8\\\");\\n        } else {\\n            sc = new Scanner(System.in, \\\"UTF-8\\\");\\n        }\\n\\n        // Parse input\\n        players = new Player[4];\\n        currentScores = new int[4];\\n\\n        // Read lines\\n        List<String> lines = new ArrayList<>();\\n        while (sc.hasNextLine()) {\\n            String line = sc.nextLine().trim();\\n            if (!line.isEmpty()) lines.add(line);\\n        }\\n\\n        String dealerWind = \\\"\\\";\\n        String[] seatOrder = null;\\n        String[] names = null;\\n        double[] prePts = new double[4];\\n        int[] scores = new int[4];\\n        String ruleName = \\\"\\\";\\n\\n        for (String line : lines) {\\n            if (line.startsWith(\\\"当前亲家：\\\") || line.startsWith(\\\"当前亲家:\\\")) {\\n                dealerWind = line.split(\\\"[：:]\\\")[1].trim();\\n            } else if (line.startsWith(\\\"座次：\\\") || line.startsWith(\\\"座次:\\\")) {\\n                String rest = line.substring(line.indexOf('：') != -1 ? line.indexOf('：') + 1 : line.indexOf(':') + 1).trim();\\n                seatOrder = rest.split(\\\"\\\\\\\\s+\\\");\\n            } else if (line.startsWith(\\\"名字：\\\") || line.startsWith(\\\"名字:\\\")) {\\n                String rest = line.substring(line.indexOf('：') != -1 ? line.indexOf('：') + 1 : line.indexOf(':') + 1).trim();\\n                names = rest.split(\\\"\\\\\\\\s+\\\");\\n            } else if (line.startsWith(\\\"开始前总分\\\")) {\\n                String rest = line.substring(\\\"开始前总分\\\".length()).trim();\\n                String[] parts = rest.split(\\\"\\\\\\\\s+\\\");\\n                for (int i = 0; i < 4; i++) {\\n                    prePts[i] = Double.parseDouble(parts[i]);\\n                }\\n            } else if (line.startsWith(\\\"当前分数\\\")) {\\n                String rest = line.substring(\\\"当前分数\\\".length()).trim();\\n                String[] parts = rest.split(\\\"\\\\\\\\s+\\\");\\n                for (int i = 0; i < 4; i++) {\\n                    scores[i] = Integer.parseInt(parts[i]);\\n                }\\n            } else if (line.startsWith(\\\"晋级条件：\\\") || line.startsWith(\\\"晋级条件:\\\")) {\\n                promoCount = Integer.parseInt(line.split(\\\"[：:]\\\")[1].trim());\\n            } else if (line.startsWith(\\\"规则：\\\") || line.startsWith(\\\"规则:\\\")) {\\n                ruleName = line.split(\\\"[：:]\\\")[1].trim();\\n            } else if (line.startsWith(\\\"供托：\\\") || line.startsWith(\\\"供托:\\\")) {\\n                kyotaku = Integer.parseInt(line.split(\\\"[：:]\\\")[1].trim());\\n            } else if (line.startsWith(\\\"本场：\\\") || line.startsWith(\\\"本场:\\\")) {\\n                honba = Integer.parseInt(line.split(\\\"[：:]\\\")[1].trim());\\n            }\\n        }\\n\\n        // Lookup rule\\n        rule = RULES.get(ruleName);\\n        if (rule == null) {\\n            // Try case-insensitive\\n            for (Map.Entry<String, RuleSet> e : RULES.entrySet()) {\\n                if (e.getKey().equalsIgnoreCase(ruleName)) {\\n                    rule = e.getValue();\\n                    break;\\n                }\\n            }\\n        }\\n        if (rule == null) {\\n            System.err.println(\\\"未知规则: \\\" + ruleName);\\n            System.err.println(\\\"支持的规则: M-League, A規, WRC, 最高位戦\\\");\\n            return;\\n        }\\n\\n        // Map winds to indices\\n        Map<String, Integer> windMap = new HashMap<>();\\n        windMap.put(\\\"东\\\", 0); windMap.put(\\\"東\\\", 0);\\n        windMap.put(\\\"南\\\", 1);\\n        windMap.put(\\\"西\\\", 2);\\n        windMap.put(\\\"北\\\", 3);\\n\\n        // Build players\\n        dealerIdx = -1;\\n        for (int i = 0; i < 4; i++) {\\n            players[i] = new Player();\\n            players[i].name = names[i];\\n            players[i].prePt = prePts[i];\\n            players[i].currentScore = scores[i];\\n            players[i].seatWind = windMap.getOrDefault(seatOrder[i], i);\\n            currentScores[i] = scores[i];\\n\\n            if (seatOrder[i].equals(dealerWind)) {\\n                dealerIdx = i;\\n            }\\n        }\\n\\n        if (dealerIdx == -1) {\\n            System.err.println(\\\"Error: dealer wind not found in seat order\\\");\\n            return;\\n        }\\n\\n        // Check if dealer is North (北) -> this is the last possible hand\\n        boolean isNorthDealer = dealerWind.equals(\\\"北\\\");\\n\\n        // honba bonus per ron = 300 * honba, per tsumo = 100 * honba per player\\n\\n        // ============================================================\\n        // Calculate and output for each player\\n        // ============================================================\\n\\n        StringBuilder sb = new StringBuilder();\\n\\n        for (int pi = 0; pi < 4; pi++) {\\n            calculatePlayerConditions(pi, sb);\\n            sb.append(\\\"\\\\n\\\");\\n        }\\n\\n        // ============================================================\\n        // Tenpai branch analysis (流局16种)\\n        // ============================================================\\n        calculateDrawBranches(sb);\\n\\n        // Output\\n        System.out.print(sb.toString());\\n    }\\n\\n    /**\\n     * For a given player pi, calculate:\\n     * 1. Tsumo conditions\\n     * 2. Ron conditions (from each other player)\\n     * 3. Deal-in conditions (to each other player)\\n     * 4. Danger zones (third-party horizontal movement)\\n     */\\n    static void calculatePlayerConditions(int pi, StringBuilder sb) {\\n        boolean piIsDealer = (pi == dealerIdx);\\n\\n        sb.append(players[pi].name).append(\\\"晋级条件\\\\n\\\");\\n\\n        // 1. TSUMO conditions\\n        sb.append(\\\"自摸\\\\t\\\");\\n        List<String> tsumoResults = new ArrayList<>();\\n        if (piIsDealer) {\\n            // Dealer tsumo: each other pays dealerTsumo + 100*honba\\n            boolean found = false;\\n            for (int ti = 0; ti < DEALER_TSUMO.length; ti++) {\\n                int baseEach = DEALER_TSUMO[ti];\\n                int eachPay = baseEach + 100 * honba;\\n                int totalGain = eachPay * 3 + kyotaku * 1000;\\n\\n                int[] finalScores = currentScores.clone();\\n                for (int j = 0; j < 4; j++) {\\n                    if (j == pi) {\\n                        finalScores[j] += totalGain;\\n                    } else {\\n                        finalScores[j] -= eachPay;\\n                    }\\n                }\\n\\n                if (qualifies(pi, finalScores, rule, getPrePts(), kyotaku, promoCount)) {\\n                    if (!found) {\\n                        String label = scoreNameDealerTsumo(baseEach) + \\\"以上\\\";\\n                        sb.append(label);\\n                        found = true;\\n                    }\\n                    break;\\n                }\\n            }\\n            if (!found) {\\n                sb.append(\\\"无法通过自摸晋级\\\");\\n            }\\n        } else {\\n            // Child tsumo: other children pay [0], dealer pays [1], plus honba\\n            boolean found = false;\\n            for (int ti = 0; ti < CHILD_TSUMO.length; ti++) {\\n                int fromChild = CHILD_TSUMO[ti][0];\\n                int fromDealer = CHILD_TSUMO[ti][1];\\n                int childPay = fromChild + 100 * honba;\\n                int dealerPay = fromDealer + 100 * honba;\\n                int totalGain = childPay * 2 + dealerPay + kyotaku * 1000;\\n\\n                int[] finalScores = currentScores.clone();\\n                for (int j = 0; j < 4; j++) {\\n                    if (j == pi) {\\n                        finalScores[j] += totalGain;\\n                    } else if (j == dealerIdx) {\\n                        finalScores[j] -= dealerPay;\\n                    } else {\\n                        finalScores[j] -= childPay;\\n                    }\\n                }\\n\\n                if (qualifies(pi, finalScores, rule, getPrePts(), 0, promoCount)) {\\n                    if (!found) {\\n                        String label = scoreNameTsumo(CHILD_TSUMO[ti]) + \\\"以上\\\";\\n                        sb.append(label);\\n                        found = true;\\n                    }\\n                    break;\\n                }\\n            }\\n            if (!found) {\\n                sb.append(\\\"无法通过自摸晋级\\\");\\n            }\\n        }\\n        sb.append(\\\"\\\\n\\\");\\n\\n        // 2. RON conditions (荣和)\\n        sb.append(\\\"=============================\\\\n\\\");\\n        for (int vi = 0; vi < 4; vi++) {\\n            if (vi == pi) continue;\\n            boolean viIsDealer = (vi == dealerIdx);\\n            int[] ronScores = piIsDealer ? DEALER_RON : CHILD_RON;\\n\\n            boolean found = false;\\n            sb.append(players[vi].name).append(\\\"荣和\\\\t\\\");\\n            for (int ri = 0; ri < ronScores.length; ri++) {\\n                int baseRon = ronScores[ri];\\n                int totalRon = baseRon + 300 * honba + kyotaku * 1000;\\n\\n                int[] finalScores = currentScores.clone();\\n                finalScores[pi] += totalRon;\\n                finalScores[vi] -= (baseRon + 300 * honba);\\n\\n                if (qualifies(pi, finalScores, rule, getPrePts(), 0, promoCount)) {\\n                    String label = scoreNameRon(baseRon, piIsDealer) + \\\"以上\\\";\\n                    sb.append(label);\\n                    found = true;\\n                    break;\\n                }\\n            }\\n            if (!found) {\\n                sb.append(\\\"无法通过荣和晋级\\\");\\n            }\\n            sb.append(\\\"\\\\n\\\");\\n        }\\n\\n        // 3. DEAL-IN conditions (放铳): player pi deals in to each other player\\n        sb.append(\\\"=============================\\\\n\\\");\\n        for (int ai = 0; ai < 4; ai++) {\\n            if (ai == pi) continue;\\n            boolean aiIsDealer = (ai == dealerIdx);\\n            int[] ronScores = aiIsDealer ? DEALER_RON : CHILD_RON;\\n\\n            // We need to find the maximum deal-in that still lets pi qualify\\n            // Check from highest to lowest\\n            List<int[]> qualifyRanges = new ArrayList<>(); // pairs of [low_idx, high_idx]\\n            boolean prevQualified = false;\\n            int rangeStart = -1;\\n\\n            for (int ri = 0; ri < ronScores.length; ri++) {\\n                int baseRon = ronScores[ri];\\n                int totalLoss = baseRon + 300 * honba;\\n                int totalGainForAttacker = baseRon + 300 * honba + kyotaku * 1000;\\n\\n                int[] finalScores = currentScores.clone();\\n                finalScores[pi] -= totalLoss;\\n                finalScores[ai] += totalGainForAttacker;\\n\\n                boolean q = qualifies(pi, finalScores, rule, getPrePts(), 0, promoCount);\\n                if (q && !prevQualified) {\\n                    rangeStart = ri;\\n                }\\n                if (!q && prevQualified) {\\n                    qualifyRanges.add(new int[]{rangeStart, ri - 1});\\n                }\\n                prevQualified = q;\\n            }\\n            if (prevQualified) {\\n                qualifyRanges.add(new int[]{rangeStart, ronScores.length - 1});\\n            }\\n\\n            for (int[] range : qualifyRanges) {\\n                int low = range[0];\\n                int high = range[1];\\n                sb.append(\\\"对\\\").append(players[ai].name).append(\\\"放铳\\\\t\\\");\\n                if (low == 0 && high == ronScores.length - 1) {\\n                    // Any deal-in is fine\\n                    sb.append(\\\"任意点数\\\");\\n                } else if (low == 0) {\\n                    sb.append(scoreNameRon(ronScores[high], aiIsDealer) + \\\"以下\\\");\\n                } else if (high == ronScores.length - 1) {\\n                    sb.append(scoreNameRon(ronScores[low], aiIsDealer) + \\\"以上\\\");\\n                } else {\\n                    sb.append(scoreNameRon(ronScores[low], aiIsDealer) + \\\"以上\\\" +\\n                              scoreNameRon(ronScores[high], aiIsDealer) + \\\"以下\\\");\\n                }\\n                sb.append(\\\"\\\\n\\\");\\n            }\\n        }\\n\\n        // 4. Being tsumo'd conditions: someone else tsumos\\n        sb.append(\\\"=============================\\\\n\\\");\\n        for (int ai = 0; ai < 4; ai++) {\\n            if (ai == pi) continue;\\n            boolean aiIsDealer = (ai == dealerIdx);\\n            String dealerLabel = aiIsDealer ? \\\"亲家\\\" : \\\"\\\";\\n\\n            if (aiIsDealer) {\\n                // Dealer tsumo: everyone else pays equally\\n                List<int[]> qualifyRanges = new ArrayList<>();\\n                boolean prevQualified = false;\\n                int rangeStart = -1;\\n\\n                for (int ti = 0; ti < DEALER_TSUMO.length; ti++) {\\n                    int baseEach = DEALER_TSUMO[ti];\\n                    int eachPay = baseEach + 100 * honba;\\n                    int totalGain = eachPay * 3 + kyotaku * 1000;\\n\\n                    int[] finalScores = currentScores.clone();\\n                    for (int j = 0; j < 4; j++) {\\n                        if (j == ai) {\\n                            finalScores[j] += totalGain;\\n                        } else {\\n                            finalScores[j] -= eachPay;\\n                        }\\n                    }\\n\\n                    boolean q = qualifies(pi, finalScores, rule, getPrePts(), 0, promoCount);\\n                    if (q && !prevQualified) {\\n                        rangeStart = ti;\\n                    }\\n                    if (!q && prevQualified) {\\n                        qualifyRanges.add(new int[]{rangeStart, ti - 1});\\n                    }\\n                    prevQualified = q;\\n                }\\n                if (prevQualified) {\\n                    qualifyRanges.add(new int[]{rangeStart, DEALER_TSUMO.length - 1});\\n                }\\n\\n                for (int[] range : qualifyRanges) {\\n                    int low = range[0];\\n                    int high = range[1];\\n                    sb.append(\\\"被\\\").append(players[ai].name).append(dealerLabel).append(\\\"自摸\\\\t\\\");\\n                    if (low == 0 && high == DEALER_TSUMO.length - 1) {\\n                        sb.append(\\\"任意点数\\\");\\n                    } else if (low == 0) {\\n                        sb.append(scoreNameDealerTsumo(DEALER_TSUMO[high]) + \\\"以下\\\");\\n                    } else if (high == DEALER_TSUMO.length - 1) {\\n                        sb.append(scoreNameDealerTsumo(DEALER_TSUMO[low]) + \\\"以上\\\");\\n                    } else {\\n                        sb.append(scoreNameDealerTsumo(DEALER_TSUMO[low]) + \\\"以上\\\" +\\n                                  scoreNameDealerTsumo(DEALER_TSUMO[high]) + \\\"以下\\\");\\n                    }\\n                    sb.append(\\\"\\\\n\\\");\\n                }\\n            } else {\\n                // Child tsumo: pi pays childPay if pi != dealer, dealerPay if pi == dealer\\n                List<int[]> qualifyRanges = new ArrayList<>();\\n                boolean prevQualified = false;\\n                int rangeStart = -1;\\n\\n                for (int ti = 0; ti < CHILD_TSUMO.length; ti++) {\\n                    int fromChild = CHILD_TSUMO[ti][0];\\n                    int fromDealer = CHILD_TSUMO[ti][1];\\n                    int childPay = fromChild + 100 * honba;\\n                    int dealerPay = fromDealer + 100 * honba;\\n\\n                    int totalGain = childPay * 2 + dealerPay + kyotaku * 1000;\\n\\n                    int[] finalScores = currentScores.clone();\\n                    for (int j = 0; j < 4; j++) {\\n                        if (j == ai) {\\n                            finalScores[j] += totalGain;\\n                        } else if (j == dealerIdx) {\\n                            finalScores[j] -= dealerPay;\\n                        } else {\\n                            finalScores[j] -= childPay;\\n                        }\\n                    }\\n\\n                    boolean q = qualifies(pi, finalScores, rule, getPrePts(), 0, promoCount);\\n                    if (q && !prevQualified) {\\n                        rangeStart = ti;\\n                    }\\n                    if (!q && prevQualified) {\\n                        qualifyRanges.add(new int[]{rangeStart, ti - 1});\\n                    }\\n                    prevQualified = q;\\n                }\\n                if (prevQualified) {\\n                    qualifyRanges.add(new int[]{rangeStart, CHILD_TSUMO.length - 1});\\n                }\\n\\n                for (int[] range : qualifyRanges) {\\n                    int low = range[0];\\n                    int high = range[1];\\n                    sb.append(\\\"被\\\").append(players[ai].name).append(\\\"自摸\\\\t\\\");\\n                    if (low == 0 && high == CHILD_TSUMO.length - 1) {\\n                        sb.append(\\\"任意点数\\\");\\n                    } else if (low == 0) {\\n                        sb.append(scoreNameTsumo(CHILD_TSUMO[high]) + \\\"以下\\\");\\n                    } else if (high == CHILD_TSUMO.length - 1) {\\n                        sb.append(scoreNameTsumo(C