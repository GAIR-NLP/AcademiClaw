\n                    String highLabel = childTsumoLabel(CHILD_TSUMO[high]);\\n                    sb.append(formatTsumoRange(lowLabel, highLabel,\\n                        low == 0, high == CHILD_TSUMO.length - 1));\\n                    sb.append(\\\"\\\\n\\\");\\n                }\\n            }\\n        }\\n\\n        // ---- DANGER ZONES ----\\n        sb.append(\\\"\\\\n\\\");\\n        sb.append(players[pi].name).append(\\\"危险区间:\\\\n\\\");\\n\\n        // Check if pi currently qualifies (without any change)\\n        boolean baseQualify = qualifies(pi, currentScores, true);\\n\\n        if (baseQualify) {\\n            for (int ai = 0; ai < 4; ai++) {\\n                if (ai == pi) continue;\\n                for (int vi = 0; vi < 4; vi++) {\\n                    if (vi == pi || vi == ai) continue;\\n                    boolean aiIsDealer = (ai == dealerIdx);\\n                    int[] ronScores = aiIsDealer ? DEALER_RON : CHILD_RON;\\n\\n                    List<int[]> dangerRanges = findDangerRanges(pi, ai, vi, ronScores, aiIsDealer);\\n\\n                    for (int[] range : dangerRanges) {\\n                        int low = range[0];\\n                        int high = range[1];\\n                        sb.append(players[ai].name).append(\\\"点\\\").append(players[vi].name).append(\\\"\\\\t\\\");\\n                        sb.append(formatDangerRange(ronScores[low], ronScores[high],\\n                            low == 0, high == ronScores.length - 1, aiIsDealer));\\n                        sb.append(\\\"\\\\n\\\");\\n                    }\\n                }\\n            }\\n        }\\n    }\\n\\n    /**\\n     * Find index ranges where pi still qualifies when ai rons from vi (deal-in scenario).\\n     * isDealIn: if true, pi is dealing in to ai; if false, used for other calculations.\\n     */\\n    static List<int[]> findQualifyRanges(int pi, int ai, int[] ronScores, boolean piDealsIn) {\\n        List<int[]> ranges = new ArrayList<>();\\n   