                  "arguments": "{\"file_path\": \"/tmp/isolated_workspace_1091/MahjongPromoCalculator.java\", \"content\": \"import java.util.*;\\nimport java.io.*;\\n\\n/**\\n * 立直麻将晋级条件计算器\\n * Riichi Mahjong Promotion Condition Calculator\\n *\\n * Supports: M-League, A規 (JPML), WRC, 最高位戦 (Saikouisen)\\n *\\n * Usage: java MahjongPromoCalculator [input_file]\\n *        If no file specified, reads from stdin.\\n */\\npublic class MahjongPromoCalculator {\\n\\n    // ============================================================\\n    // Data classes\\n    // ============================================================\\n\\n    static class Player {\\n        String name;\\n        double prePt;      // cumulative pt before this hanchan\\n        int currentScore;  // current score in this hanchan\\n        int seatWind;      // 0=East, 1=South, 2=West, 3=North\\n    }\\n\\n    static class RuleSet {\\n        String name;\\n        int startScore;     // 持ち点\\n        int returnScore;    // 返し点\\n        double[] uma;       // 順位点 for 1st~4th (in pt units)\\n\\n        RuleSet(String n, int start, int ret, double[] u) {\\n            name = n; startScore = start; returnScore = ret; uma = u;\\n        }\\n    }\\n\\n    // ============================================================\\n    // Rule Sets\\n    // ============================================================\\n\\n    static final Map<String, RuleSet> RULES = new LinkedHashMap<>();\\n    static {\\n        RULES.put(\\\"m-league\\\", new RuleSet(\\\"M-League\\\", 25000, 30000, new double[]{50, 10, -10, -30}));\\n        RULES.put(\\\"a規\\\",      new RuleSet(\\\"A規\\\", 25000, 30000, new double[]{12, 4, -4, -12}));\\n        RULES.put(\\\"a-rule\\\",   new RuleSet(\\\"A規\\\", 25000, 30000, new double[]{12, 4, -4, -12}));\\n        RULES.put(\\\"a规\\\",      new RuleSet(\\\"A規\\\", 25000, 30000, new double[]{12, 4, -4, -12}));\\n        RULES.put(\\\"wrc\\\",      new RuleSet(\\\"WRC\\\", 25000, 30000, new double[]{15, 5, -5, -15}));\\n        RULES.put(\\\"最高位戦\\\",  new RuleSet(\\\"最高位戦\\\", 30000, 30000, new double[]{30, 10, -10, -30}));\\n        RULES.put(\\\"最高位战\\\",  new RuleSet(\\\"最高位戦\\\", 30000, 30000, new double[]{30, 10, -10, -30}));\\n        RULES.put(\\\"saikouisen\\\",new RuleSet(\\\"最高位戦\\\", 30000, 30000, new double[]{30, 10, -10, -30}));\\n    }\\n\\n    // ============================================================\\n    // Standard Mahjong Scores\\n    // ============================================================\\n\\n    // Child (子) Ron scores\\n    static final int[] CHILD_RON = {\\n        1000, 1300, 1600, 2000, 2300, 2600, 2900, 3200, 3400, 3900,\\n        4500, 4800, 5200, 5800, 6400, 6800, 7100, 7700,\\n        8000, 12000, 16000, 24000, 32000, 64000, 96000\\n    };\\n\\n    // Child Tsumo: {fromChild, fromDealer}\\n    static final int[][] CHILD_TSUMO = {\\n        {300, 500}, {400, 700}, {400, 800}, {500, 1000},\\n        {600, 1200}, {700, 1300}, {700, 1300}, {800, 1600},\\n        {800, 1500}, {1000, 2000},\\n        {1200, 2300}, {1200, 2300}, {1300, 2600}, {1500, 2900},\\n        {1600, 3200}, {1600, 3200}, {1800, 3600}, {2000, 3900},\\n        {2000, 4000}, {3000, 6000}, {4000, 8000},\\n        {6000, 12000}, {8000, 16000}, {16000, 32000}, {24000, 48000}\\n    };\\n\\n    // Dealer (親) Ron scores\\n    static final int[] DEALER_RON = {\\n        1500, 2000, 2400, 2900, 3400, 3900, 4400, 4800, 4800, 5800,\\n        6800, 7700, 7700, 8700, 9600, 9600, 10600, 11600,\\n        12000, 18000, 24000, 36000, 48000, 96000, 144000\\n    };\\n\\n    // Dealer Tsumo: {fromEach}\\n    static final int[] DEALER_TSUMO = {\\n        500, 700, 800, 1000, 1200, 1300, 1500, 1600, 1600, 2000,\\n        2300, 2600, 2600, 2900, 3200, 3200, 3600, 3900,\\n        4000, 6000, 8000, 12000, 16000, 32000, 48000\\n    };\\n\\n    // ============================================================\\n    // Label helpers\\n    // ============================================================\\n\\n    static String ronLabel(int score, boolean attackerIsDealer) {\\n        // Use special names for yakuman-level milestones\\n        if (attackerIsDealer) {\\n            switch (score) {\\n                case 48000: return \\\"役満\\\";\\n                case 96000: return \\\"2倍役满\\\";\\n                case 144000: return \\\"3倍役满\\\";\\n                default: return String.valueOf(score);\\n            }\\n        } else {\\n            switch (score) {\\n                case 32000: return \\\"役満\\\";\\n                case 64000: return \\\"2倍役满\\\";\\n                case 96000: return \\\"3倍役满\\\";\\n                default: return String.valueOf(score);\\n            }\\n        }\\n    }\\n\\n    static String childTsumoLabel(int[] ct) { return ct[0] + \\\"・\\\" + ct[1]; }\\n    static String dealerTsumoLabel(int dt) { return dt + \\\"all\\\"; }\\n\\n    // ============================================================\\n    // Global State\\n    // ============================================================\\n\\n    static int[] currentScores;\\n    static Player[] players;\\n    static RuleSet rule;\\n    static int promoCount;\\n    static int honba;\\n    static int kyotaku;\\n    static int dealerIdx;\\n\\n    // ============================================================\\n    // Core Calculation\\n    // ============================================================\\n\\n    static double[] computeFinalPt(int[] finalScores, double[] prePt, boolean kyotakuTo1st) {\\n        Integer[] indices = {0, 1, 2, 3};\\n        final int[] fs = finalScores;\\n        Arrays.sort(indices, (a, b) -> {\\n            if (fs[a] != fs[b]) return fs[b] - fs[a];\\n            return a - b;\\n        });\\n\\n        // Handle ties: share uma\\n        double[] umaAssign = new double[4];\\n        int i = 0;\\n        while (i < 4) {\\n            int j = i;\\n            while (j < 4 && fs[indices[j]] == fs[indices[i]]) j++;\\n            double sumUma = 0;\\n            for (int k = i; k < j; k++) sumUma += rule.uma[k];\\n            double avgUma = sumUma / (j - i);\\n            for (int k = i; k < j; k++) umaAssign[indices[k]] = avgUma;\\n            i = j;\\n        }\\n\\n        double[] result = new double[4];\\n        for (int p = 0; p < 4; p++) {\\n            result[p] = prePt[p] + (finalScores[p] - rule.returnScore) / 1000.0 + umaAssign[p];\\n        }\\n\\n        if (kyotakuTo1st && kyotaku > 0) {\\n            result[indices[0]] += kyotaku;\\n        }\\n        return result;\\n    }\\n\\n    static boolean qualifies(int pi, int[] finalScores, boolean isDraw) {\\n        double[] fp = computeFinalPt(finalScores, getPrePts(), isDraw);\\n        Integer[] idx = {0, 1, 2, 3};\\n        final double[] f = fp;\\n        Arrays.sort(idx, (a, b) -> {\\n            if (Math.abs(f[a] - f[b]) > 0.001) return Double.compare(f[b], f[a]);\\n            return a - b;\\n        });\\n        for (int i = 0; i < promoCount; i++) {\\n            if (idx[i] == pi) return true;\\n        }\\n        return false;\\n    }\\n\\n    static double[] getPrePts() {\\n        double[] pts = new double[4];\\n        for (int i = 0; i < 4; i++) pts[i] = players[i].prePt;\\n        return pts;\\n    }\\n\\n    // ============================================================\\n    // Main\\n    // ============================================================\\n\\n    public static void main(String[] args) throws Exception {\\n        Scanner sc = args.length > 0 ?\\n            new Scanner(new File(args[0]), \\\"UTF-8\\\") :\\n            new Scanner(System.in, \\\"UTF-8\\\");\\n\\n        players = new Player[4];\\n        currentScores = new int[4];\\n\\n        List<String> lines = new ArrayList<>();\\n        while (sc.hasNextLine()) {\\n            String line = sc.nextLine().trim();\\n            if (!line.isEmpty()) lines.add(line);\\n        }\\n\\n        String dealerWind = \\\"\\\";\\n        String[] seatOrder = null;\\n        String[] names = null;\\n        double[] prePts = new double[4];\\n        int[] scores = new int[4];\\n        String ruleName = \\\"\\\";\\n\\n        for (String line : lines) {\\n            if (line.startsWith(\\\"当前亲家\\\")) {\\n                dealerWind = line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim();\\n            } else if (line.startsWith(\\\"座次\\\")) {\\n                seatOrder = line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim().split(\\\"\\\\\\\\s+\\\");\\n            } else if (line.startsWith(\\\"名字\\\")) {\\n                names = line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim().split(\\\"\\\\\\\\s+\\\");\\n            } else if (line.startsWith(\\\"开始前总分\\\")) {\\n                String[] p = line.substring(\\\"开始前总分\\\".length()).trim().split(\\\"\\\\\\\\s+\\\");\\n                for (int i = 0; i < 4; i++) prePts[i] = Double.parseDouble(p[i]);\\n            } else if (line.startsWith(\\\"当前分数\\\")) {\\n                String[] p = line.substring(\\\"当前分数\\\".length()).trim().split(\\\"\\\\\\\\s+\\\");\\n                for (int i = 0; i < 4; i++) scores[i] = Integer.parseInt(p[i]);\\n            } else if (line.startsWith(\\\"晋级条件\\\")) {\\n                promoCount = Integer.parseInt(line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim());\\n            } else if (line.startsWith(\\\"规则\\\")) {\\n                ruleName = line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim();\\n            } else if (line.startsWith(\\\"供托\\\")) {\\n                kyotaku = Integer.parseInt(line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim());\\n            } else if (line.startsWith(\\\"本场\\\")) {\\n                honba = Integer.parseInt(line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim());\\n            }\\n        }\\n\\n        rule = RULES.get(ruleName.toLowerCase());\\n        if (rule == null) {\\n            System.err.println(\\\"未知规则: \\\" + ruleName);\\n            System.err.println(\\\"支持: M-League, A規, A规, WRC, 最高位戦, 最高位战\\\");\\n            return;\\n        }\\n\\n        Map<String, Integer> windMap = new HashMap<>();\\n        windMap.put(\\\"东\\\", 0); windMap.put(\\\"東\\\", 0);\\n        windMap.put(\\\"南\\\", 1); windMap.put(\\\"西\\\", 2); windMap.put(\\\"北\\\", 3);\\n\\n        dealerIdx = -1;\\n        for (int i = 0; i < 4; i++) {\\n            players[i] = new Player();\\n            players[i].name = names[i];\\n            players[i].prePt = prePts[i];\\n            players[i].currentScore = scores[i];\\n            players[i].seatWind = windMap.getOrDefault(seatOrder[i], i);\\n            currentScores[i] = scores[i];\\n            if (seatOrder[i].equals(dealerWind)) dealerIdx = i;\\n        }\\n\\n        if (dealerIdx == -1) {\\n            System.err.println(\\\"Error: 找不到亲家 '\\\" + dealerWind + \\\"'\\\");\\n            return;\\n        }\\n\\n        StringBuilder sb = new StringBuilder();\\n        for (int pi = 0; pi < 4; pi++) {\\n            calcPlayer(pi, sb);\\n            sb.append(\\\"\\\\n\\\");\\n        }\\n        calcDraw(sb);\\n        System.out.print(sb);\\n    }\\n\\n    // ============================================================\\n    // Player Conditions\\n    // ============================================================\\n\\n    static void calcPlayer(int pi, StringBuilder sb) {\\n        boolean piD = (pi == dealerIdx);\\n        sb.append(players[pi].name).append(\\\"晋级条件\\\\n\\\");\\n\\n        // 1. TSUMO\\n        sb.append(\\\"自摸\\\\t\\\");\\n        boolean found = false;\\n        if (piD) {\\n            for (int ti = 0; ti < DEALER_TSUMO.length; ti++) {\\n                int base = DEALER_TSUMO[ti];\\n                int pay = base + 100 * honba;\\n                int gain = pay * 3 + kyotaku * 1000;\\n                int[] fs = applyDealerTsumo(currentScores, pi, pay, gain);\\n                if (qualifies(pi, fs, false)) {\\n                    sb.append(dealerTsumoLabel(base)).append(\\\"以上\\\");\\n                    found = true; break;\\n                }\\n            }\\n        } else {\\n            for (int ti = 0; ti < CHILD_TSUMO.length; ti++) {\\n                int fc = CHILD_TSUMO[ti][0], fd = CHILD_TSUMO[ti][1];\\n                int cp = fc + 100 * honba, dp = fd + 100 * honba;\\n                int gain = cp * 2 + dp + kyotaku * 1000;\\n                int[] fs = applyChildTsumo(currentScores, pi, cp, dp, gain);\\n                if (qualifies(pi, fs, false)) {\\n                    sb.append(childTsumoLabel(CHILD_TSUMO[ti])).append(\\\"以上\\\");\\n                    found = true; break;\\n                }\\n            }\\n        }\\n        if (!found) sb.append(\\\"无法通过自摸晋级\\\");\\n        sb.append(\\\"\\\\n\\\");\\n\\n        // 2. RON from each opponent\\n        sb.append(\\\"=============================\\\\n\\\");\\n        for (int vi = 0; vi < 4; vi++) {\\n            if (vi == pi) continue;\\n            int[] ronArr = piD ? DEALER_RON : CHILD_RON;\\n            found = false;\\n            for (int ri = 0; ri < ronArr.length; ri++) {\\n                int base = ronArr[ri];\\n                int bonus = 300 * honba;\\n                int gain = base + bonus + kyotaku * 1000;\\n                int loss = base + bonus;\\n                int[] fs = applyRon(currentScores, pi, vi, gain, loss);\\n                if (qualifies(pi, fs, false)) {\\n                    sb.append(players[vi].name).append(\\\"荣和\\\\t\\\")\\n                      .append(ronLabel(base, piD)).append(\\\"以上\\\\n\\\");\\n                    found = true; break;\\n                }\\n            }\\n            if (!found) sb.append(players[vi].name).append(\\\"荣和\\\\t无法通过荣和晋级\\\\n\\\");\\n        }\\n\\n        // 3. DEAL-IN (放铳) to each opponent\\n        sb.append(\\\"=============================\\\\n\\\");\\n        for (int ai = 0; ai < 4; ai++) {\\n            if (ai == pi) continue;\\n            boolean aiD = (ai == dealerIdx);\\n            int[] ronArr = aiD ? DEALER_RON : CHILD_RON;\\n            List<int[]> ranges = findRanges(pi, ai, ronArr, aiD, true);\\n            for (int[] r : ranges) {\\n                sb.append(\\\"对\\\").append(players[ai].name).append(\\\"放铳\\\\t\\\");\\n                sb.append(fmtRange(ronArr, r[0], r[1], aiD));\\n                sb.append(\\\"\\\\n\\\");\\n            }\\n        }\\n\\n        // 4. Being tsumo'd\\n        sb.append(\\\"=============================\\\\n\\\");\\n        for (int ai = 0; ai < 4; ai++) {\\n            if (ai == pi) continue;\\n            boolean aiD = (ai == dealerIdx);\\n            String dm = aiD ? \\\"亲家\\\" : \\\"\\\";\\n\\n            if (aiD) {\\n                List<int[]> ranges = findDealerTsumoRanges(pi, ai);\\n                for (int[] r : ranges) {\\n                    sb.append(\\\"被\\\").append(players[ai].name).append(dm).append(\\\"自摸\\\\t\\\");\\n                    sb.append(fmtTsumoRange(r[0], r[1], true));\\n                    sb.append(\\\"\\\\n\\\");\\n                }\\n            } else {\\n                List<int[]> ranges = findChildTsumoRanges(pi, ai);\\n                for (int[] r : ranges) {\\n                    sb.append(\\\"被\\\").append(players[ai].name).append(\\\"自摸\\\\t\\\");\\n                    sb.append(fmtTsumoRange(r[0], r[1], false));\\n                    sb.append(\\\"\\\\n\\\");\\n                }\\n            }\\n        }\\n\\n        // 5. DANGER ZONES\\n        sb.append(\\\"\\\\n\\\").append(players[pi].name).append(\\\"危险区间:\\\\n\\\");\\n\\n        // For each pair (ai rons vi), check if pi's qualification changes\\n        for (int ai = 0; ai < 4; ai++) {\\n            if (ai == pi) continue;\\n            for (int vi = 0; vi < 4; vi++) {\\n                if (vi == pi || vi == ai) continue;\\n                boolean aiD = (ai == dealerIdx);\\n                int[] ronArr = aiD ? DEALER_RON : CHILD_RON;\\n\\n                // Find ranges where pi does NOT qualify\\n                List<int[]> notQualRanges = new ArrayList<>();\\n                boolean prevNotQ = false;\\n                int start = -1;\\n\\n                for (int ri = 0; ri < ronArr.length; ri++) {\\n                    int base = ronArr[ri];\\n                    int bonus = 300 * honba;\\n                    int gain = base + bonus + kyotaku * 1000;\\n                    int loss = base + bonus;\\n                    int[] fs = applyRon(currentScores, ai, vi, gain, loss);\\n                    boolean q = qualifies(pi, fs, false);\\n                    boolean notQ = !q;\\n                    if (notQ && !prevNotQ) start = ri;\\n                    if (!notQ && prevNotQ) notQualRanges.add(new int[]{start, ri - 1});\\n                    prevNotQ = notQ;\\n                }\\n                if (prevNotQ) notQualRanges.add(new int[]{start, ronArr.length - 1});\\n\\n                // Compare with base qualification\\n                boolean baseQ = qualifies(pi, currentScores, true);\\n\\n                for (int[] r : notQualRanges) {\\n                    // Only show if this is a CHANGE from base state\\n                    // If baseQ = true: show ranges where pi LOSES qualification\\n                    // If baseQ = false: show ranges where pi STAYS non-qualifying\\n                    //   But only if there exist ranges where pi would qualify\\n                    if (baseQ) {\\n                        // pi currently qualifies, this range causes loss\\n                        sb.append(players[ai].name).append(\\\"点\\\").append(players[vi].name).append(\\\"\\\\t\\\");\\n                        sb.append(fmtDangerRange(ronArr, r[0], r[1], aiD));\\n                        sb.append(\\\"\\\\n\\\");\\n                    } else {\\n                        // pi currently doesn't qualify; check if there are \\\"good\\\" ranges\\n                        // Only meaningful if some values outside this range let pi qualify\\n                        boolean anyQualify = false;\\n                        for (int ri = 0; ri < ronArr.length; ri++) {\\n                            boolean inRange = false;\\n                            for (int[] nr : notQualRanges) {\\n                                if (ri >= nr[0] && ri <= nr[1]) { inRange = true; break; }\\n                            }\\n                            if (!inRange) { anyQualify = true; break; }\\n                        }\\n                        if (anyQualify) {\\n                            sb.append(players[ai].name).append(\\\"点\\\").append(players[vi].name).append(\\\"\\\\t\\\");\\n                            sb.append(fmtDangerRange(ronArr, r[0], r[1], aiD));\\n                            sb.append(\\\"\\\\n\\\");\\n                        }\\n                    }\\n                }\\n            }\\n        }\\n    }\\n\\n    // ============================================================\\n    // Score application helpers\\n    // ============================================================\\n\\n    static int[] applyRon(int[] scores, int winner, int loser, int gain, int loss) {\\n        int[] fs = scores.clone();\\n        fs[winner] += gain;\\n        fs[loser] -= loss;\\n        return fs;\\n    }\\n\\n    static int[] applyDealerTsumo(int[] scores, int winner, int eachPay, int totalGain) {\\n        int[] fs = scores.clone();\\n        for (int j = 0; j < 4; j++) {\\n            if (j == winner) fs[j] += totalGain;\\n            else fs[j] -= eachPay;\\n        }\\n        return fs;\\n    }\\n\\n    static int[] applyChildTsumo(int[] scores, int winner, int childPay, int dealerPay, int totalGain) {\\n        int[] fs = scores.clone();\\n        for (int j = 0; j < 4; j++) {\\n            if (j == winner) fs[j] += totalGain;\\n            else if (j == dealerIdx) fs[j] -= dealerPay;\\n            else fs[j] -= childPay;\\n        }\\n        return fs;\\n    }\\n\\n    // ==========================================