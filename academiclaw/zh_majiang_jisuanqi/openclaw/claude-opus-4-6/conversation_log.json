                  "arguments": "{\"content\": \"import java.util.*;\\nimport java.io.*;\\n\\n/**\\n * 立直麻将晋级条件计算器\\n * Riichi Mahjong Promotion Condition Calculator\\n *\\n * Supports: M-League, A規 (JPML), WRC, 最高位戦 (Saikouisen)\\n */\\npublic class MahjongPromoCalculator {\\n\\n    // ============================================================\\n    // Data classes\\n    // ============================================================\\n\\n    static class Player {\\n        String name;\\n        double prePt;      // total pt before this hanchan\\n        int currentScore;  // current score in this hanchan (e.g. 48200)\\n        int seatWind;      // 0=East, 1=South, 2=West, 3=North\\n    }\\n\\n    static class RuleSet {\\n        String name;\\n        int startScore;     // 持ち点 (e.g. 25000)\\n        int returnScore;    // 返し点 (e.g. 30000)\\n        double[] uma;       // 順位点 for 1st~4th (in pt units, e.g. +50, +10, -10, -30)\\n\\n        RuleSet(String name, int startScore, int returnScore, double[] uma) {\\n            this.name = name;\\n            this.startScore = startScore;\\n            this.returnScore = returnScore;\\n            this.uma = uma;\\n        }\\n    }\\n\\n    // ============================================================\\n    // Rule Sets\\n    // ============================================================\\n\\n    static final Map<String, RuleSet> RULES = new LinkedHashMap<>();\\n    static {\\n        // M-League: 25000持ち/30000返し, 順位点 +50/+10/-10/-30\\n        RULES.put(\\\"m-league\\\", new RuleSet(\\\"M-League\\\", 25000, 30000, new double[]{50, 10, -10, -30}));\\n\\n        // A規 (日本プロ麻雀連盟 A-rule): 25000持ち/30000返し, 順位点 +12/+4/-4/-12\\n        RULES.put(\\\"a規\\\", new RuleSet(\\\"A規\\\", 25000, 30000, new double[]{12, 4, -4, -12}));\\n        RULES.put(\\\"a-rule\\\", new RuleSet(\\\"A規\\\", 25000, 30000, new double[]{12, 4, -4, -12}));\\n        RULES.put(\\\"a规\\\", new RuleSet(\\\"A規\\\", 25000, 30000, new double[]{12, 4, -4, -12}));\\n\\n        // WRC: 25000持ち/30000返し, 順位点 +15/+5/-5/-15\\n        RULES.put(\\\"wrc\\\", new RuleSet(\\\"WRC\\\", 25000, 30000, new double[]{15, 5, -5, -15}));\\n\\n        // 最高位戦: 30000持ち/30000返し, ウマ 10000-30000 → 順位点 +30/+10/-10/-30\\n        RULES.put(\\\"最高位戦\\\", new RuleSet(\\\"最高位戦\\\", 30000, 30000, new double[]{30, 10, -10, -30}));\\n        RULES.put(\\\"saikouisen\\\", new RuleSet(\\\"最高位戦\\\", 30000, 30000, new double[]{30, 10, -10, -30}));\\n        RULES.put(\\\"最高位战\\\", new RuleSet(\\\"最高位戦\\\", 30000, 30000, new double[]{30, 10, -10, -30}));\\n    }\\n\\n    // ============================================================\\n    // Standard Mahjong Scores\\n    // ============================================================\\n\\n    // Child (子) Ron scores - all possible values in ascending order\\n    static final int[] CHILD_RON = {\\n        1000, 1300, 1600, 2000, 2300, 2600, 2900, 3200, 3400, 3900,\\n        4500, 4800, 5200, 5800, 6400, 6800, 7100, 7700,\\n        8000,   // mangan\\n        12000,  // haneman\\n        16000,  // baiman\\n        24000,  // sanbaiman\\n        32000,  // yakuman\\n        64000,  // double yakuman\\n        96000   // triple yakuman\\n    };\\n\\n    // Child (子) Tsumo scores: [fromChild, fromDealer]\\n    static final int[][] CHILD_TSUMO = {\\n        {300, 500}, {400, 700}, {400, 800}, {500, 1000},\\n        {600, 1200}, {700, 1300}, {700, 1300}, {800, 1600},\\n        {800, 1500}, {1000, 2000},\\n        {1200, 2300}, {1200, 2300}, {1300, 2600}, {1500, 2900},\\n        {1600, 3200}, {1600, 3200}, {1800, 3600}, {2000, 3900},\\n        {2000, 4000},   // mangan\\n        {3000, 6000},   // haneman\\n        {4000, 8000},   // baiman\\n        {6000, 12000},  // sanbaiman\\n        {8000, 16000},  // yakuman\\n        {16000, 32000}, // double yakuman\\n        {24000, 48000}  // triple yakuman\\n    };\\n\\n    // Dealer (親) Ron scores\\n    static final int[] DEALER_RON = {\\n        1500, 2000, 2400, 2900, 3400, 3900, 4400, 4800, 4800, 5800,\\n        6800, 7700, 7700, 8700, 9600, 9600, 10600, 11600,\\n        12000,  // mangan\\n        18000,  // haneman\\n        24000,  // baiman\\n        36000,  // sanbaiman\\n        48000,  // yakuman\\n        96000,  // double yakuman\\n        144000  // triple yakuman\\n    };\\n\\n    // Dealer (親) Tsumo scores: [fromEach]\\n    static final int[] DEALER_TSUMO = {\\n        500, 700, 800, 1000, 1200, 1300, 1500, 1600, 1600, 2000,\\n        2300, 2600, 2600, 2900, 3200, 3200, 3600, 3900,\\n        4000,   // mangan\\n        6000,   // haneman\\n        8000,   // baiman\\n        12000,  // sanbaiman\\n        16000,  // yakuman\\n        32000,  // double yakuman\\n        48000   // triple yakuman\\n    };\\n\\n    // Corresponding labels for child ron (used when attacker is child)\\n    // We'll show raw numbers, but for special milestones we use aliases\\n    static String childRonLabel(int score) {\\n        switch (score) {\\n            case 8000: return \\\"満貫\\\";\\n            case 12000: return \\\"跳満\\\";\\n            case 16000: return \\\"倍満\\\";\\n            case 24000: return \\\"三倍満\\\";\\n            case 32000: return \\\"役満\\\";\\n            case 64000: return \\\"2倍役满\\\";\\n            case 96000: return \\\"3倍役满\\\";\\n            default: return String.valueOf(score);\\n        }\\n    }\\n\\n    static String dealerRonLabel(int score) {\\n        switch (score) {\\n            case 12000: return \\\"満貫\\\";\\n            case 18000: return \\\"跳満\\\";\\n            case 24000: return \\\"倍満\\\";\\n            case 36000: return \\\"三倍満\\\";\\n            case 48000: return \\\"役満\\\";\\n            case 96000: return \\\"2倍役满\\\";\\n            case 144000: return \\\"3倍役满\\\";\\n            default: return String.valueOf(score);\\n        }\\n    }\\n\\n    static String ronLabel(int score, boolean attackerIsDealer) {\\n        return attackerIsDealer ? dealerRonLabel(score) : childRonLabel(score);\\n    }\\n\\n    static String childTsumoLabel(int[] ct) {\\n        return ct[0] + \\\"・\\\" + ct[1];\\n    }\\n\\n    static String dealerTsumoLabel(int dt) {\\n        return dt + \\\"all\\\";\\n    }\\n\\n    // ============================================================\\n    // Global State\\n    // ============================================================\\n\\n    static int[] currentScores;\\n    static Player[] players;\\n    static RuleSet rule;\\n    static int promoCount;\\n    static int honba;\\n    static int kyotaku;      // number of 1000-pt sticks on table\\n    static int dealerIdx;    // index of current dealer\\n\\n    // ============================================================\\n    // Core Calculation\\n    // ============================================================\\n\\n    /**\\n     * Compute final total pt for each player given their final hanchan scores.\\n     * kyotakuTo1st: if true, add kyotaku to 1st place (used for draws).\\n     */\\n    static double[] computeFinalPt(int[] finalScores, double[] prePt, boolean kyotakuTo1st) {\\n        // Rank by score (ties broken by seat index closer to East = 0)\\n        Integer[] indices = {0, 1, 2, 3};\\n        final int[] fs = finalScores;\\n        Arrays.sort(indices, (a, b) -> {\\n            if (fs[a] != fs[b]) return fs[b] - fs[a];\\n            return a - b; // seat 0 (East) > seat 1 (South) > ...\\n        });\\n\\n        int[] rank = new int[4]; // 0=1st, 1=2nd, etc.\\n        for (int i = 0; i < 4; i++) {\\n            rank[indices[i]] = i;\\n        }\\n\\n        // Handle ties: if players have same score, they share uma\\n        // Check for ties and average uma\\n        double[] umaAssign = new double[4];\\n        int i = 0;\\n        while (i < 4) {\\n            int j = i;\\n            while (j < 4 && fs[indices[j]] == fs[indices[i]]) j++;\\n            // indices[i..j-1] have same score, share uma[i..j-1]\\n            double sumUma = 0;\\n            for (int k = i; k < j; k++) sumUma += rule.uma[k];\\n            double avgUma = sumUma / (j - i);\\n            for (int k = i; k < j; k++) {\\n                umaAssign[indices[k]] = avgUma;\\n            }\\n            i = j;\\n        }\\n\\n        double[] resultPt = new double[4];\\n        for (int p = 0; p < 4; p++) {\\n            double scorePt = (finalScores[p] - rule.returnScore) / 1000.0;\\n            resultPt[p] = prePt[p] + scorePt + umaAssign[p];\\n        }\\n\\n        // Kyotaku to 1st place (for draws / end-of-game)\\n        if (kyotakuTo1st && kyotaku > 0) {\\n            resultPt[indices[0]] += kyotaku;\\n        }\\n\\n        return resultPt;\\n    }\\n\\n    /**\\n     * Check if player pi is promoted given final scores.\\n     * When a player wins (ron/tsumo), kyotaku is already incorporated into scores.\\n     * isWin: true if this is a win scenario (kyotaku already in winner's score)\\n     * isDraw: true if this is a draw (kyotaku goes to 1st)\\n     */\\n    static boolean qualifies(int pi, int[] finalScores, boolean isDraw) {\\n        double[] prePt = getPrePts();\\n        double[] finalPt = computeFinalPt(finalScores, prePt, isDraw);\\n\\n        // Rank by finalPt\\n        Integer[] indices = {0, 1, 2, 3};\\n        final double[] fp = finalPt;\\n        Arrays.sort(indices, (a, b) -> {\\n            if (Math.abs(fp[a] - fp[b]) > 0.001) return Double.compare(fp[b], fp[a]);\\n            return a - b;\\n        });\\n\\n        for (int i = 0; i < promoCount; i++) {\\n            if (indices[i] == pi) return true;\\n        }\\n        return false;\\n    }\\n\\n    // ============================================================\\n    // Main\\n    // ============================================================\\n\\n    public static void main(String[] args) throws Exception {\\n        Scanner sc;\\n        if (args.length > 0) {\\n            sc = new Scanner(new File(args[0]), \\\"UTF-8\\\");\\n        } else {\\n            sc = new Scanner(System.in, \\\"UTF-8\\\");\\n        }\\n\\n        players = new Player[4];\\n        currentScores = new int[4];\\n\\n        List<String> lines = new ArrayList<>();\\n        while (sc.hasNextLine()) {\\n            String line = sc.nextLine().trim();\\n            if (!line.isEmpty()) lines.add(line);\\n        }\\n\\n        String dealerWind = \\\"\\\";\\n        String[] seatOrder = null;\\n        String[] names = null;\\n        double[] prePts = new double[4];\\n        int[] scores = new int[4];\\n        String ruleName = \\\"\\\";\\n\\n        for (String line : lines) {\\n            if (line.startsWith(\\\"当前亲家\\\")) {\\n                dealerWind = line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim();\\n            } else if (line.startsWith(\\\"座次\\\")) {\\n                String rest = line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim();\\n                seatOrder = rest.split(\\\"\\\\\\\\s+\\\");\\n            } else if (line.startsWith(\\\"名字\\\")) {\\n                String rest = line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim();\\n                names = rest.split(\\\"\\\\\\\\s+\\\");\\n            } else if (line.startsWith(\\\"开始前总分\\\")) {\\n                String rest = line.substring(\\\"开始前总分\\\".length()).trim();\\n                String[] parts = rest.split(\\\"\\\\\\\\s+\\\");\\n                for (int i = 0; i < 4; i++) {\\n                    prePts[i] = Double.parseDouble(parts[i]);\\n                }\\n            } else if (line.startsWith(\\\"当前分数\\\")) {\\n                String rest = line.substring(\\\"当前分数\\\".length()).trim();\\n                String[] parts = rest.split(\\\"\\\\\\\\s+\\\");\\n                for (int i = 0; i < 4; i++) {\\n                    scores[i] = Integer.parseInt(parts[i]);\\n                }\\n            } else if (line.startsWith(\\\"晋级条件\\\")) {\\n                promoCount = Integer.parseInt(line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim());\\n            } else if (line.startsWith(\\\"规则\\\")) {\\n                ruleName = line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim();\\n            } else if (line.startsWith(\\\"供托\\\")) {\\n                kyotaku = Integer.parseInt(line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim());\\n            } else if (line.startsWith(\\\"本场\\\")) {\\n                honba = Integer.parseInt(line.replaceAll(\\\".*[：:]\\\\\\\\s*\\\", \\\"\\\").trim());\\n            }\\n        }\\n\\n        // Lookup rule (case-insensitive)\\n        rule = RULES.get(ruleName.toLowerCase());\\n        if (rule == null) {\\n            System.err.println(\\\"未知规则: \\\" + ruleName);\\n            System.err.println(\\\"支持的规则: M-League, A規/A规, WRC, 最高位戦/最高位战\\\");\\n            return;\\n        }\\n\\n        // Map wind names\\n        Map<String, Integer> windMap = new HashMap<>();\\n        windMap.put(\\\"东\\\", 0); windMap.put(\\\"東\\\", 0);\\n        windMap.put(\\\"南\\\", 1);\\n        windMap.put(\\\"西\\\", 2);\\n        windMap.put(\\\"北\\\", 3);\\n\\n        dealerIdx = -1;\\n        for (int i = 0; i < 4; i++) {\\n            players[i] = new Player();\\n            players[i].name = names[i];\\n            players[i].prePt = prePts[i];\\n            players[i].currentScore = scores[i];\\n            players[i].seatWind = windMap.getOrDefault(seatOrder[i], i);\\n            currentScores[i] = scores[i];\\n\\n            if (seatOrder[i].equals(dealerWind)) {\\n                dealerIdx = i;\\n            }\\n        }\\n\\n        if (dealerIdx == -1) {\\n            System.err.println(\\\"Error: dealer wind '\\\" + dealerWind + \\\"' not found in seat order\\\");\\n            return;\\n        }\\n\\n        StringBuilder sb = new StringBuilder();\\n\\n        for (int pi = 0; pi < 4; pi++) {\\n            calculatePlayerConditions(pi, sb);\\n            sb.append(\\\"\\\\n\\\");\\n        }\\n\\n        calculateDrawBranches(sb);\\n\\n        System.out.print(sb.toString());\\n    }\\n\\n    // ============================================================\\n    // Player Condition Calculation\\n    // ============================================================\\n\\n    static void calculatePlayerConditions(int pi, StringBuilder sb) {\\n        boolean piIsDealer = (pi == dealerIdx);\\n\\n        sb.append(players[pi].name).append(\\\"晋级条件\\\\n\\\");\\n\\n        // ---- 1. TSUMO ----\\n        sb.append(\\\"自摸\\\\t\\\");\\n        boolean tsumoFound = false;\\n        if (piIsDealer) {\\n            for (int ti = 0; ti < DEALER_TSUMO.length; ti++) {\\n                int baseEach = DEALER_TSUMO[ti];\\n                int eachPay = baseEach + 100 * honba;\\n                int totalGain = eachPay * 3 + kyotaku * 1000;\\n\\n                int[] fs = currentScores.clone();\\n                for (int j = 0; j < 4; j++) {\\n                    if (j == pi) fs[j] += totalGain;\\n                    else fs[j] -= eachPay;\\n                }\\n\\n                if (qualifies(pi, fs, false)) {\\n                    sb.append(dealerTsumoLabel(baseEach)).append(\\\"以上\\\");\\n                    tsumoFound = true;\\n                    break;\\n                }\\n            }\\n        } else {\\n            for (int ti = 0; ti < CHILD_TSUMO.length; ti++) {\\n                int fromChild = CHILD_TSUMO[ti][0];\\n                int fromDealer = CHILD_TSUMO[ti][1];\\n                int childPay = fromChild + 100 * honba;\\n                int dealerPay = fromDealer + 100 * honba;\\n                int totalGain = childPay * 2 + dealerPay + kyotaku * 1000;\\n\\n                int[] fs = currentScores.clone();\\n                for (int j = 0; j < 4; j++) {\\n                    if (j == pi) fs[j] += totalGain;\\n                    else if (j == dealerIdx) fs[j] -= dealerPay;\\n                    else fs[j] -= childPay;\\n                }\\n\\n                if (qualifies(pi, fs, false)) {\\n                    sb.append(childTsumoLabel(CHILD_TSUMO[ti])).append(\\\"以上\\\");\\n                    tsumoFound = true;\\n                    break;\\n                }\\n            }\\n        }\\n        if (!tsumoFound) {\\n            sb.append(\\\"无法通过自摸晋级\\\");\\n        }\\n        sb.append(\\\"\\\\n\\\");\\n\\n        // ---- 2. RON from each opponent ----\\n        sb.append(\\\"=============================\\\\n\\\");\\n        for (int vi = 0; vi < 4; vi++) {\\n            if (vi == pi) continue;\\n            int[] ronScores = piIsDealer ? DEALER_RON : CHILD_RON;\\n\\n            boolean found = false;\\n            for (int ri = 0; ri < ronScores.length; ri++) {\\n                int baseRon = ronScores[ri];\\n                int honbaBonus = 300 * honba;\\n                int piGain = baseRon + honbaBonus + kyotaku * 1000;\\n                int viLoss = baseRon + honbaBonus;\\n\\n                int[] fs = currentScores.clone();\\n                fs[pi] += piGain;\\n                fs[vi] -= viLoss;\\n\\n                if (qualifies(pi, fs, false)) {\\n                    sb.append(players[vi].name).append(\\\"荣和\\\\t\\\");\\n                    sb.append(ronLabel(baseRon, piIsDealer)).append(\\\"以上\\\");\\n                    found = true;\\n                    sb.append(\\\"\\\\n\\\");\\n                    break;\\n                }\\n            }\\n            if (!found) {\\n                sb.append(players[vi].name).append(\\\"荣和\\\\t无法通过荣和晋级\\\\n\\\");\\n            }\\n        }\\n\\n        // ---- 3. DEAL-IN to each opponent ----\\n        sb.append(\\\"=============================\\\\n\\\");\\n        for (int ai = 0; ai < 4; ai++) {\\n            if (ai == pi) continue;\\n            boolean aiIsDealer = (ai == dealerIdx);\\n            int[] ronScores = aiIsDealer ? DEALER_RON : CHILD_RON;\\n\\n            // Find ranges where pi still qualifies after dealing in\\n            List<int[]> qualifyRanges = findQualifyRanges(pi, ai, ronScores, true)