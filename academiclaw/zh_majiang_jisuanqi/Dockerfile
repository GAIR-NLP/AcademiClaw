# =============================================================================
# Query 1 专属 Dockerfile - 立直麻将晋级条件计算器
# 
# 任务需求：Java开发环境，支持编译和运行Java程序
# =============================================================================

# 使用CPU基础镜像
FROM agencybench-sandbox

# =============================================================================
# 元数据
# =============================================================================

LABEL query="T15_zh_majiang_jisuanqi"
LABEL task="立直麻将晋级条件计算器"

# =============================================================================
# 任务特定依赖
# =============================================================================

# 安装Java开发工具
RUN apt-get update && apt-get install -y \
    default-jdk \
    maven \
    gradle \
    && rm -rf /var/lib/apt/lists/*

# 设置Java环境变量
ENV JAVA_HOME=/usr/lib/jvm/default-java
ENV PATH=$PATH:$JAVA_HOME/bin

# 验证Java安装
RUN java -version && javac -version

# =============================================================================
# 工作目录
# =============================================================================

WORKDIR /agencybench

# =============================================================================
# 命令
# =============================================================================

CMD []
