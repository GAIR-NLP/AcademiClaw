                "id": "call_CkAQsu0Y3SfLF1AZXIzT77uu",
                "name": "write",
                "arguments": "{\"path\":\"/tmp/isolated_workspace_1091/solution.cpp\",\"content\":\"#include <bits/stdc++.h>\\nusing namespace std;\\n\\nint main() {\\n    ios::sync_with_stdio(false);\\n    cin.tie(nullptr);\\n\\n    int n;\\n    long long C;\\n    cin >> n >> C;\\n\\n    priority_queue<long long, vector<long long>, greater<long long>> pq;\\n    long long ans = 0;\\n\\n    for (int i = 0; i < n; ++i) {\\n        long long a;\\n        cin >> a;\\n\\n        if (!pq.empty() && a - C > pq.top()) {\\n            long long buy_cost = pq.top();\\n            pq.pop();\\n            ans += (a - C - buy_cost);\\n\\n            // Regret-based maintenance:\\n            // 1) push (a - C): treat current sale point as a virtual buy point\\n            //    so future higher prices can extend the trade without paying fee twice.\\n            // 2) push a: represent a real buy on the current day for later transactions.\\n            pq.push(a - C);\\n            pq.push(a);\\n        } else {\\n            pq.push(a);\\n        }\\n    }\\n\\n    cout << ans << '\\\\n';\\n    return 0;\\n}\\n\"}"
