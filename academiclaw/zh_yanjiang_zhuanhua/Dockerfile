# =============================================================================
# Query 专属 Dockerfile - 量子计算演讲稿生成任务
# 
# 任务类型: 学术论文转通俗演讲稿
# 需求: PDF 处理能力
# =============================================================================


# =============================================================================
# 选择基础镜像
# =============================================================================

# CPU 任务（默认）
FROM agencybench-sandbox


# =============================================================================
# 元数据
# =============================================================================

LABEL query="T37_zh_yanjiang_zhuanhua"
LABEL task="根据学术文章生成通俗演讲稿"


# =============================================================================
# 任务特定依赖
# 
# 此任务需要处理 PDF 文件（学术论文），因此安装 PDF 处理相关库
# =============================================================================

# ----- PDF 处理库 -----
RUN pip3 install --no-cache-dir \
    PyPDF2 \
    pdfplumber \
    pypdf


# =============================================================================
# 工作目录
# =============================================================================

WORKDIR /agencybench


# =============================================================================
# 重要提醒
# 
# 1. 不要定义 ENTRYPOINT - 基础镜像已经定义了正确的 entrypoint
# 2. 不要定义 CMD - 除非你有特殊需求
# 3. entrypoint 会自动处理:
#    - 准备隔离的工作目录
#    - 复制 workspace 和 context 到隔离目录
#    - 运行 eval_task.py（带正确的参数）
#    - 复制结果回宿主机
# =============================================================================

CMD []
